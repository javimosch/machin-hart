// models.src — hart's project landing, composed from machin-web-ui components
// and themed with hart's teal brand. Matches the depth of the hand-authored
// landing.html but from reusable components. SHARED by the SSR server and the
// wasm client (which hydrates the static markup).

func app_name() (s) { s = "hart" }

func feature(title, body) (h) {
    h = ui_card(title, "<p class=\"text-sm leading-6 text-muted\">" + body + "</p>")
}

func section(id, title, desc, body) (h) {
    h = "<section id=\"" + id + "\" class=\"scroll-mt-8 flex flex-col gap-6 pt-4\">"
    h = h + ui_section_header(title, desc, "")
    h = h + body + "</section>"
}

func app_view(unused) (h) {
    h = ui_navbar("hart", []string{"What", "Model", "Self-host", "GitHub"}, []string{"#what", "#model", "#selfhost", "https://github.com/javimosch/machin-hart"}, "")

    cta := "<a class=\"" + ui_button_classes("primary") + "\" href=\"https://github.com/javimosch/machin-hart\">Get hart</a>"
    cta = cta + "<a class=\"" + ui_button_classes("ghost") + "\" href=\"#what\">How it works</a>"
    h = h + ui_hero("Ship an HTML page from your terminal. Get a live URL back.",
        "One binary that hosts self-contained HTML and JSX — versioned, sandboxed, and updatable with just data. Built for agents, run by you.", cta)

    stats := "<div class=\"grid grid-cols-1 gap-3 sm:grid-cols-3\">"
    stats = stats + ui_stat("binary", "one", "CLI + hosting daemon")
    stats = stats + ui_stat("versions", "immutable", "v1/v2/latest, instant rollback")
    stats = stats + ui_stat("runtime deps", "zero", "pure MFL, no Node")
    stats = stats + "</div>"
    h = h + stats

    // --- What it is ---
    grid := "<div class=\"grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3\">"
    grid = grid + feature("A home for agent HTML", "Claude and friends generate great HTML. hart gives it a real, shareable, sandboxed URL — for any terminal agent, not one vendor's.")
    grid = grid + feature("Pipe a file, get a URL", "Pipe a self-contained file; get /a/owner/name back. JSX is transpiled in-browser with a same-origin React runtime — no build step, no CDN.")
    grid = grid + feature("Immutable versions", "Re-publish to append a version. Latest always tracks newest; old versions stay immutably pinned; rollback reverts instantly.")
    grid = grid + feature("Sandboxed by default", "Every artifact is served under a strict CSP — no external scripts, no network. A publish-time linter blocks anything that reaches off-page.")
    grid = grid + feature("Agent-first I/O", "JSON in, JSON out, semantic exit codes, no UI tax. The interface is the CLI — an agent drives it blind.")
    grid = grid + feature("Content-addressed", "Publishes are hash-addressed and deduplicated. The store is just the filesystem — no index, schedule with plain cron.")
    grid = grid + feature("Operator visibility", "Run one instance for all your agents. An admin token unlocks cross-owner discovery — list every owner and artifact, and move/rename them in place (history + read-key preserved).")
    grid = grid + feature("Living deliverables", "A page can stay alive: push new data to the same URL, or let hart self-refresh it on a schedule from a URL or command. Opt a page into live mode and it repaints in the browser without a reload.")
    grid = grid + feature("hart Pro (open-core)", "The CLI is fully free; a license key unlocks higher storage limits, an audit log (who changed what), and teams. Honest, offline-verified keys — buy agent-first with <code class=\"rounded bg-surface-100 dark:bg-surface-800 px-1 py-0.5 text-ink dark:text-ink-100\">hart upgrade</code>.")
    grid = grid + feature("Teams & SSO", "Share a namespace with per-member keys, each with its own identity in the audit log. Members self-onboard with <code class=\"rounded bg-surface-100 dark:bg-surface-800 px-1 py-0.5 text-ink dark:text-ink-100\">hart join</code> via any OpenID Connect provider you point it at — you bring the IdP.")
    grid = grid + "</div>"
    h = h + section("what", "What it is", "The agent-first artifact host, at a glance.", grid)

    // --- Template + data model ---
    tpl := "<div class=\"flex flex-col gap-4\">"
    tpl = tpl + "<p class=\"text-sm leading-6 text-muted\">Publish a template once, then push just the data — the artifact re-renders. An agent keeps a page live as its source data changes. Use double-brace placeholders, or read <code class=\"rounded bg-surface-100 dark:bg-surface-800 px-1 py-0.5 text-ink dark:text-ink-100\">window.HART_DATA</code> from your script.</p>"
    tpl = tpl + ui_code_block("1 - publish a template", "echo '<h1>Hello, {{name}}</h1>' > g.html\nhart publish g.html --owner acme --artifact hello\n# -> /a/acme/hello")
    tpl = tpl + ui_code_block("2 - push data (one call, re-renders live)", "hart data acme/hello data.json\n# data.json holds the values; /a/acme/hello now greets by name")
    tpl = tpl + ui_code_block("3 - or let hart keep it fresh itself", "hart refresh acme/hello --url https://api/metrics --every 15m\nhart live acme/hello on   # repaint in the browser, no reload")
    tpl = tpl + "</div>"
    h = h + section("model", "The template + data model", "Separate the page from its data; update either independently.", tpl)

    // --- Run your own ---
    run := "<div class=\"grid grid-cols-1 gap-6 md:grid-cols-2\">"
    run = run + "<div class=\"flex flex-col gap-4\">" + ui_code_block("build and serve (your box)", "./build.sh && ./hart serve 8799\n# SQLite store at $HART_DB (default ~/.hart.db)\n\nexport HART_URL=https://hart.yourdomain\nhart publish report.html --title 'Q3'") + "</div>"
    run = run + "<div>" + ui_list_group([]string{
        "one static binary", "CLI + daemon, no runtime deps",
        "store", "content-addressed files + SQLite metadata",
        "auth", "BYOK, open-core, self-hostable",
        "safety", "strict CSP + publish-time linter"}) + "</div>"
    run = run + "</div>"
    h = h + section("selfhost", "Run your own", "Fully self-hostable. One binary is both the CLI and the daemon.", run)

    // --- FAQ ---
    faq := ui_accordion([]string{
        "How is this different from Netlify or Pastebin?", "Netlify is human-first (a dashboard, a build). Pastebin does not render or sandbox. hart is agent-first (JSON/CLI, no UI) and safely hosts UNTRUSTED agent HTML under a strict CSP with content-addressed versioning.",
        "Do I need Node or a build step?", "No. hart is one machin (MFL) static binary. JSX is transpiled in the browser with a same-origin React runtime — no bundler, no CDN.",
        "Can I roll back a bad publish?", "Yes. Every publish is an immutable version; latest tracks the newest, old versions stay pinned at /a/owner/name/vN, and rollback is instant.",
        "Who is it for?", "Any terminal agent — Cursor, aider, Codex, Gemini CLI, or your own — that generates HTML and needs a live, shareable, safe URL back."})
    h = h + section("faq", "FAQ", "", faq)

    h = h + ui_footer("hart &mdash; the show arm of the agent-first stack. This page is built with <span class=\"text-ink\">machin</span> + machin-web-ui.",
        []string{"GitHub", "machin", "machin-web-ui"}, []string{"https://github.com/javimosch/machin-hart", "https://github.com/javimosch/machin", "https://github.com/javimosch/machin-web-ui"})
}
