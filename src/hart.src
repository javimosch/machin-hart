// hart — the agent-first artifact host. One MFL/machin static binary that is BOTH a hosting
// daemon (`hart serve`) and a CLI (`hart publish <file>` → a live, sandboxed URL). M0 spike:
// prove the loop end to end — publish HTML → stored+versioned in SQLite → served at /a/<id>
// wrapped in a doctype skeleton + a strict CSP, with v1/v2/v3/latest versioning.
//
// Agent-first: JSON on stdout, structured errors on stderr, semantic exit codes.
// Env: HART_URL (publish target, default http://127.0.0.1:8799), HART_DB (default ~/.hart.db),
//      HART_PORT (serve port, default 8799), HART_PUBLIC (public base for returned URLs).

type ArtRow struct { id string  owner string  name string  title string  latest int  data string  visibility string  read_key_hash string  created int  updated int }
type VerRow struct { version int  format string  created int }
type HtmlRow struct { html string  format string  title string }
type SumRow struct { s int }
type CntRow struct { n int }
type OwnerRow struct { owner string  key_hash string  created int }
type ListRow struct { id string  owner string  name string  title string  visibility string  updated int }
type AdmArt struct { id string  owner string  name string  title string  latest int  visibility string  read_key_hash string  updated int  views int  fresh_ttl int }
type StatArt struct { id string  owner string  latest int  visibility string  updated int  data_updated int  fresh_ttl int }
type StatRow struct { total int  last_view int }
type RefRow struct { host string  count int }
type StaleRow struct { id string  owner string  updated int  data_updated int  fresh_ttl int }
type RefreshRow struct { artifact_id string  kind string  source string  header string  every int  next int  last int  last_status string  enabled int }
type JoinRow struct { token string  owner string  status string  email string  member_key string  created int }
type TopRow struct { id string  owner string  views int }
type RecRow struct { id string  owner string  created int }
type FbRow struct { id string  kind string  message string  context string  reporter string  version string  created int }
type AdmOwn struct { owner string  cnt int  updated int  bytes int  has_key int }

// the strict render sandbox — same envelope idea as Claude artifacts: renders the page while
// neutering it as an exfiltration/attack vector. No external anything; no network.
func csp() (c) {
    c = "default-src 'none'; img-src data: blob:; media-src data: blob:; style-src 'unsafe-inline'; font-src data:; script-src 'unsafe-inline' 'unsafe-eval'; base-uri 'none'; form-action 'none'; frame-ancestors 'self'"
}

// JSX pages additionally load the same-origin runtime (react/babel) — script-src gains 'self'
// for those assets only. Still no external host, still no network.
func csp_jsx() (c) {
    c = "default-src 'none'; img-src data: blob:; media-src data: blob:; style-src 'unsafe-inline'; font-src data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; base-uri 'none'; form-action 'none'; frame-ancestors 'self'"
}

// Live artifacts (D2 slice 2) add `connect-src 'self'` — ONLY so the page can fetch its OWN
// same-origin /a/<id>/data.json and repaint without a reload. Still no external host: a live
// page can talk to hart about itself, nothing else. Applied per-artifact (opt-in `live` flag);
// every non-live artifact keeps the full default-src 'none' lockdown above.
func csp_live() (c) {
    c = "default-src 'none'; connect-src 'self'; img-src data: blob:; media-src data: blob:; style-src 'unsafe-inline'; font-src data:; script-src 'unsafe-inline' 'unsafe-eval'; base-uri 'none'; form-action 'none'; frame-ancestors 'self'"
}
func csp_jsx_live() (c) {
    c = "default-src 'none'; connect-src 'self'; img-src data: blob:; media-src data: blob:; style-src 'unsafe-inline'; font-src data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; base-uri 'none'; form-action 'none'; frame-ancestors 'self'"
}

// ---- hart Pro license (M3 Plan A, slice 0) --------------------------------
// Open-core: pro features gate behind `licensed(feature)`. A key is an Ed25519-signed token
// (`hart_pro.<b64url(payload)>.<b64url(sig)>`) minted by hart-cloud and verified OFFLINE here —
// the binary embeds the public key, no phone-home. Enforcement is honest, not DRM: the source
// is public and the check is removable; people pay for support/updates/compliance.

// The signing public key. Default is the intrane key; HART_LICENSE_PUBKEY overrides it so anyone
// can run their own hart-cloud. (Current default is a DEV key — replace before selling.)
func license_pubkey() (h) {
    h = env("HART_LICENSE_PUBKEY")
    if h == "" { h = "284381ce529e6971c46f4b403fefb33c50468b50de8b1302af37ebfd0b04ac05" }
}

func lic_b64pad(s) (t) {
    t = replace(s, "-", "+")
    t = replace(t, "_", "/")
    while (len(t) % 4) != 0 { t = t + "=" }
}
func lic_b64_str(s) (o) { o = base64_decode(lic_b64pad(s)) }
func lic_b64_bytes(s) (o) { o = base64_decode_bytes(lic_b64pad(s)) }

func lic_split3(s) (a, b, c) {
    a = ""  b = ""  c = ""
    i := index(s, ".")
    if i < 0 { return }
    a = substr(s, 0, i)
    rest := substr(s, i + 1, len(s))
    j := index(rest, ".")
    if j < 0 { b = rest  return }
    b = substr(rest, 0, j)
    c = substr(rest, j + 1, len(rest))
}

// parse_license — verify signature + expiry. valid=1 only if the sig checks against the embedded
// pubkey AND exp is in the future. features is the raw JSON array string from the payload.
func parse_license(token) (valid, plan, features, exp) {
    valid = 0  plan = ""  features = "[]"  exp = 0
    if token == "" { return }
    p, si, sigb := lic_split3(token)
    if p != "hart_pro" || si == "" || sigb == "" { return }
    if ed25519_verify(from_hex(license_pubkey()), bytes("hart_pro." + si), lic_b64_bytes(sigb)) == false { return }
    payload := lic_b64_str(si)
    pv, _ := json_get(payload, ".plan")
    plan = unq(pv)
    ev, _ := json_get(payload, ".exp")
    exp = parse_int(ev)
    fv, ferr := json_get(payload, ".features")
    if ferr == "" { features = fv }
    if exp > now() { valid = 1 }
}

// current_license — the active key: HART_LICENSE_KEY env first, else the stored license row.
func current_license() (tok) {
    tok = env("HART_LICENSE_KEY")
    if tok != "" { return }
    db := opendb()
    rows := sqlite_query(db, "SELECT token FROM license WHERE id = 1", []string{})
    sqlite_close(db)
    tv, _ := json_get(rows, "[0].token")
    tok = unq(tv)
}

// licensed — is `feature` unlocked by the current, valid license? The gate every pro feature calls.
func licensed(feature) (ok) {
    ok = 0
    valid, plan, features, exp := parse_license(current_license())
    if valid == 0 { return }
    if index(features, "\"" + feature + "\"") >= 0 { ok = 1 }
}

// licensed_db — same check but reads the license from an already-open handle (no nested opendb),
// for hot-ish paths inside a request that already hold `db` (e.g. the audit recorder).
func license_token_db(db) (tok) {
    tok = env("HART_LICENSE_KEY")
    if tok != "" { return }
    rows := sqlite_query(db, "SELECT token FROM license WHERE id = 1", []string{})
    tv, _ := json_get(rows, "[0].token")
    tok = unq(tv)
}
func licensed_db(db, feature) (ok) {
    ok = 0
    valid, plan, features, exp := parse_license(license_token_db(db))
    if valid == 0 { return }
    if index(features, "\"" + feature + "\"") >= 0 { ok = 1 }
}

// ---- teams (M3 slice 1, pro) ----------------------------------------------
// A team = an owner namespace with named members, each holding their own key (mk_...). A member key
// authorizes writes to that owner (in addition to the shared owner-key) and, crucially, makes the
// actor in the audit log the member's EMAIL instead of an IP. Gated by licensed("teams").

// member_email — the email behind a valid x-hart-member-key for `owner`, else "".
func member_email(db, owner, req) (email) {
    email = ""
    k := header(req, "x-hart-member-key")
    if k == "" { return }
    h := to_hex(sha256_bytes(bytes(k)))
    rows := sqlite_query(db, "SELECT email FROM members WHERE owner = ? AND key_hash = ?", []string{owner, h})
    ev, err := json_get(rows, "[0].email")
    if err == "" { email = unq(ev) }
}

// owner_key_only — the STRICT gate for managing a team (adding/removing members): admin token or the
// owner-key itself, never a member key (a member must not be able to escalate by editing the roster).
func owner_key_only(db, owner, req) (ok) {
    ok = 0
    if check_admin(req) == 1 { return 1 }
    if owner == "" { return }
    k := header(req, "x-hart-owner-key")
    if k == "" { return }
    provided := to_hex(sha256_bytes(bytes(k)))
    rows := sqlite_query(db, "SELECT key_hash FROM owners WHERE owner = ?", []string{owner})
    hv, err := json_get(rows, "[0].key_hash")
    if err != "" { return }
    kh := unq(hv)
    if kh != "" && provided == kh { ok = 1 }
}

// audit — record a mutating action IF the audit-log pro feature is licensed (else a no-op, so the
// free tier carries no audit cost). Actor = the acting team member's email if a member key is
// present, else the client IP. Uses the caller's open db handle. Best-effort, never blocks.
func audit(db, action, owner, artifact_id, version, detail, req) {
    if licensed_db(db, "audit-log") == 0 { return }
    actor := ""
    if owner != "" { actor = member_email(db, owner, req) }
    if actor == "" { actor = hart_client_ip(req) }
    sqlite_exec(db, "INSERT INTO audit(ts, action, owner, artifact_id, version, actor, detail) VALUES(?,?,?,?,?,?,?)", []string{str(now()), action, owner, artifact_id, str(version), actor, detail})
}

func runtime_dir() (d) {
    d = env("HART_RUNTIME_DIR")
    if d == "" { d = "runtime" }
}

func hdb() (p) {
    p = env("HART_DB")
    if p == "" { p = env("HOME") + "/.hart.db" }
}

func opendb() (db) {
    db = sqlite_open(hdb())
    sqlite_exec(db, "PRAGMA busy_timeout=3000", []string{})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS artifacts(id TEXT PRIMARY KEY, owner TEXT DEFAULT '', name TEXT DEFAULT '', title TEXT, latest INTEGER DEFAULT 0, created INTEGER, updated INTEGER)", []string{})
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN owner TEXT DEFAULT ''", []string{})   // no-op once it exists
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN name TEXT DEFAULT ''", []string{})
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN data TEXT DEFAULT ''", []string{})   // the template's live data (window.HART_DATA + {{key}})
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN visibility TEXT DEFAULT 'unlisted'", []string{})   // unlisted (default) | public | private
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN read_key_hash TEXT DEFAULT ''", []string{})   // sha256 of the read password (private mode)
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS versions(artifact_id TEXT, version INTEGER, title TEXT, format TEXT, html TEXT, hash TEXT, created INTEGER, PRIMARY KEY(artifact_id, version))", []string{})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS hits(ip TEXT, ts INTEGER)", []string{})   // per-IP submit rate window
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS owners(owner TEXT PRIMARY KEY, key_hash TEXT DEFAULT '', created INTEGER)", []string{})   // namespace claim keys
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN data_updated INTEGER DEFAULT 0", []string{})   // last `hart data` push (living-deliverable freshness)
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN fresh_ttl INTEGER DEFAULT 0", []string{})   // freshness SLA in seconds (0 = not a monitored living deliverable) -> `hart stale`
    // living-deliverable analytics: server-side view counting (CSP blocks any client-side beacon,
    // so the only privacy-respecting count is the HTTP GET the daemon serves). Aggregate counters,
    // no event log -> O(1) storage, nothing to prune, no cookies/JS/third-party trackers.
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS views(artifact_id TEXT PRIMARY KEY, total INTEGER DEFAULT 0, last_view INTEGER DEFAULT 0)", []string{})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS view_referers(artifact_id TEXT, host TEXT, count INTEGER DEFAULT 0, PRIMARY KEY(artifact_id, host))", []string{})
    // feedback: bugs/ideas/praise from agents & operators. `hart feedback` writes here + best-effort
    // to a central relay (machin-feedback). Idempotent on client id (dual-write dedup).
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS feedback(id TEXT PRIMARY KEY, kind TEXT DEFAULT '', message TEXT, context TEXT DEFAULT '', reporter TEXT DEFAULT '', version TEXT DEFAULT '', created INTEGER, ip TEXT DEFAULT '')", []string{})
    // living loop: a per-artifact refresh source the daemon runs on a schedule to push fresh data
    // itself (kind 'url' = GET the URL; 'cmd' = run a shell command, operator/admin only). D2.
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS refresh(artifact_id TEXT PRIMARY KEY, kind TEXT DEFAULT 'url', source TEXT DEFAULT '', header TEXT DEFAULT '', every INTEGER DEFAULT 0, next INTEGER DEFAULT 0, last INTEGER DEFAULT 0, last_status TEXT DEFAULT '', enabled INTEGER DEFAULT 1)", []string{})
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN live INTEGER DEFAULT 0", []string{})   // D2 slice 2: page may fetch its own /data.json and repaint (relaxes CSP to connect-src 'self')
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS license(id INTEGER PRIMARY KEY, token TEXT DEFAULT '', updated INTEGER DEFAULT 0)", []string{})   // M3 Plan A: hart Pro license key (single row id=1)
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS audit(id INTEGER PRIMARY KEY AUTOINCREMENT, ts INTEGER, action TEXT, owner TEXT DEFAULT '', artifact_id TEXT DEFAULT '', version INTEGER DEFAULT 0, actor TEXT DEFAULT '', detail TEXT DEFAULT '')", []string{})   // M3 slice 1: pro audit log
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS members(owner TEXT, email TEXT, key_hash TEXT, role TEXT DEFAULT 'writer', created INTEGER, PRIMARY KEY(owner, email))", []string{})   // M3 slice 1: pro teams (per-member keys)
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS joins(token TEXT PRIMARY KEY, owner TEXT, status TEXT DEFAULT 'pending', email TEXT DEFAULT '', member_key TEXT DEFAULT '', created INTEGER)", []string{})   // teams SSO: pending `hart join` self-onboarding flows
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS oidc_meta(issuer TEXT PRIMARY KEY, authz TEXT, token TEXT, userinfo TEXT, fetched INTEGER)", []string{})   // cached OIDC discovery per issuer
}

// referer_host — the bare host of an inbound Referer header ("" -> "direct"). Self-referrals
// (same host the client hit) are dropped so internal navigation doesn't pollute the breakdown.
func referer_host(ref, ownhost) (h) {
    h = "direct"
    if ref == "" { return "direct" }
    r := ref
    ci := index(r, "://")
    if ci >= 0 { r = substr(r, ci + 3, len(r)) }
    si := index(r, "/")
    if si >= 0 { r = substr(r, 0, si) }
    if r == "" { return "direct" }
    if r == ownhost { return "" }   // self — skip
    h = r
}

// record_view — count one authorized render of an artifact (aggregate upserts). Best-effort:
// never blocks or fails the serve.
func record_view(db, id, req) {
    n := now()
    sqlite_exec(db, "INSERT INTO views(artifact_id, total, last_view) VALUES(?,1,?) ON CONFLICT(artifact_id) DO UPDATE SET total = total + 1, last_view = excluded.last_view", []string{id, str(n)})
    h := referer_host(header(req, "referer"), header(req, "host"))
    if h != "" { sqlite_exec(db, "INSERT INTO view_referers(artifact_id, host, count) VALUES(?,?,1) ON CONFLICT(artifact_id, host) DO UPDATE SET count = count + 1", []string{id, h}) }
}

// human_dur — a compact age string for the stale report (37s / 12m / 5h / 3d).
func human_dur(s) (o) {
    if s < 60 { return str(s) + "s" }
    if s < 3600 { return str(s / 60) + "m" }
    if s < 86400 { return str(s / 3600) + "h" }
    o = str(s / 86400) + "d"
}

// owner_authorized — the namespace claim model (works even when the instance is free/tokenless):
// first mutation to a NEW owner claims it (with a key if the client sent one, else open); once an
// owner is claimed with a key, all further mutations to it require that key (X-Hart-Owner-Key).
// Anonymous artifacts (owner == "") have no namespace to protect. Returns 1 if allowed to write.
func owner_authorized(db, owner, req) (ok) {
    ok = 0
    if owner == "" { return 1 }
    provided := ""
    k := header(req, "x-hart-owner-key")
    if k != "" { provided = to_hex(sha256_bytes(bytes(k))) }
    rows := sqlite_query(db, "SELECT owner, key_hash, created FROM owners WHERE owner = ?", []string{owner})
    os := parse(rows, []OwnerRow{})
    if len(os) == 0 {
        sqlite_exec(db, "INSERT INTO owners(owner, key_hash, created) VALUES(?,?,?)", []string{owner, provided, str(now())})
        return 1
    }
    if os[0].key_hash == "" { return 1 }
    if provided == os[0].key_hash { return 1 }
    // teams (pro): a valid per-member key also authorizes writes to this owner
    if licensed_db(db, "teams") == 1 && member_email(db, owner, req) != "" { return 1 }
}

// cookie_secret — a stable HMAC secret for signed unlock cookies, initialized once at startup
// (cmd_serve). HART_COOKIE_SECRET pins it across restarts (else unlock cookies invalidate on
// restart — users just re-enter the password, which is fine).
var g_cookie_secret = ""
func cookie_secret() (s) { s = g_cookie_secret }

// pubbase_over_https — 1 if the public base is HTTPS (so unlock cookies get "; Secure").
func pubbase_over_https() (yes) {
    yes = 0
    if has_prefix(env("HART_PUBLIC"), "https://") { yes = 1 }
}

// read_cookie_name — a URL/cookie-safe per-artifact name for the unlock cookie.
func read_cookie_name(id) (n) {
    n = "hr_" + substr(to_hex(sha256_bytes(bytes(id))), 0, 16)
}

// read_authorized — may the requester VIEW this (private) artifact? A valid X-Hart-Read-Key
// header OR a valid signed unlock cookie (value == current read_key_hash) grants access.
func read_authorized(db, id, kh, req) (ok) {
    ok = 0
    if kh == "" { return 1 }   // not gated
    hk := header(req, "x-hart-read-key")
    if hk != "" { if to_hex(sha256_bytes(bytes(hk))) == kh { return 1 } }
    val, vok := get_session(req, cookie_secret(), read_cookie_name(id))
    if vok == 1 && val == kh { return 1 }
}

// ---- abuse limits (customizable; the daemon is otherwise open/free) --------
func max_submits_per_min() (n) {
    n = parse_int(env("HART_MAX_SUBMITS_PER_MIN"))
    if n <= 0 { n = 10 }
}
// Per-owner storage quota (M3 slice 1 — limits gating). The FREE tier is capped at today's
// value (no regression); the `limits` pro feature lets the operator raise it (or go unlimited).
// configured_owner_mb — the operator's desired cap (HART_MAX_OWNER_MB, default 30; 0 = unlimited).
func configured_owner_mb() (mb) {
    if env("HART_MAX_OWNER_MB") == "" { mb = 30  return }
    mb = parse_int(env("HART_MAX_OWNER_MB"))
}
// free_owner_mb — the ceiling the FREE tier can't exceed (HART_FREE_MAX_OWNER_MB, default 30 = today).
func free_owner_mb() (mb) {
    if env("HART_FREE_MAX_OWNER_MB") == "" { mb = 30  return }
    mb = parse_int(env("HART_FREE_MAX_OWNER_MB"))
    if mb <= 0 { mb = 30 }
}
// effective per-owner quota in BYTES. 0 = unlimited. Pro honors the configured cap; free clamps to
// the free ceiling (a configured "unlimited" also clamps down without a license).
func max_owner_bytes() (n) {
    cmb := configured_owner_mb()
    if licensed("limits") == 1 { n = cmb * 1048576  return }
    fmb := free_owner_mb()
    eff := cmb
    if cmb == 0 || cmb > fmb { eff = fmb }
    n = eff * 1048576
}

// hart_client_ip — client IP for rate limits. Uses machweb client_ip (respects set_trust_proxy);
// never trusts X-Forwarded-For on a direct socket unless the operator enabled proxy trust.
func hart_client_ip(req) (ip) {
    ip = client_ip(req)
    if ip == "" { ip = "unknown" }
}

// rate_ok — sliding 60s window per IP. Prunes old rows, counts recent, records this hit.
func rate_ok(db, ip) (ok) {
    cut := now() - 60
    sqlite_exec(db, "DELETE FROM hits WHERE ts < ?", []string{str(cut)})
    crows := sqlite_query(db, "SELECT COUNT(*) AS n FROM hits WHERE ip = ? AND ts >= ?", []string{ip, str(cut)})
    cs := parse(crows, []CntRow{})
    if len(cs) > 0 && cs[0].n >= max_submits_per_min() { return 0 }
    sqlite_exec(db, "INSERT INTO hits(ip, ts) VALUES(?,?)", []string{ip, str(now())})
    ok = 1
}

// ---- peage overage (optional) ----------------------------------------------
// A caller past the free rate limit can pay per call by resending with an
// X-Peage-Wallet header: the charge goes through the peage rail
// (https://peage.intrane.fr) as merchant PEAGE_MERCHANT_KEY at
// HART_PEAGE_PRICE_CENTS (default 1). Unconfigured instances keep the plain
// 429 — metering is additive, never a new failure mode.

func hart_peage_price() (c) {
    c = parse_int(env("HART_PEAGE_PRICE_CENTS"))
    if env("HART_PEAGE_PRICE_CENTS") == "" { c = 1 }
}

// peage_overage — called only when rate_ok said no. ok=1: the caller paid, proceed.
// ok=0: res is the refusal to return (429, or peage's 402/403 passed through).
func peage_overage(req, kind) (ok, res) {
    ok = 0
    w := header(req, "x-peage-wallet")
    key := env("PEAGE_MERCHANT_KEY")
    hint := ""
    if key != "" { hint = " — or pay per call: resend with an X-Peage-Wallet header (see https://peage.intrane.fr/llms.txt)" }
    if w == "" || key == "" {
        res = response("429 Too Many Requests", "application/json", "{\"ok\":false,\"error\":\"rate limit: max " + str(max_submits_per_min()) + " submits/min — slow down" + hint + "\"}")
        return ok, res
    }
    price := hart_peage_price()
    body := "{\"wallet_token\":" + json(w) + ",\"amount_cents\":" + str(price) + ",\"memo\":" + json("hart " + kind)
    idem := header(req, "x-peage-idempotency")
    if idem != "" { body = body + ",\"idempotency_key\":" + json(idem) }
    body = body + "}"
    api := env("PEAGE_URL")
    if api == "" { api = "https://peage.intrane.fr" }
    status, resp, herr := http_request("POST", api + "/v1/charge", []string{"content-type: application/json", "authorization: Bearer " + key}, body)
    if herr != "" {
        res = response("429 Too Many Requests", "application/json", "{\"ok\":false,\"error\":\"rate limit (and the peage rail is unreachable right now) — slow down and retry\"}")
        return ok, res
    }
    if status == 200 {
        rc, _ := json_get(resp, ".receipt")
        write(2, "{\"event\":\"peage_overage\",\"kind\":" + json(kind) + ",\"amount_cents\":" + str(price) + ",\"receipt\":" + rc + "}\n")
        ok = 1
        return ok, res
    }
    st := "402 Payment Required"
    if status == 403 { st = "403 Forbidden" }
    if status == 404 { st = "404 Not Found" }
    res = response(st, "application/json", resp)
    return ok, res
}

// owner_bytes — total stored HTML bytes for an owner (quota accounting).
func owner_bytes(db, owner) (n) {
    srows := sqlite_query(db, "SELECT COALESCE(SUM(LENGTH(v.html)),0) AS s FROM versions v JOIN artifacts a ON v.artifact_id = a.id WHERE a.owner = ?", []string{owner})
    ss := parse(srows, []SumRow{})
    if len(ss) > 0 { n = ss[0].s }
}

func nid() (s) { s = to_hex(rand_bytes(6)) }

// hart_version — single source of truth for the version reported to clients (MCP serverInfo).
func hart_version() (s) { s = "0.4.3" }

func unq(s) (o) {
    o = s
    n := len(s)
    if n >= 2 { if substr(s, 0, 1) == "\"" { o = substr(s, 1, n - 1) } }
}

// auth: a single OPTIONAL static token, set by the self-hoster. If HART_TOKEN is set on the
// daemon, mutating requests must present it (Bearer); if unset, the service is OPEN (free).
// Ownership is a plain label (--owner), not a secured identity — legible, not access-control.
func check_token(req) (ok) {
    st := env("HART_TOKEN")
    if st == "" { return 1 }
    if header(req, "authorization") == "Bearer " + st { return 1 }
    at := env("HART_ADMIN_TOKEN")   // the operator god-token also satisfies the write gate (admin >= publish)
    if at != "" && header(req, "authorization") == "Bearer " + at { return 1 }
    ok = 0
}

// check_admin — a SEPARATE operator god-token (HART_ADMIN_TOKEN), distinct from HART_TOKEN. Grants
// cross-owner read/enumeration of ALL artifacts on this instance. You own the box and the SQLite
// file, so this just exposes that power over the CLI. UNSET = the admin API is OFF (403), never
// open — the opposite default from check_token, which opens the write API when HART_TOKEN is unset.
func check_admin(req) (ok) {
    at := env("HART_ADMIN_TOKEN")
    if at == "" { return 0 }
    if header(req, "authorization") == "Bearer " + at { return 1 }
    ok = 0
}

// jesc — minimal JSON string escaper for hand-built JSON (free-text fields like `title`).
func jesc(s) (o) {
    o = ""
    i := 0
    for i < len(s) {
        c := substr(s, i, i + 1)
        if c == "\\" { o = o + "\\\\" } else { if c == "\"" { o = o + "\\\"" } else { if c == "\n" { o = o + "\\n" } else { if c == "\r" { o = o + "\\r" } else { if c == "\t" { o = o + "\\t" } else { o = o + c } } } } }
        i = i + 1
    }
}

// slugify — a URL-safe artifact name: lowercase, non-alnum runs -> single "-", trimmed.
func slugify(s) (out) {
    lc := to_lower(s)
    out = ""
    prevdash := 1
    i := 0
    for i < len(lc) {
        c := substr(lc, i, i + 1)
        keep := 0
        if c >= "a" && c <= "z" { keep = 1 }
        if c >= "0" && c <= "9" { keep = 1 }
        if keep == 1 {
            out = out + c
            prevdash = 0
        } else {
            if prevdash == 0 { out = out + "-"; prevdash = 1 }
        }
        i = i + 1
    }
    if len(out) > 0 { if substr(out, len(out) - 1, len(out)) == "-" { out = substr(out, 0, len(out) - 1) } }
}

// valid_id — URL-safe artifact id: lowercase alnum, hyphen, slash; no traversal; bounded length.
func valid_id(id) (ok) {
    ok = 0
    if id == "" { return }
    if len(id) > 128 { return }
    if index(id, "..") >= 0 { return }
    if index(id, "\\") >= 0 { return }
    i := 0
    for i < len(id) {
        c := substr(id, i, i + 1)
        good := 0
        if c >= "a" && c <= "z" { good = 1 }
        if c >= "0" && c <= "9" { good = 1 }
        if c == "-" || c == "/" { good = 1 }
        if good == 0 { return }
        i = i + 1
    }
    ok = 1
}

// invalid_id_json — consistent 400 body for rejected artifact ids (daemon handlers).
func invalid_id_json() (s) { s = "{\"ok\":false,\"error\":\"invalid id — use owner/artifact (lowercase alnum and hyphens)\"}" }

// invalid_owner_json / invalid_artifact_json — consistent 400 bodies for rejected slugs (daemon).
func invalid_owner_json() (s) { s = "{\"ok\":false,\"error\":\"invalid owner — use letters, digits, or hyphens\"}" }
func invalid_artifact_json() (s) { s = "{\"ok\":false,\"error\":\"invalid artifact — use letters, digits, or hyphens\"}" }

// reject_bad_slug — 1 if raw was provided but slugify emptied it (caller should 400).
func reject_bad_slug(raw) (bad) {
    bad = 0
    if raw != "" && slugify(raw) == "" { bad = 1 }
}

func say(s) { write(1, s + "\n") }
func die(code, msg) { write(2, "{\"ok\":false,\"error\":\"" + msg + "\"}\n"); exit(code) }

// require_valid_id — CLI-side guard: reject bad ids locally (exit 80) before any HTTP round-trip.
func require_valid_id(id) {
    if id == "" { die(80, "need an artifact id (owner/name)") }
    if valid_id(id) == 0 { die(80, "invalid id — use owner/artifact (lowercase alnum and hyphens, no ..)") }
}

// require_owner_slug — CLI-side guard for --owner / --artifact flags.
func require_owner_slug(raw, label) (out) {
    out = slugify(raw)
    if raw != "" && out == "" { die(80, "invalid " + label + " — use letters, digits, or hyphens") }
}

// require_mv_to — CLI-side guard for admin mv destination (owner/name).
func require_mv_to(raw) {
    si := index(raw, "/")
    if si <= 0 { die(80, "target must be owner/name") }
    nowner := require_owner_slug(substr(raw, 0, si), "owner")
    nname := require_owner_slug(substr(raw, si + 1, len(raw)), "name")
    require_valid_id(nowner + "/" + nname)
}

// cli_resolve_id — pick id from --id, --owner+--artifact, or a positional arg; validate locally.
func cli_resolve_id(a, pos) (id) {
    owner := flagv(a, "--owner", "")
    artifact := flagv(a, "--artifact", "")
    id = flagv(a, "--id", "")
    if id == "" && owner != "" && artifact != "" {
        so := require_owner_slug(owner, "owner")
        sa := require_owner_slug(artifact, "artifact")
        id = so + "/" + sa
    }
    if id == "" && len(a) > pos { id = a[pos] }
    require_valid_id(id)
}

// public base for the URLs we hand back. HART_PUBLIC pins the real domain (hosted/proxied);
// otherwise reflect the Host the client actually hit, so returned URLs are always dialable.
func pubbase(req) (b) {
    b = env("HART_PUBLIC")
    if b == "" {
        host := header(req, "host")
        if host == "" { host = "127.0.0.1:8799" }
        b = "http://" + host
    }
}

// ---- daemon ---------------------------------------------------------------

// POST /v1/publish?owner=&artifact=&id=&title=&format=  — raw HTML in the body.
// Address by owner/artifact (legible, stable): id = "<owner>/<slug(artifact)>". Re-publishing
// the same owner+artifact appends the next version. Falls back to a random id if neither given.
func h_publish(req) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"this hart requires a token — hart login <token> (the operator set HART_TOKEN)\"}") }
    raw_owner := query(req, "owner")
    raw_artifact := query(req, "artifact")
    owner := slugify(raw_owner)
    artifact := slugify(raw_artifact)
    if reject_bad_slug(raw_owner) == 1 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_owner_json()) }
    if reject_bad_slug(raw_artifact) == 1 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_artifact_json()) }
    id := query(req, "id")
    if id == "" && owner != "" && artifact != "" { id = owner + "/" + artifact }
    if id != "" && valid_id(id) == 0 { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"invalid id — use owner/artifact (lowercase alnum and hyphens)\"}") }
    if query(req, "unguessable") == "1" && id != "" { id = id + "-" + substr(to_hex(rand_bytes(3)), 0, 5) }
    title := query(req, "title")
    format := query(req, "format")
    if format == "" { format = "html" }
    vis := query(req, "visibility")
    if vis != "public" && vis != "private" { vis = "unlisted" }
    rkh := ""
    rk := query(req, "read_key")
    if rk != "" { rkh = to_hex(sha256_bytes(bytes(rk))) }
    body := req.body
    if body == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"empty body\"}") }
    // abuse limits: per-IP submit rate + per-owner storage quota (both customizable);
    // past the rate limit an X-Peage-Wallet header buys the call (peage_overage)
    if rate_ok(db, hart_client_ip(req)) == 0 {
        pok, pres := peage_overage(req, "publish overage")
        if pok == 0 { sqlite_close(db); return pres }
    }
    cap := max_owner_bytes()   // effective (0 = unlimited); free tier is clamped, Pro raises it
    if cap > 0 && owner_bytes(db, owner) + len(body) > cap {
        hint := ""
        if licensed("limits") == 0 { hint = " — raise the limit with hart Pro: run `hart upgrade`" }
        sqlite_close(db)
        return response("413 Payload Too Large", "application/json", "{\"ok\":false,\"error\":\"storage quota exceeded for owner '" + owner + "': max " + str(cap / 1048576) + " MB total" + hint + "\",\"limit_mb\":" + str(cap / 1048576) + ",\"pro\":" + str(licensed("limits")) + "}")
    }
    // publish-time safety lint (see lint()); hard violations block unless ?force=1
    report := lint(body)
    if query(req, "dry") == "1" {
        sqlite_close(db)
        blk := "false"
        if lint_blocks(report) == 1 { blk = "true" }
        return ok_json("{\"ok\":true,\"dry_run\":true,\"would_block\":" + blk + ",\"bytes\":" + str(len(body)) + ",\"lint\":" + report + "}")
    }
    if lint_blocks(report) == 1 && query(req, "force") != "1" {
        sqlite_close(db)
        return response("422 Unprocessable Entity", "application/json", "{\"ok\":false,\"error\":\"content-security violations — self-contained pages only; inline assets or pass --force\",\"lint\":" + report + "}")
    }
    if owner_authorized(db, owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + owner + "' is claimed — pass the owner key (--owner-key / HART_OWNER_KEY)\"}") }
    n := now()
    ver := 1
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if id != "" && len(ars) > 0 {
        // next version = highest ever + 1 (NOT latest+1 — rollback can move latest backward)
        mrows := sqlite_query(db, "SELECT COALESCE(MAX(version),0) AS m FROM versions WHERE artifact_id = ?", []string{id})
        mraw, _ := json_get(mrows, "[0].m")
        ver = parse_int(mraw) + 1
        sqlite_exec(db, "UPDATE artifacts SET latest = ?, title = COALESCE(NULLIF(?,''), title), updated = ? WHERE id = ?", []string{str(ver), title, str(n), id})
        // visibility/read-key only change if explicitly provided (re-publish keeps them otherwise)
        if query(req, "visibility") != "" { sqlite_exec(db, "UPDATE artifacts SET visibility = ? WHERE id = ?", []string{vis, id}) }
        if rk != "" { sqlite_exec(db, "UPDATE artifacts SET read_key_hash = ? WHERE id = ?", []string{rkh, id}) }
        if query(req, "fresh") != "" { sqlite_exec(db, "UPDATE artifacts SET fresh_ttl = ? WHERE id = ?", []string{str(parse_int(query(req, "fresh"))), id}) }
        if query(req, "live") != "" { lv := 0  if query(req, "live") == "1" { lv = 1 }  sqlite_exec(db, "UPDATE artifacts SET live = ? WHERE id = ?", []string{str(lv), id}) }
        vis = ars[0].visibility
        if query(req, "visibility") != "" { vis = query(req, "visibility") }
    } else {
        if id == "" { id = nid() }
        livep := 0
        if query(req, "live") == "1" { livep = 1 }
        sqlite_exec(db, "INSERT INTO artifacts(id, owner, name, title, latest, visibility, read_key_hash, created, updated, fresh_ttl, live) VALUES(?,?,?,?,?,?,?,?,?,?,?)", []string{id, owner, artifact, title, str(ver), vis, rkh, str(n), str(n), str(parse_int(query(req, "fresh"))), str(livep)})
    }
    hash := to_hex(sha256_bytes(bytes(body)))
    sqlite_exec(db, "INSERT INTO versions(artifact_id, version, title, format, html, hash, created) VALUES(?,?,?,?,?,?,?)", []string{id, str(ver), title, format, body, hash, str(n)})
    audit(db, "publish", owner, id, ver, format, req)
    sqlite_close(db)
    base := pubbase(req)
    out := "{\"ok\":true,\"id\":\"" + id + "\",\"owner\":\"" + owner + "\",\"artifact\":\"" + artifact + "\",\"version\":" + str(ver) + ",\"format\":\"" + format + "\",\"visibility\":\"" + vis + "\",\"url\":\"" + base + "/a/" + id + "\",\"latest_url\":\"" + base + "/a/" + id + "/latest\",\"pinned_url\":\"" + base + "/a/" + id + "/v" + str(ver) + "\",\"lint\":" + report + "}"
    res = ok_json(out)
}

// POST /v1/data?owner=&artifact=&id=  — JSON body = the artifact's live data. Updates the data
// slot (a mutable pointer, not a version) so an agent can refresh an artifact's content without
// re-pushing the template. The template reads it via window.HART_DATA and/or {{key}}.
func h_data(req) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    if rate_ok(db, hart_client_ip(req)) == 0 {
        pok, pres := peage_overage(req, "data overage")
        if pok == 0 { sqlite_close(db); return pres }
    }
    raw_owner := query(req, "owner")
    raw_artifact := query(req, "artifact")
    owner := slugify(raw_owner)
    artifact := slugify(raw_artifact)
    if reject_bad_slug(raw_owner) == 1 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_owner_json()) }
    if reject_bad_slug(raw_artifact) == 1 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_artifact_json()) }
    id := query(req, "id")
    if id == "" && owner != "" && artifact != "" { id = owner + "/" + artifact }
    if id == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need --id or --owner+--artifact\"}") }
    if valid_id(id) == 0 { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"invalid id\"}") }
    body := req.body
    if body == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"empty data body\"}") }
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"no such artifact — publish the template first\"}") }
    if owner_authorized(db, ars[0].owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + ars[0].owner + "' is claimed — pass the owner key\"}") }
    sqlite_exec(db, "UPDATE artifacts SET data = ?, updated = ?, data_updated = ? WHERE id = ?", []string{body, str(now()), str(now()), id})
    audit(db, "data", ars[0].owner, id, 0, "", req)
    sqlite_close(db)
    base := pubbase(req)
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"data_bytes\":" + str(len(body)) + ",\"url\":\"" + base + "/a/" + id + "\"}")
}

func h_list(req) (res) {
    db := opendb()
    raw_owner := query(req, "owner")
    owner := slugify(raw_owner)
    if reject_bad_slug(raw_owner) == 1 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_owner_json()) }
    if owner != "" {
        // owner-scoped list: gated by the instance publish token, as before.
        if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
        rows := sqlite_query(db, "SELECT id, owner, name, title, latest, updated FROM artifacts WHERE owner = ? ORDER BY updated DESC LIMIT 500", []string{owner})
        sqlite_close(db)
        return ok_json("{\"ok\":true,\"artifacts\":" + rows + "}")
    }
    // Cross-owner enumeration. On a multi-tenant instance (operator set HART_ADMIN_TOKEN) this is
    // admin-only — closes the old leak where any HART_TOKEN holder could dump every owner. On a
    // single-user/trusted instance (no admin token) it falls back to the publish-token gate.
    if env("HART_ADMIN_TOKEN") != "" {
        if check_admin(req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"cross-owner list is admin-only on this instance — use `hart admin list` with HART_ADMIN_TOKEN\"}") }
    } else {
        if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    }
    rows := sqlite_query(db, "SELECT id, owner, name, title, latest, updated FROM artifacts ORDER BY updated DESC LIMIT 500", []string{})
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"artifacts\":" + rows + "}")
}

// GET /v1/admin/owners  — admin-only. Every owner namespace on the instance with artifact count,
// total stored bytes (all versions), whether it holds an owner-key, and last-updated. Keys are
// stored hashed, so we surface booleans, never the secret.
func h_admin_owners(req) (res) {
    if check_admin(req) == 0 { return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"admin token required — set HART_ADMIN_TOKEN on the daemon and send it (hart admin login <token>)\"}") }
    db := opendb()
    rows := sqlite_query(db, "SELECT a.owner AS owner, COUNT(DISTINCT a.id) AS cnt, MAX(a.updated) AS updated, COALESCE(SUM(LENGTH(v.html)),0) AS bytes, CASE WHEN o.key_hash IS NOT NULL AND o.key_hash != '' THEN 1 ELSE 0 END AS has_key FROM artifacts a LEFT JOIN versions v ON v.artifact_id = a.id LEFT JOIN owners o ON o.owner = a.owner GROUP BY a.owner ORDER BY bytes DESC", []string{})
    sqlite_close(db)
    os := parse(rows, []AdmOwn{})
    out := "{\"ok\":true,\"owners\":["
    i := 0
    for i < len(os) {
        o := os[i]
        if i > 0 { out = out + "," }
        hk := "false"
        if o.has_key == 1 { hk = "true" }
        out = out + "{\"owner\":\"" + o.owner + "\",\"artifacts\":" + str(o.cnt) + ",\"bytes\":" + str(o.bytes) + ",\"has_owner_key\":" + hk + ",\"updated\":" + str(o.updated) + "}"
        i = i + 1
    }
    out = out + "]}"
    res = ok_json(out)
}

// GET /v1/admin/list[?owner=]  — admin-only. Every artifact (optionally one owner), each with its
// dialable URL, visibility, and has_read_key. Read-keys are hashed, so has_read_key is a boolean —
// to get into a private artifact, reset its key via `hart visibility <id> private --read-key <new>`.
func h_admin_list(req) (res) {
    if check_admin(req) == 0 { return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"admin token required — set HART_ADMIN_TOKEN on the daemon and send it (hart admin login <token>)\"}") }
    db := opendb()
    raw_owner := query(req, "owner")
    owner := slugify(raw_owner)
    if reject_bad_slug(raw_owner) == 1 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_owner_json()) }
    rows := ""
    if owner != "" {
        rows = sqlite_query(db, "SELECT a.id AS id, a.owner AS owner, a.name AS name, a.title AS title, a.latest AS latest, a.visibility AS visibility, a.read_key_hash AS read_key_hash, a.updated AS updated, COALESCE(vw.total,0) AS views, a.fresh_ttl AS fresh_ttl FROM artifacts a LEFT JOIN views vw ON vw.artifact_id = a.id WHERE a.owner = ? ORDER BY a.updated DESC LIMIT 1000", []string{owner})
    } else {
        rows = sqlite_query(db, "SELECT a.id AS id, a.owner AS owner, a.name AS name, a.title AS title, a.latest AS latest, a.visibility AS visibility, a.read_key_hash AS read_key_hash, a.updated AS updated, COALESCE(vw.total,0) AS views, a.fresh_ttl AS fresh_ttl FROM artifacts a LEFT JOIN views vw ON vw.artifact_id = a.id ORDER BY a.updated DESC LIMIT 1000", []string{})
    }
    sqlite_close(db)
    arts := parse(rows, []AdmArt{})
    base := pubbase(req)
    n := now()
    out := "{\"ok\":true,\"artifacts\":["
    i := 0
    for i < len(arts) {
        ar := arts[i]
        if i > 0 { out = out + "," }
        hrk := "false"
        if ar.read_key_hash != "" { hrk = "true" }
        stale := "false"
        if ar.fresh_ttl > 0 && (n - ar.updated) > ar.fresh_ttl { stale = "true" }
        out = out + "{\"id\":\"" + ar.id + "\",\"owner\":\"" + ar.owner + "\",\"name\":\"" + ar.name + "\",\"title\":\"" + jesc(ar.title) + "\",\"version\":" + str(ar.latest) + ",\"visibility\":\"" + ar.visibility + "\",\"has_read_key\":" + hrk + ",\"views\":" + str(ar.views) + ",\"fresh_ttl\":" + str(ar.fresh_ttl) + ",\"stale\":" + stale + ",\"updated\":" + str(ar.updated) + ",\"url\":\"" + base + "/a/" + ar.id + "\"}"
        i = i + 1
    }
    out = out + "]}"
    res = ok_json(out)
}

// POST /v1/admin/mv?from=<id>&to=<owner>/<name>  — admin-only. Rename/move an artifact and ALL its
// versions to a new owner+name, preserving version history, visibility, live data, and read-key
// (nothing is re-uploaded). `to` is slugified into owner/name the same way publish addresses ids.
// Source must exist; target id must be free. The old URL 404s after the move.
func h_admin_mv(req) (res) {
    if check_admin(req) == 0 { return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"admin token required — set HART_ADMIN_TOKEN on the daemon and send it (hart admin login <token>)\"}") }
    from := query(req, "from")
    to := query(req, "to")
    if from == "" || to == "" { return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need from and to (to = <owner>/<name>)\"}") }
    if valid_id(from) == 0 { return response("400 Bad Request", "application/json", invalid_id_json()) }
    si := index(to, "/")
    if si <= 0 { return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"to must be <owner>/<name>\"}") }
    nowner := slugify(substr(to, 0, si))
    nname := slugify(substr(to, si + 1, len(to)))
    if nowner == "" || nname == "" { return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"to must be <owner>/<name> (both non-empty after slugify)\"}") }
    nnid := nowner + "/" + nname
    if valid_id(nnid) == 0 { return response("400 Bad Request", "application/json", invalid_id_json()) }
    db := opendb()
    src := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{from})
    ss := parse(src, []ArtRow{})
    if len(ss) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"no such artifact: " + from + "\"}") }
    if nnid == from { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"target is identical to source: " + from + "\"}") }
    dst := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{nnid})
    ds := parse(dst, []ArtRow{})
    if len(ds) > 0 { sqlite_close(db); return response("409 Conflict", "application/json", "{\"ok\":false,\"error\":\"target already exists: " + nnid + " (pick another name or rm it first)\"}") }
    // atomic across both tables — id is the FK from versions.artifact_id. `updated` is left as-is
    // so a move doesn't masquerade as a content edit in recency-ordered listings.
    sqlite_exec(db, "BEGIN", []string{})
    sqlite_exec(db, "UPDATE artifacts SET id = ?, owner = ?, name = ? WHERE id = ?", []string{nnid, nowner, nname, from})
    sqlite_exec(db, "UPDATE versions SET artifact_id = ? WHERE artifact_id = ?", []string{nnid, from})
    sqlite_exec(db, "UPDATE refresh SET artifact_id = ? WHERE artifact_id = ?", []string{nnid, from})   // self-refresh source follows the move
    sqlite_exec(db, "COMMIT", []string{})
    audit(db, "admin-mv", nowner, nnid, 0, "from " + from, req)
    sqlite_close(db)
    base := pubbase(req)
    res = ok_json("{\"ok\":true,\"moved\":{\"from\":\"" + from + "\",\"to\":\"" + nnid + "\"},\"owner\":\"" + nowner + "\",\"name\":\"" + nname + "\",\"version\":" + str(ss[0].latest) + ",\"url\":\"" + base + "/a/" + nnid + "\"}")
}

// GET /v1/admin/digest?days=N  — admin-only adoption digest: new owners/artifacts over the window,
// what's active, all-time totals, top artifacts by views, and the recent publishes. Powers the CLI
// (`hart admin digest`) and the /_fleet "activity" strip. Default window 7 days.
func h_admin_digest(req) (res) {
    if check_admin(req) == 0 { return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"admin token required — set HART_ADMIN_TOKEN\"}") }
    db := opendb()
    days := parse_int(query(req, "days"))
    if days <= 0 { days = 7 }
    cut := now() - days * 86400
    cs := str(cut)
    new_art := dash_count(db, "SELECT COUNT(*) AS n FROM artifacts WHERE created > " + cs)
    active := dash_count(db, "SELECT COUNT(*) AS n FROM artifacts WHERE updated > " + cs)
    new_own := dash_count(db, "SELECT COUNT(*) AS n FROM (SELECT owner FROM artifacts WHERE owner != '' GROUP BY owner HAVING MIN(created) > " + cs + ")")
    tot_art := dash_count(db, "SELECT COUNT(*) AS n FROM artifacts")
    tot_own := dash_count(db, "SELECT COUNT(DISTINCT owner) AS n FROM artifacts WHERE owner != ''")
    tot_views := dash_count(db, "SELECT COALESCE(SUM(total),0) AS n FROM views")
    toprows := sqlite_query(db, "SELECT a.id AS id, a.owner AS owner, COALESCE(v.total,0) AS views FROM artifacts a LEFT JOIN views v ON v.artifact_id = a.id ORDER BY views DESC, a.updated DESC LIMIT 5", []string{})
    tops := parse(toprows, []TopRow{})
    recrows := sqlite_query(db, "SELECT id, owner, created FROM artifacts WHERE created > " + cs + " ORDER BY created DESC LIMIT 10", []string{})
    recs := parse(recrows, []RecRow{})
    sqlite_close(db)
    tj := "["
    i := 0
    for i < len(tops) {
        if i > 0 { tj = tj + "," }
        tj = tj + "{\"id\":\"" + tops[i].id + "\",\"owner\":\"" + tops[i].owner + "\",\"views\":" + str(tops[i].views) + "}"
        i = i + 1
    }
    tj = tj + "]"
    rj := "["
    j := 0
    for j < len(recs) {
        if j > 0 { rj = rj + "," }
        rj = rj + "{\"id\":\"" + recs[j].id + "\",\"owner\":\"" + recs[j].owner + "\",\"created\":" + str(recs[j].created) + "}"
        j = j + 1
    }
    rj = rj + "]"
    out := "{\"ok\":true,\"days\":" + str(days) + ",\"since\":" + cs + ",\"new_owners\":" + str(new_own) + ",\"new_artifacts\":" + str(new_art) + ",\"active_artifacts\":" + str(active) + ",\"totals\":{\"artifacts\":" + str(tot_art) + ",\"owners\":" + str(tot_own) + ",\"views\":" + str(tot_views) + "},\"top_artifacts\":" + tj + ",\"recent\":" + rj + "}"
    res = ok_json(out)
}

// POST /v1/feedback — open (rate-limited, size-capped) feedback submission. Same payload shape as
// the central relay: {kind,message,context,id,reporter,version}. Idempotent on client id.
func h_feedback(req) (res) {
    body := req.body
    if len(body) > 16384 { return response("413 Payload Too Large", "application/json", "{\"ok\":false,\"error\":\"feedback too large\"}") }
    msg := trim(json_field(body, ".message", ""))
    if msg == "" { return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"message is required\"}") }
    db := opendb()
    if rate_ok(db, hart_client_ip(req)) == 0 { sqlite_close(db); return response("429 Too Many Requests", "application/json", "{\"ok\":false,\"error\":\"rate limit\"}") }
    id := json_field(body, ".id", "")
    if id == "" { id = nid() }
    kind := json_field(body, ".kind", "")
    ctx := json_field(body, ".context", "")
    rep := json_field(body, ".reporter", "")
    ver := json_field(body, ".version", "")
    sqlite_exec(db, "INSERT OR IGNORE INTO feedback(id, kind, message, context, reporter, version, created, ip) VALUES(?,?,?,?,?,?,?,?)", []string{id, kind, msg, ctx, rep, ver, str(now()), hart_client_ip(req)})
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"id\":\"" + jesc(id) + "\",\"stored\":true}")
}

// stats_authorized — READ gate for an artifact's stats: no side effects (unlike owner_authorized,
// which claims an unclaimed owner). Open for an unclaimed/keyless owner; else needs the owner-key.
func stats_authorized(db, owner, req) (ok) {
    if owner == "" { return 1 }
    rows := sqlite_query(db, "SELECT owner, key_hash, created FROM owners WHERE owner = ?", []string{owner})
    os := parse(rows, []OwnerRow{})
    if len(os) == 0 { return 1 }
    if os[0].key_hash == "" { return 1 }
    k := header(req, "x-hart-owner-key")
    if k != "" { if to_hex(sha256_bytes(bytes(k))) == os[0].key_hash { return 1 } }
    ok = 0
}

// GET /v1/artifacts/<id>/stats — living-deliverable analytics: total views, last view, freshness
// (last publish + last data push), and top inbound referrers. Gated to the owner (owner-key) or an
// admin; open for an unclaimed owner. View counts are server-side (CSP blocks client beacons).
func h_stats(db, req, id) (res) {
    arows := sqlite_query(db, "SELECT id, owner, latest, visibility, updated, data_updated, fresh_ttl FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []StatArt{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    if check_admin(req) == 0 && stats_authorized(db, ars[0].owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + ars[0].owner + "' is claimed — pass the owner key (--owner-key / HART_OWNER_KEY) or the admin token\"}") }
    vrows := sqlite_query(db, "SELECT total, last_view FROM views WHERE artifact_id = ?", []string{id})
    vs := parse(vrows, []StatRow{})
    total := 0
    last_view := 0
    if len(vs) > 0 { total = vs[0].total; last_view = vs[0].last_view }
    rrows := sqlite_query(db, "SELECT host, count FROM view_referers WHERE artifact_id = ? ORDER BY count DESC LIMIT 10", []string{id})
    rfs := parse(rrows, []RefRow{})
    sqlite_close(db)
    refs := "["
    i := 0
    for i < len(rfs) {
        if i > 0 { refs = refs + "," }
        refs = refs + "{\"host\":\"" + jesc(rfs[i].host) + "\",\"count\":" + str(rfs[i].count) + "}"
        i = i + 1
    }
    refs = refs + "]"
    stale := "false"
    if ars[0].fresh_ttl > 0 && (now() - ars[0].updated) > ars[0].fresh_ttl { stale = "true" }
    out := "{\"ok\":true,\"id\":\"" + id + "\",\"owner\":\"" + ars[0].owner + "\",\"version\":" + str(ars[0].latest) + ",\"visibility\":\"" + ars[0].visibility + "\",\"views\":" + str(total) + ",\"last_view\":" + str(last_view) + ",\"updated\":" + str(ars[0].updated) + ",\"data_updated\":" + str(ars[0].data_updated) + ",\"fresh_ttl\":" + str(ars[0].fresh_ttl) + ",\"stale\":" + stale + ",\"referrers\":" + refs + "}"
    res = ok_json(out)
}

// POST /v1/fresh?id=&ttl=  — set an artifact's freshness SLA (seconds; 0 clears it). Owner-key
// protected like other mutations. A monitored living deliverable (ttl>0) shows up in `hart stale`
// once (now - updated) exceeds ttl.
func h_fresh(req) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    id := query(req, "id")
    if id == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need --id\"}") }
    if valid_id(id) == 0 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_id_json()) }
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    if owner_authorized(db, ars[0].owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + ars[0].owner + "' is claimed — pass the owner key\"}") }
    ttl := parse_int(query(req, "ttl"))
    if ttl < 0 { ttl = 0 }
    sqlite_exec(db, "UPDATE artifacts SET fresh_ttl = ? WHERE id = ?", []string{str(ttl), id})
    audit(db, "fresh", ars[0].owner, id, ttl, "", req)
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"fresh_ttl\":" + str(ttl) + "}")
}

// GET /v1/stale?owner=&older_than=  — the staleness signal: living deliverables that went quiet.
// Without older_than: flag artifacts past their own SLA (fresh_ttl>0 && age>fresh_ttl). With
// older_than=<seconds>: an ad-hoc scan of everything older than that. Cross-owner is admin-only;
// owner-scoped is open (unclaimed) or owner-key gated. hart emits the signal; the agent alerts.
func h_stale(req) (res) {
    db := opendb()
    raw_owner := query(req, "owner")
    owner := slugify(raw_owner)
    if reject_bad_slug(raw_owner) == 1 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_owner_json()) }
    ot := parse_int(query(req, "older_than"))
    if ot < 0 { ot = 0 }
    if owner == "" {
        if check_admin(req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"cross-owner stale is admin-only — pass --owner, or set HART_ADMIN_TOKEN\"}") }
    } else {
        if check_admin(req) == 0 && stats_authorized(db, owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + owner + "' is claimed — pass the owner key or the admin token\"}") }
    }
    n := now()
    ns := str(n)
    rows := ""
    mode := "sla"
    // ns and ot are trusted integers (now() and parse_int) — inlined as literals so SQLite does
    // numeric arithmetic/comparison (a string param would compare as TEXT, which sorts above any
    // number and silently matches nothing). owner stays a bound param (user input).
    if ot > 0 {
        mode = "older_than"
        if owner != "" {
            rows = sqlite_query(db, "SELECT id, owner, updated, data_updated, fresh_ttl FROM artifacts WHERE owner = ? AND (" + ns + " - updated) > " + str(ot) + " ORDER BY updated ASC LIMIT 500", []string{owner})
        } else {
            rows = sqlite_query(db, "SELECT id, owner, updated, data_updated, fresh_ttl FROM artifacts WHERE (" + ns + " - updated) > " + str(ot) + " ORDER BY updated ASC LIMIT 500", []string{})
        }
    } else {
        if owner != "" {
            rows = sqlite_query(db, "SELECT id, owner, updated, data_updated, fresh_ttl FROM artifacts WHERE owner = ? AND fresh_ttl > 0 AND (" + ns + " - updated) > fresh_ttl ORDER BY updated ASC LIMIT 500", []string{owner})
        } else {
            rows = sqlite_query(db, "SELECT id, owner, updated, data_updated, fresh_ttl FROM artifacts WHERE fresh_ttl > 0 AND (" + ns + " - updated) > fresh_ttl ORDER BY updated ASC LIMIT 500", []string{})
        }
    }
    sqlite_close(db)
    sr := parse(rows, []StaleRow{})
    base := pubbase(req)
    out := "{\"ok\":true,\"now\":" + ns + ",\"mode\":\"" + mode + "\",\"count\":" + str(len(sr)) + ",\"stale\":["
    i := 0
    for i < len(sr) {
        if i > 0 { out = out + "," }
        age := n - sr[i].updated
        out = out + "{\"id\":\"" + sr[i].id + "\",\"owner\":\"" + sr[i].owner + "\",\"updated\":" + str(sr[i].updated) + ",\"data_updated\":" + str(sr[i].data_updated) + ",\"fresh_ttl\":" + str(sr[i].fresh_ttl) + ",\"age_seconds\":" + str(age) + ",\"age\":\"" + human_dur(age) + "\",\"url\":\"" + base + "/a/" + sr[i].id + "\"}"
        i = i + 1
    }
    out = out + "]}"
    res = ok_json(out)
}

func h_versions(db, req, id) (res) {
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    orows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    oa := parse(orows, []ArtRow{})
    if len(oa) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    rows := sqlite_query(db, "SELECT version, format, created FROM versions WHERE artifact_id = ? ORDER BY version DESC", []string{id})
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"owner\":\"" + oa[0].owner + "\",\"name\":\"" + oa[0].name + "\",\"versions\":" + rows + "}")
}

// h_delete — remove an artifact + all versions.
func h_delete(req, id) (res) {
    if valid_id(id) == 0 { return response("400 Bad Request", "application/json", invalid_id_json()) }
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    orows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    oa := parse(orows, []ArtRow{})
    if len(oa) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    if owner_authorized(db, oa[0].owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + oa[0].owner + "' is claimed — pass the owner key\"}") }
    sqlite_exec(db, "DELETE FROM versions WHERE artifact_id = ?", []string{id})
    sqlite_exec(db, "DELETE FROM refresh WHERE artifact_id = ?", []string{id})   // no orphan self-refresh source
    audit(db, "rm", oa[0].owner, id, 0, "", req)
    sqlite_exec(db, "DELETE FROM artifacts WHERE id = ?", []string{id})
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"deleted\":\"" + id + "\"}")
}

// h_rollback — re-point `latest` at an existing older version. Non-destructive: versions stay
// immutable; publishing afterwards still appends MAX+1.
func h_rollback(req, id, target) (res) {
    if valid_id(id) == 0 { return response("400 Bad Request", "application/json", invalid_id_json()) }
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    orows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    oa := parse(orows, []ArtRow{})
    if len(oa) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    if owner_authorized(db, oa[0].owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + oa[0].owner + "' is claimed — pass the owner key\"}") }
    vrows := sqlite_query(db, "SELECT version, format, created FROM versions WHERE artifact_id = ? AND version = ?", []string{id, str(target)})
    vs := parse(vrows, []VerRow{})
    if len(vs) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"no such version — see hart versions <id>\"}") }
    sqlite_exec(db, "UPDATE artifacts SET latest = ?, updated = ? WHERE id = ?", []string{str(target), str(now()), id})
    audit(db, "rollback", oa[0].owner, id, target, "", req)
    sqlite_close(db)
    base := pubbase(req)
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"latest\":" + str(target) + ",\"url\":\"" + base + "/a/" + id + "\"}")
}

// ---- the publish contract linter ------------------------------------------
// hart hosts SELF-CONTAINED pages. lint() flags anything that reaches off-page: external
// script/style/img/font, @import, and network calls. Hard violations (external <script src>,
// fetch/XHR/WebSocket) block publish unless forced; soft ones (external img/font) warn.
// Returns a JSON array of {level,rule,note}. Cheap substring scan on a lowercased copy.
func lint_find(lc, needle, level, rule, note, acc) (out, blocked) {
    out = acc
    blocked = 0
    if index(lc, needle) >= 0 {
        if acc != "[" { out = acc + "," }
        out = out + "{\"level\":\"" + level + "\",\"rule\":\"" + rule + "\",\"note\":\"" + note + "\"}"
        if level == "error" { blocked = 1 }
    }
}

func lint(html) (report) {
    lc := to_lower(html)
    r := "["
    b := 0
    r2, b2 := lint_find(lc, "<script src=\"http", "error", "external-script", "external <script src> — inline the JS", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "<script src='http", "error", "external-script", "external <script src> — inline the JS", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "fetch(", "error", "network-fetch", "fetch() call — artifacts are offline; connect-src is 'none'", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "xmlhttprequest", "error", "network-xhr", "XMLHttpRequest — no network in the sandbox", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "new websocket", "error", "network-ws", "WebSocket — no network in the sandbox", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "rel=\"stylesheet\" href=\"http", "warn", "external-css", "external stylesheet — inline the CSS", r)
    r = r2
    r2, b2 = lint_find(lc, "@import url(http", "warn", "external-import", "@import from a URL — inline the CSS", r)
    r = r2
    r2, b2 = lint_find(lc, "src=\"http", "warn", "external-asset", "external asset src — embed as a data: URI", r)
    r = r2
    report = r + "]"
}

func lint_blocks(report) (n) {
    n = 0
    if index(report, "\"level\":\"error\"") >= 0 { n = 1 }
}

// apply_template — replace {{key}} placeholders in the HTML with top-level values from the
// artifact's data JSON. Bounded loop; unknown keys become empty.
func apply_template(html, data) (out) {
    out = html
    if data == "" { return out }
    guard := 0
    for guard < 500 {
        st := index(out, "{{")
        if st < 0 { return out }
        rel := index(substr(out, st, len(out)), "}}")
        if rel < 0 { return out }
        en := st + rel
        key := trim(substr(out, st + 2, en))
        rep := ""
        val, err := json_get(data, "." + key)
        if err == "" { rep = unq(val) }
        out = substr(out, 0, st) + rep + substr(out, en + 2, len(out))
        guard = guard + 1
    }
}

// data_script — inject the live data as a JS global so templates (charts, JSX, anything) read
// window.HART_DATA. Empty data -> {}.
func data_script(data) (s) {
    d := data
    if d == "" { d = "{}" }
    s = "<script>window.HART_DATA=" + d + ";</script>"
}

// inject_live — append the live-repaint poller (D2 slice 2). hart owns this fetch (not the
// author, so it isn't caught by the fetch() linter): it polls the artifact's own data.json,
// refreshes window.HART_DATA, and fires a `hart:data` CustomEvent. A live template paints from
// window.HART_DATA on load and repaints on that event. Interval overridable via window.HART_LIVE_MS.
func inject_live(page, id, ms) (out) {
    js := "<script>(function(){var U='/a/" + jesc(id) + "/data.json',M=(window.HART_LIVE_MS||" + str(ms) + ");function t(){fetch(U,{cache:'no-store'}).then(function(r){return r.ok?r.json():null}).then(function(d){if(d==null)return;window.HART_DATA=d;window.dispatchEvent(new CustomEvent('hart:data',{detail:d}))}).catch(function(){})}setInterval(t,M)})();</script>"
    out = replace(page, "</body></html>", js + "</body></html>")
}

// GET /a/<id>/data.json — the artifact's current live data as JSON, same read-gating as the page
// (private needs the unlock cookie/header, which the same-origin poll sends automatically). This
// is what a live artifact polls to repaint. Not view-counted (polling would inflate views).
func h_artifact_data(req, id) (res) {
    if valid_id(id) == 0 { return response("400 Bad Request", "application/json; charset=utf-8", invalid_id_json()) }
    db := opendb()
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "application/json; charset=utf-8", "{\"ok\":false,\"error\":\"not found\"}") }
    if read_authorized(db, id, ars[0].read_key_hash, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json; charset=utf-8", "{\"ok\":false,\"error\":\"protected — unlock the artifact first\"}") }
    d := ars[0].data
    sqlite_close(db)
    if d == "" { d = "{}" }
    r := response("200 OK", "application/json; charset=utf-8", d)
    r = with_header(r, "Cache-Control", "no-store")
    r = with_header(r, "X-Content-Type-Options", "nosniff")
    res = r
}

// wrap stored content in a minimal doctype skeleton (the content itself carries inline
// <title>/<style>/<script>, artifact-style) and serve under the strict CSP. Data is applied
// two ways: {{key}} substitution in the markup + a window.HART_DATA global for scripts.
func render_page(html, title, data) (page) {
    t := title
    if t == "" { t = "hart artifact" }
    b := apply_template(html, data)
    page = "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>" + t + "</title>" + data_script(data) + "</head><body>" + b + "</body></html>"
}

// JSX: load the same-origin React + Babel runtime, then transform the agent's JSX with the
// CLASSIC runtime (emits React.createElement — no `import` of jsx-runtime, which would fail
// outside a module) and eval it. React/ReactDOM are globals; the agent renders into #root.
func render_page_jsx(jsx, title, data) (page) {
    t := title
    if t == "" { t = "hart artifact" }
    src := replace(jsx, "</script>", "<\\/script>")   // don't let the source close its host tag
    head := "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>" + t + "</title>" + data_script(data)
    rt := "<script src=\"/_hart/runtime/react.js\"></script><script src=\"/_hart/runtime/react-dom.js\"></script><script src=\"/_hart/runtime/babel.js\"></script></head>"
    boot := "<script>(function(){try{var s=document.getElementById('__hart_jsx').textContent;var o=Babel.transform(s,{presets:[['react',{runtime:'classic'}]]}).code;(0,eval)(o);}catch(e){document.getElementById('root').innerHTML='<pre style=\"color:#b00020;padding:24px;font:14px ui-monospace,monospace;white-space:pre-wrap\">hart: JSX error\\n\\n'+((e&&e.message)?e.message:e)+'</pre>';}})();</script>"
    body := "<body><div id=\"root\"></div><script type=\"text/plain\" id=\"__hart_jsx\">\n" + src + "\n</script>" + boot + "</body></html>"
    page = head + rt + body
}

// serve a same-origin runtime asset (react/react-dom/babel) from disk. Path-safe (no traversal).
func serve_runtime(fname) (res) {
    if index(fname, "..") >= 0 || index(fname, "/") >= 0 { return response("400 Bad Request", "text/plain", "bad path") }
    body := read_file(runtime_dir() + "/" + fname)
    if body == "" { return response("404 Not Found", "text/plain; charset=utf-8", "runtime asset not found — deploy the hart runtime dir") }
    r := response("200 OK", "application/javascript; charset=utf-8", body)
    r = with_header(r, "Cache-Control", "public, max-age=31536000, immutable")
    res = r
}

func serve_artifact(db, req, id, ver) (res) {
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "text/plain; charset=utf-8", "artifact not found") }
    // private (gated) read: valid header or unlock cookie, else the unlock page
    if read_authorized(db, id, ars[0].read_key_hash, req) == 0 { r := unlock_page(id, ""); sqlite_close(db); return r }
    record_view(db, id, req)   // authorized render -> count it (server-side; CSP blocks client beacons)
    v := ver
    if v == 0 { v = ars[0].latest }
    data := ars[0].data
    gated := 0
    if ars[0].read_key_hash != "" { gated = 1 }
    // live flag + poll cadence (D2 slice 2), read while the db is still open
    lrows := sqlite_query(db, "SELECT live FROM artifacts WHERE id = ?", []string{id})
    lraw, _ := json_get(lrows, "[0].live")
    live := parse_int(lraw)
    poll_ms := 15000
    if live == 1 {
        erows := sqlite_query(db, "SELECT every FROM refresh WHERE artifact_id = ? AND enabled = 1", []string{id})
        eraw, eerr := json_get(erows, "[0].every")
        if eerr == "" { ev := parse_int(eraw)  if ev > 0 { poll_ms = ev * 1000 } }
    }
    hrows := sqlite_query(db, "SELECT html, format, title FROM versions WHERE artifact_id = ? AND version = ?", []string{id, str(v)})
    sqlite_close(db)
    hs := parse(hrows, []HtmlRow{})
    if len(hs) == 0 { return response("404 Not Found", "text/plain; charset=utf-8", "version not found") }
    page := render_page(hs[0].html, hs[0].title, data)
    ct := csp()
    if hs[0].format == "jsx" { page = render_page_jsx(hs[0].html, hs[0].title, data); ct = csp_jsx() }
    // live (D2 slice 2): relax CSP to connect-src 'self' and inject the self-polling repainter.
    if live == 1 {
        ct = csp_live()
        if hs[0].format == "jsx" { ct = csp_jsx_live() }
        page = inject_live(page, id, poll_ms)
    }
    r := ok_html(page)
    r = with_header(r, "Content-Security-Policy", ct)
    r = with_header(r, "X-Content-Type-Options", "nosniff")
    r = with_header(r, "X-Frame-Options", "SAMEORIGIN")
    r = with_header(r, "Referrer-Policy", "no-referrer")
    if gated == 1 { r = with_header(r, "Cache-Control", "no-store") }
    res = r
}

// the unlock page — a password form for a private artifact. Posts to /a/<id>/unlock.
func unlock_page(id, errmsg) (res) {
    em := ""
    if errmsg != "" { em = "<p class=\"e\">" + errmsg + "</p>" }
    body := "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Protected · hart</title>"
    body = body + "<style>body{margin:0;background:#0e1216;color:#e8edf2;font:15px system-ui;min-height:100vh;display:grid;place-items:center}.b{width:min(90vw,360px);text-align:center}.lock{font-size:34px}h1{font-size:19px;font-weight:600;margin:14px 0 4px}p{color:#8b97a4;font-size:13px;margin:0 0 20px}form{display:flex;gap:8px}input{flex:1;background:#151b21;border:1px solid #232c34;border-radius:8px;padding:11px 13px;color:#e8edf2;font:14px system-ui}input:focus{outline:2px solid #0e6e6e;border-color:transparent}button{background:#3ad0c4;color:#062023;border:0;border-radius:8px;padding:11px 18px;font:600 14px system-ui;cursor:pointer}.e{color:#e0a355;font:12px ui-monospace,monospace;margin-top:12px}</style></head>"
    body = body + "<body><div class=\"b\"><div class=\"lock\">🔒</div><h1>This artifact is protected</h1><p>Enter the read password to view it.</p>"
    body = body + "<form method=\"POST\" action=\"/a/" + id + "/unlock\"><input type=\"password\" name=\"key\" placeholder=\"password\" autofocus autocomplete=\"current-password\"><button type=\"submit\">Unlock</button></form>" + em + "</div></body></html>"
    r := response("401 Unauthorized", "text/html; charset=utf-8", body)
    r = with_header(r, "Content-Security-Policy", "default-src 'none'; style-src 'unsafe-inline'; form-action 'self'")
    r = with_header(r, "Cache-Control", "no-store")
    res = r
}

// unlock_success_page — shown after correct password entry. Displays the curl snippet
// for agents/operators (blurred by default) with copy + toggle-blur buttons, plus a
// link to view the artifact (cookie is already set).
func unlock_success_page(id, key, req) (res) {
    base := pubbase(req)
    curl := "curl -s -H 'X-Hart-Read-Key: " + key + "' " + base + "/a/" + id
    esc_curl := html_escape(curl)
    body := "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Unlocked · hart</title>"
    body = body + "<style>"
    body = body + "body{margin:0;background:#0e1216;color:#e8edf2;font:15px system-ui;min-height:100vh;display:grid;place-items:center}"
    body = body + ".b{width:min(90vw,520px);text-align:center}"
    body = body + ".ok{font-size:34px}h1{font-size:19px;font-weight:600;margin:14px 0 4px}"
    body = body + "p{color:#8b97a4;font-size:13px;margin:0 0 20px}"
    body = body + ".snip{background:#151b21;border:1px solid #232c34;border-radius:10px;padding:16px;margin:16px 0;text-align:left;position:relative}"
    body = body + ".snip label{display:block;font:11px ui-monospace,monospace;color:#5c6773;margin-bottom:8px;letter-spacing:.05em;text-transform:uppercase}"
    body = body + "pre{margin:0;font:13px ui-monospace,monospace;color:#3ad0c4;white-space:pre-wrap;word-break:break-all;transition:filter .15s}"
    body = body + "pre.blurred{filter:blur(7px);user-select:none}"
    body = body + ".btns{display:flex;gap:8px;justify-content:center;margin-top:14px}"
    body = body + "button,.view{background:#3ad0c4;color:#062023;border:0;border-radius:8px;padding:10px 16px;font:600 13px system-ui;cursor:pointer;text-decoration:none;display:inline-block}"
    body = body + "button.ghost{background:transparent;color:#8b97a4;border:1px solid #232c34}"
    body = body + "button.ghost:hover{border-color:#3ad0c4;color:#3ad0c4}"
    body = body + ".copied{color:#22c55e;font:12px system-ui;margin-top:8px;opacity:0;transition:opacity .2s}"
    body = body + ".copied.show{opacity:1}"
    body = body + "</style></head>"
    body = body + "<body><div class=\"b\"><div class=\"ok\">🔓</div><h1>Unlocked</h1><p>Share this snippet with an agent or operator to fetch the artifact programmatically.</p>"
    body = body + "<div class=\"snip\"><label>Agent curl command</label>"
    body = body + "<pre id=\"curl\" class=\"blurred\">" + esc_curl + "</pre>"
    body = body + "<div class=\"btns\">"
    body = body + "<button class=\"ghost\" onclick=\"var e=document.getElementById('curl');e.classList.toggle('blurred');this.textContent=e.classList.contains('blurred')?'Show':'Hide'\">Show</button>"
    body = body + "<button onclick=\"var t=document.getElementById('curl').textContent;navigator.clipboard.writeText(t);var c=document.getElementById('copied');c.classList.add('show');setTimeout(function(){c.classList.remove('show')},1500)\">Copy</button>"
    body = body + "</div>"
    body = body + "<div class=\"copied\" id=\"copied\">Copied to clipboard</div>"
    body = body + "</div>"
    body = body + "<div class=\"btns\"><a class=\"view\" href=\"/a/" + id + "\">View artifact →</a></div>"
    body = body + "</div></body></html>"
    r := response("200 OK", "text/html; charset=utf-8", body)
    r = with_header(r, "Content-Security-Policy", "default-src 'none'; style-src 'unsafe-inline'; script-src 'unsafe-inline'")
    r = with_header(r, "Cache-Control", "no-store")
    res = r
}

// POST /a/<id>/unlock  (form: key) — verify the read password, set a signed cookie,
// then show the success page with the blurred agent curl snippet (instead of a bare
// redirect). The cookie lets the "View artifact" link work without re-entering the password.
func h_unlock(req, id) (res) {
    if valid_id(id) == 0 { return response("400 Bad Request", "text/plain", "bad id") }
    db := opendb()
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "text/plain", "not found") }
    kh := ars[0].read_key_hash
    key := query_form(req, "key")
    if kh == "" || to_hex(sha256_bytes(bytes(key))) != kh {
        r := unlock_page(id, "Wrong password.")
        sqlite_close(db)
        return r
    }
    sec := cookie_secret()
    sqlite_close(db)
    r := unlock_success_page(id, key, req)
    r = set_session(r, sec, read_cookie_name(id), kh)
    res = r
}

// query_form — read a value from an application/x-www-form-urlencoded body.
func query_form(req, name) (v) {
    v = ""
    parts := split(req.body, "&")
    i := 0
    for i < len(parts) {
        kv := split(parts[i], "=")
        if len(kv) >= 2 { if url_decode(kv[0]) == name { v = url_decode(kv[1]) } }
        i = i + 1
    }
}

// is_version_seg — a trailing path segment that pins a version: "latest" or "v<digits>".
func is_version_seg(seg) (yes) {
    yes = 0
    if seg == "latest" { return 1 }
    if len(seg) >= 2 { if substr(seg, 0, 1) == "v" {
        rest := substr(seg, 1, len(seg))
        alld := 1
        i := 0
        for i < len(rest) { c := substr(rest, i, i + 1); if c < "0" || c > "9" { alld = 0 } i = i + 1 }
        yes = alld
    } }
}

// parse /a/<id>, /a/<owner>/<artifact>, plus an optional trailing /latest or /v<n>.
// The id is everything before a trailing version segment (so owner/artifact ids keep their slash).
func handle_artifact(req, p) (res) {
    rest := substr(p, 3, len(p))   // strip "/a/"
    if rest == "" { return response("404 Not Found", "text/plain", "no id") }
    parts := split(rest, "/")
    ver := 0
    idcount := len(parts)
    last := parts[len(parts) - 1]
    if len(parts) > 1 && is_version_seg(last) == 1 {
        if last != "latest" { ver = parse_int(substr(last, 1, len(last))) }
        idcount = len(parts) - 1
    }
    id := ""
    i := 0
    for i < idcount { if id != "" { id = id + "/" } id = id + parts[i] i = i + 1 }
    if id == "" { return response("404 Not Found", "text/plain", "no id") }
    if valid_id(id) == 0 { return response("400 Bad Request", "text/plain", "bad id") }
    db := opendb()
    res = serve_artifact(db, req, id, ver)
}

// POST /v1/visibility?id=&visibility=&read_key=  — change an artifact's visibility/read-key
// without a new version. Owner-key protected (like other mutations).
func h_visibility(req) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    id := query(req, "id")
    if id == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need --id\"}") }
    if valid_id(id) == 0 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_id_json()) }
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    if owner_authorized(db, ars[0].owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + ars[0].owner + "' is claimed — pass the owner key\"}") }
    vis := query(req, "visibility")
    if vis != "" {
        if vis != "public" && vis != "private" && vis != "unlisted" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"visibility must be unlisted|public|private\"}") }
        sqlite_exec(db, "UPDATE artifacts SET visibility = ? WHERE id = ?", []string{vis, id})
    }
    rk := query(req, "read_key")
    if rk != "" { sqlite_exec(db, "UPDATE artifacts SET read_key_hash = ? WHERE id = ?", []string{to_hex(sha256_bytes(bytes(rk))), id}) }
    if query(req, "clear_read_key") == "1" { sqlite_exec(db, "UPDATE artifacts SET read_key_hash = '' WHERE id = ?", []string{id}) }
    audit(db, "visibility", ars[0].owner, id, 0, vis, req)
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"visibility\":\"" + vis + "\"}")
}

// GET /v1/public?owner=&q=  — the discovery feed: PUBLIC artifacts only, recency-ranked.
// Powers /explore (global) and /o/<owner> (per-owner). JSON for agents.
func public_rows(db, owner, q) (rows) {
    like := "%" + q + "%"
    if owner != "" {
        rows = sqlite_query(db, "SELECT id, owner, name, title, visibility, updated FROM artifacts WHERE visibility = 'public' AND owner = ? AND (title LIKE ? OR name LIKE ?) ORDER BY updated DESC LIMIT 200", []string{owner, like, like})
    } else {
        rows = sqlite_query(db, "SELECT id, owner, name, title, visibility, updated FROM artifacts WHERE visibility = 'public' AND (title LIKE ? OR name LIKE ? OR owner LIKE ?) ORDER BY updated DESC LIMIT 200", []string{like, like, like})
    }
}

func h_public(req) (res) {
    db := opendb()
    raw_owner := query(req, "owner")
    owner := slugify(raw_owner)
    if reject_bad_slug(raw_owner) == 1 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_owner_json()) }
    rows := public_rows(db, owner, query(req, "q"))
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"artifacts\":" + rows + "}")
}

// gallery_html — the server-rendered listing page shared by /explore and /o/<owner>.
func gallery_html(db, owner, q) (page) {
    rows := public_rows(db, owner, q)
    items := parse(rows, []ListRow{})
    heading := "Explore"
    sub := "Public artifacts on this hart instance."
    if owner != "" { heading = owner; sub = "Public artifacts by " + owner + "." }
    cards := ""
    i := 0
    for i < len(items) {
        it := items[i]
        t := it.title
        if t == "" { t = it.name }
        cards = cards + "<a class=\"card\" href=\"/a/" + it.id + "\"><div class=\"ct\">" + t + "</div><div class=\"cm\">" + it.owner + " / " + it.name + "</div></a>"
        i = i + 1
    }
    if len(items) == 0 { cards = "<p class=\"empty\">Nothing public yet. Publish with <code>--visibility public</code>.</p>" }
    page = "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>" + heading + " · hart</title>"
    page = page + "<style>body{margin:0;background:#0e1216;color:#e8edf2;font:15px system-ui}.w{max-width:820px;margin:0 auto;padding:56px 24px 80px}a{color:#3ad0c4;text-decoration:none}.eyebrow{font:12px ui-monospace,monospace;letter-spacing:.2em;text-transform:uppercase;color:#3ad0c4;margin:0 0 12px}h1{font-size:32px;letter-spacing:-.02em;margin:0 0 6px}.sub{color:#8b97a4;margin:0 0 26px}form{margin:0 0 26px}input{width:100%;max-width:360px;background:#151b21;border:1px solid #232c34;border-radius:8px;padding:11px 14px;color:#e8edf2;font:14px system-ui}.grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.card{display:block;background:#151b21;border:1px solid #232c34;border-radius:12px;padding:18px 20px}.card:hover{border-color:#2f5c58}.ct{font-weight:600;color:#e8edf2;letter-spacing:-.01em}.cm{font:12px ui-monospace,monospace;color:#5c6773;margin-top:5px}.empty{color:#8b97a4}code{font:.9em ui-monospace,monospace;background:#1b232a;border:1px solid #232c34;border-radius:4px;padding:1px 6px}.home{font:12px ui-monospace,monospace;color:#5c6773}@media(max-width:600px){.grid{grid-template-columns:1fr}}</style></head>"
    page = page + "<body><div class=\"w\"><a class=\"home\" href=\"/\">← hart</a><p class=\"eyebrow\" style=\"margin-top:18px\">" + sub + "</p><h1>" + heading + "</h1>"
    page = page + "<form method=\"GET\"><input type=\"search\" name=\"q\" value=\"" + esc_attr(q) + "\" placeholder=\"Search public artifacts…\"></form>"
    page = page + "<div class=\"grid\">" + cards + "</div></div></body></html>"
}

func esc_attr(s) (o) {
    o = replace(s, "\"", "")
    o = replace(o, "<", "")
    o = replace(o, ">", "")
}

// html_escape — replace & < > " ' with HTML entities for safe inline display.
func html_escape(s) (o) {
    o = replace(s, "&", "&amp;")
    o = replace(o, "<", "&lt;")
    o = replace(o, ">", "&gt;")
    o = replace(o, "\"", "&quot;")
    o = replace(o, "'", "&#39;")
}

func serve_explore(req) (res) {
    if env("HART_EXPLORE") == "0" { return response("404 Not Found", "text/plain", "explore disabled") }
    db := opendb()
    page := gallery_html(db, "", query(req, "q"))
    sqlite_close(db)
    r := ok_html(page)
    r = with_header(r, "Content-Security-Policy", "default-src 'none'; style-src 'unsafe-inline'")
    res = r
}

func serve_owner(req, owner) (res) {
    if reject_bad_slug(owner) == 1 { return response("400 Bad Request", "text/plain", "invalid owner") }
    db := opendb()
    page := gallery_html(db, slugify(owner), query(req, "q"))
    sqlite_close(db)
    r := ok_html(page)
    r = with_header(r, "Content-Security-Policy", "default-src 'none'; style-src 'unsafe-inline'")
    res = r
}

// guide_md — the embedded operator/agent manual (version-exact). `base` = this instance's URL;
// `authline` describes whether publishing needs a token. Shared by `hart guide` and /guide.md.
func guide_md(base, authline) (g) {
    g = "# hart — agent guide\n\n"
    g = g + "The agent-first artifact host. Publish self-contained **HTML or JSX** and get a live, versioned, sandboxed URL. One static binary is BOTH the CLI (`hart <cmd>`) and the daemon (`hart serve`).\n\n"
    g = g + "This instance: `" + base + "` — " + authline + "\n\n"
    g = g + "## Use an existing instance (fastest)\n\n"
    g = g + "```sh\nexport HART_URL=" + base + "\n# publish a finished, self-contained page:\nhart publish page.html --owner you --artifact my-page\n# -> {\"url\":\"" + base + "/a/you/my-page\", ...}\n```\n\n"
    g = g + "No `hart` binary? Every write is just an HTTP POST — you can curl it:\n\n"
    g = g + "```sh\ncurl -X POST '" + base + "/v1/publish?owner=you&artifact=my-page' \\\n  -H 'content-type: text/html' --data-binary @page.html\n```\n\n"
    g = g + "## Self-host in 30s\n\n```sh\ngit clone https://github.com/javimosch/machin-hart && cd machin-hart\n./runtime/fetch.sh          # seed the JSX runtime (react/babel)\n./build.sh                  # needs `machin` on PATH -> ./hart\n./hart serve 8799 &         # free/open by default\n```\nGate publishing with `HART_TOKEN=<secret>`; expose publicly behind any reverse proxy and set `HART_PUBLIC=https://your.domain`.\n\n"
    g = g + "## The publish contract (important)\n\nhart hosts **self-contained** pages — inline ALL CSS/JS, embed images/fonts as `data:` URIs. The daemon wraps your body in a doctype skeleton and serves it under a strict CSP: **no external scripts/styles/fonts, no network** (`fetch`/XHR/WebSocket are blocked). A publish-time linter rejects external refs + network calls (HTTP 422) unless you pass `--force`. Use `--dry-run` to lint without storing.\n\n"
    g = g + "## Versioning\n\nRe-publishing the same `--owner/--artifact` appends a version; `latest` tracks newest, old versions are immutably pinned.\n- `" + base + "/a/<owner>/<artifact>` or `/latest` -> newest\n- `.../v<n>` -> a pinned version\n- `hart rollback <id> <v>` re-points latest (non-destructive)\n\n"
    g = g + "## Template + data (update without re-uploading)\n\nPublish a template once, then push just the data — it re-renders. Two mechanisms:\n- `{{key}}` placeholders in the markup\n- `window.HART_DATA` — a JS global your script/JSX reads\n\n```sh\nhart publish chart.html --owner you --artifact sales\nhart data you/sales '{\"points\":[3,1,4,1,5]}'   # re-renders, same URL\n```\n\n"
    g = g + "## Visibility\n\n- **unlisted** (default) — public read, not listed\n- **public** — public read + listed at `/explore` and `/o/<owner>` (`hart explore [q]`)\n- **private** — gated read: browsers get an unlock page (password -> signed cookie); agents send `X-Hart-Read-Key` (`HART_READ_KEY`).\n\nSet with `--visibility` / `--read-key` at publish, or `hart visibility <id> <mode>` later.\n\n"
    g = g + "## Ownership (write protection)\n\nOn a free instance, the first write to a new `--owner` claims it. Pass `--owner-key <secret>` (or `HART_OWNER_KEY`) to claim a namespace; then all writes to that owner require the key (else 403). Anonymous (no-owner) artifacts get a random id.\n\n"
    g = g + "## JSX\n\n`hart publish app.jsx --format jsx` — author React/JSX; the daemon serves a same-origin React+Babel runtime and transpiles in-browser. No build step, no CDN. `React`/`ReactDOM` are globals; render into `#root`.\n\n"
    g = g + "## Commands\n\n| cmd | does |\n|---|---|\n| `publish <file> [--owner --artifact --title --format html\\|jsx --visibility --read-key --unguessable --dry-run --force]` | upload -> {id,url,version} |\n| `data <id> '<json>'` | update the live data (re-renders) |\n| `visibility <id> <unlisted\\|public\\|private> [--read-key --clear-read-key]` | change visibility |\n| `versions <id>` / `rollback <id> <v>` | history / revert |\n| `list [--owner <who>]` / `get <id>` / `rm <id>` | manage |\n| `stats <id>` | living-deliverable analytics: views, last view, freshness, top referrers |\n| `feedback <msg> [--kind bug\\|idea\\|praise] [--context <c>]` | send feedback (dual-writes to this instance + a central relay) |\n| `fresh <id> <30s\\|15m\\|2h\\|1d\\|off>` | set/clear a freshness SLA |\n| `refresh <id> [--url <URL>\\|--cmd '<sh>'] --every <dur> [--header 'H: v']\\|--off\\|--now` | daemon self-refreshes the artifact's data on a schedule (living loop) |\n| `live <id> <on\\|off>` | allow the page to poll its own data.json and repaint live (opt-in CSP relax) |\n| `upgrade [--plan pro]` | mint a checkout link to buy hart Pro (give the URL to the human to pay) |\n| `license <key>` / `license status` | set / inspect the hart Pro license (unlocks pro features) |\n| `audit [--owner --action --since --limit]` | who changed what — the audit log (**hart Pro**) |\n| `team add\\|invite\\|list\\|rm <owner> [<email>]` | manage team members / per-member keys (**hart Pro**) |\n| `join <owner>` | SSO self-onboarding — sign in once, receive your member key (**hart Pro**) |\n| `stale [--owner <who>] [--older-than <dur>]` | living deliverables that went quiet (JSON signal) |\n| `explore [query]` | public discovery feed (JSON) |\n| `admin owners` / `admin list [--owner <who>]` | operator cross-owner visibility (needs `HART_ADMIN_TOKEN`) |\n| `serve [port]` | run the daemon |\n| `mcp` | run as a stdio MCP server (native tools for MCP agents) |\n| `guide` / `skill` | this manual / a drop-in agent SKILL.md |\n\n## MCP (native tools for MCP-capable agents)\n\nBesides the CLI, hart can run as a **stdio MCP server** so MCP-native agents (Claude Desktop, Cursor, …) get hart as first-class tools. One binary, no extra runtime — it wraps hart's own HTTP API and inherits auth from env. Configure your MCP client:\n\n```json\n{\"mcpServers\":{\"hart\":{\"command\":\"hart\",\"args\":[\"mcp\"],\"env\":{\"HART_URL\":\"" + base + "\"}}}}\n```\nTools exposed: `hart_publish`, `hart_data`, `hart_list`, `hart_get`, `hart_stats`, `hart_stale`, `hart_explore`. (The CLI remains the primary interface; MCP is an additional surface.)\n\n## Stats (living deliverables)\n\nView counts are **server-side** (the CSP blocks any client-side beacon), so they're privacy-respecting — no cookies, no JS, no third-party trackers. `hart stats <id>` returns total views, last-view time, freshness (last publish `updated` + last `hart data` push `data_updated`), and the top inbound referrer hosts.\n\n```sh\nhart stats you/sales\n# -> {\"views\":128,\"last_view\":..,\"updated\":..,\"data_updated\":..,\"referrers\":[{\"host\":\"news.ycombinator.com\",\"count\":41},{\"host\":\"direct\",\"count\":52}]}\n```\nGated to the owner (owner-key) or the admin token; open for an unclaimed owner. `hart admin list` also carries a `views` count per artifact.\n\n## Staleness (living deliverables that went quiet)\n\nSome artifacts are kept fresh by an agent/cron pushing `hart data` on a cadence. Give one a **freshness SLA** and hart will flag it once it hasn't been refreshed in time — so a silently-dead dashboard doesn't go unnoticed.\n\n```sh\nhart fresh you/board 15m        # SLA: expect a refresh at least every 15 min (off = clear)\nhart stale                      # artifacts past their own SLA (admin: all owners)\nhart stale --owner you          # scoped to one owner\nhart stale --older-than 2h      # ad-hoc: anything not touched in 2h (ignores SLAs)\n# -> {\"mode\":\"sla\",\"count\":1,\"stale\":[{\"id\":\"you/board\",\"age\":\"22m\",\"fresh_ttl\":900, ...}]}\n```\nhart emits the **signal** (JSON); your agent/cron does the alerting (Slack, etc.). `fresh_ttl` + a computed `stale` also appear in `hart stats` and `hart admin list`. Freshness = time since the last publish or `hart data` push (`updated`).\n\n## Living loop (self-refreshing deliverables)\n\n`hart data` and `hart fresh`/`hart stale` assume **something external** keeps pushing data. `hart refresh` closes the loop: the daemon runs a **source** on a schedule and pushes the result as the artifact's live data itself — no external cron. Pair it with `hart fresh` and the SLA stays green because hart is the one keeping it green.\n\n```sh\n# GET a JSON URL every 15 min and make it the artifact's data (url sources need the owner key)\nhart refresh you/board --url https://api.example.com/metrics --every 15m --header 'Authorization: Bearer XYZ'\n\n# or run a shell command (pipes/curl|jq ok) — arbitrary shell on the server, so ADMIN ONLY\nhart refresh you/board --cmd 'curl -s https://api.example.com/m | jq .summary' --every 15m\n\nhart refresh you/board            # show config + last run status\nhart refresh you/board --now      # run once, right now, inline\nhart refresh you/board --off      # stop refreshing\n```\nThe source's output must be a JSON object or array (it becomes `window.HART_DATA` + `{{key}}`); non-JSON or a failed fetch is recorded in `last_status` and the existing data is left untouched. Minimum interval 30s. `--url` sources need the owner key; `--cmd` sources require `HART_ADMIN_TOKEN` (they execute shell on your box). The daemon runs due sources every few seconds in-process — one binary, no scheduler to deploy.\n\n**Live repaint (no reload).** By default a refreshed page shows new data on the *next load*. Mark an artifact **live** and it repaints while someone's watching it: hart injects a small poller that fetches the artifact's own `" + base + "/a/<id>/data.json` and updates `window.HART_DATA`, then fires a `hart:data` event. Your template paints from `window.HART_DATA` on load and repaints on the event:\n\n```html\n<script>\n  function paint(d){ /* render d */ }\n  paint(window.HART_DATA);                               // initial\n  addEventListener('hart:data', e => paint(e.detail));   // live updates\n</script>\n```\n```sh\nhart publish board.html --owner you --artifact board --live   # publish as live\nhart live you/board on|off                                    # toggle anytime (setting a refresh source turns it on)\n```\nLive is **opt-in per artifact**: only a live page's CSP is relaxed to `connect-src 'self'` (so it can fetch *its own* data.json and nothing else) — every other artifact keeps the full `default-src 'none'` lockdown. The poll interval tracks the refresh cadence (override with `window.HART_LIVE_MS`). `data.json` uses the same read-gating as the page (a private artifact's poll rides its unlock cookie).\n\n## Admin (operator god-mode)\n\nOn an instance **you host**, set `HART_ADMIN_TOKEN` (separate from `HART_TOKEN`) on the daemon to unlock cross-owner discovery — for auditing all artifacts your agents/operators produced on your own box.\n\n```sh\nexport HART_ADMIN_TOKEN=<secret>   # or: hart admin login <secret>\nhart admin owners                  # every owner: {owner, artifacts, bytes, has_owner_key, updated}\nhart admin list [--owner <who>]    # every artifact: {id, owner, url, visibility, has_read_key, version, updated}\nhart admin digest [--days N]       # adoption: new owners/artifacts (default 7d), totals, top by views\nhart admin mv <old-id> <new-owner/new-name>   # move/rename, keeps version history + read-key\n```\n\n**Visual operator dashboard:** point a browser at `" + base + "/_fleet` and sign in with the admin token — every owner + artifact (incl. unlisted/private), view counts, and stale living-deliverables flagged, server-rendered. The JSON API above is for agents; `/_fleet` is for you.\n\n**`admin mv` examples** — reorganize owners without losing anything (history, visibility, live data, and read-key all move with the artifact; the old URL 404s):\n\n```sh\n# fold a per-agent owner into a shared namespace, prefixing to keep provenance\nhart admin mv am/fleet-monitor   intrane/am-fleet-monitor      # v36 stays v36\nhart admin mv crmd/product       intrane/crmd-product\n# regroup several owners under a new project namespace\nhart admin mv geored/e2e-retroplanning     simpliciti/geored-e2e-retroplanning\nhart admin mv sso-server/changelog-7d      simpliciti/sso-server-changelog-7d\n# a plain rename (same owner)\nhart admin mv acme/q3-draft      acme/q3-final\n```\n\nGuards: `404` if the source is missing, `409` if the target id already exists, `400` on a same-id or malformed `to` (must be `<owner>/<name>`).\n\nKeys/read-keys are stored **hashed**, so admin surfaces `has_owner_key`/`has_read_key` booleans, never the secret. `admin mv` renames an artifact and all its versions to a new owner/name in place — history, visibility, live data, and read-key are preserved (nothing is re-uploaded); the old URL 404s. Unset `HART_ADMIN_TOKEN` = the admin API is **off** (403), and cross-owner `hart list` is then admin-only on multi-tenant instances (owner-scoped `list --owner X` is unaffected).\n\n"
    g = g + "## Env\n\n`HART_URL` (daemon) · `HART_TOKEN` (publish token, if the instance requires one) · `HART_OWNER_KEY` (namespace write key) · `HART_READ_KEY` (read key for a private artifact) · `HART_ADMIN_TOKEN` (operator god-token for the admin API — cross-owner list; separate from `HART_TOKEN`, unset = admin off). Server: `HART_DB`, `HART_RUNTIME_DIR`, `HART_PUBLIC`, `HART_LANDING`, `HART_MAX_SUBMITS_PER_MIN` (10), `HART_MAX_OWNER_MB` (30 — the per-owner storage cap; raising it above `HART_FREE_MAX_OWNER_MB` requires a **hart Pro** license), `HART_FREE_MAX_OWNER_MB` (30 — the free-tier ceiling), `HART_EXPLORE=0`, `HART_COOKIE_SECRET`, `HART_LICENSE_KEY` (Pro key), `HART_LICENSE_PUBKEY` (run your own issuer). **Production hardening** (auto on when `HART_PUBLIC` is set): `HART_HARDEN=1` · `HART_TRUST_PROXY=1` (only behind a proxy you control) · `HART_MAX_BODY_BYTES` (default 10 MiB) · `HART_READ_TIMEOUT_MS` (default 30s) · `HART_ACCESS_LOG=1`; opt out locally with `HART_HARDEN=0`. **BYOK key map:** `" + base + "/byok.md` (also `docs/BYOK.md` in the repo).\n\n## hart Pro (self-host)\n\nhart is open-core: the CLI is fully functional and free, and a few features unlock with a **license key** (`hart license <key>`, or `HART_LICENSE_KEY` on the daemon; `hart license status` shows your tier). Keys are Ed25519-signed and verified offline (no phone-home). Pro today: **limits** (raise the per-owner storage quota), **audit-log** (`hart audit` — who changed what), **teams** (`hart team` — per-member keys). Enforcement is honest, not DRM — pay for support, updates, and to stay compliant.\n\n**Teams SSO (optional, your IdP).** `hart join <owner>` lets a member self-onboard via **any OpenID Connect provider you configure** — you bring the IdP, hart is a standard OIDC client. Set `HART_OIDC_ISSUER` (e.g. your Auth0/Okta/Keycloak/Google/machin-idp), `HART_OIDC_CLIENT_ID`, `HART_OIDC_CLIENT_SECRET` (register `<your-hart>/team/callback` as the redirect URI at your IdP); optional `HART_OIDC_SCOPES` (default `openid email`). hart discovers the endpoints, runs the code flow, and reads the member's email from `userinfo`. Unset = SSO off (teams still work via `hart team add` member keys).\n\n**Buying is agent-first.** Run `hart upgrade` — it returns a checkout URL; give it to the human to pay. They're emailed a license key; then run `hart license <key>` (or set `HART_LICENSE_KEY`). Lost the key? `" + base + "/manage` re-emails it. Contact: javi@intrane.fr.\n\nSource + releases: https://github.com/javimosch/machin-hart\n"
}

// skill_md — a drop-in, self-installable agent SKILL.md (the machin-web-ui `skill` convention).
// Instance-aware and version-exact: `hart skill > ~/.claude/skills/hart/SKILL.md` and any terminal
// agent reflexively publishes its HTML deliverables here + can discover what it already shipped.
func skill_md(base, authline) (s) {
    s = "---\n"
    s = s + "name: hart\n"
    s = s + "description: Publish a self-contained HTML or JSX deliverable to a live, shareable, sandboxed URL — and discover artifacts you already published. Use whenever you generate an HTML report, dashboard, mockup, one-pager, or data explorer and the human needs a link (not a local file), or to list/find/update prior artifacts.\n"
    s = s + "---\n\n"
    s = s + "# hart — publish your HTML deliverables to a live URL\n\n"
    s = s + "You (an agent) generate rich HTML but have nowhere to put it: `open` dies at share-time, a gist mangles it. **hart** turns a self-contained file into a live, versioned, sandboxed URL in one call. This instance: `" + base + "` — " + authline + "\n\n"
    s = s + "## When to use\n\n- You produced an HTML/JSX deliverable and the human needs a **shareable link**.\n- The data behind a page you published **changed** — refresh it in place (same URL).\n- You need to **find or list** artifacts you (or your fleet) published before.\n\n"
    s = s + "## Setup (once)\n\n```sh\nexport HART_URL=" + base + "\n# if this instance requires a publish token: `hart login <token>` (or set HART_TOKEN)\n```\nNo `hart` binary on PATH? Every write is a plain HTTP POST — curl works (see the manual).\n\n"
    s = s + "## Publish — the core loop\n\n```sh\nhart publish deliverable.html --owner <you> --artifact <name>\n# -> {\"ok\":true,\"url\":\"" + base + "/a/<you>/<name>\",\"version\":1, ...}\n```\nParse `.url` from the JSON and hand it to the human. Re-publish the same `--owner/--artifact` to append a version (`latest` moves; old versions stay pinned; `hart rollback <id> <v>` reverts).\n\n"
    s = s + "## The contract (do this or publish is rejected)\n\nPages must be **self-contained**: inline ALL CSS/JS, embed images/fonts as `data:` URIs. Served under a strict CSP — **no external scripts/styles/fonts, no network** (`fetch`/XHR/WebSocket blocked). A linter rejects external refs (HTTP 422); `--dry-run` lints without storing, `--force` overrides. JSX: add `--format jsx` (in-browser React+Babel, no build step; render into `#root`).\n\n"
    s = s + "## Living deliverables — update data without re-uploading\n\nPublish a template once, then push just the data; the same URL re-renders. The page reads `{{key}}` placeholders and/or the `window.HART_DATA` global.\n\n```sh\nhart publish chart.html --owner <you> --artifact sales\nhart data <you>/sales '{\"points\":[3,1,4,1,5]}'   # same URL, fresh render\n```\nGreat for status boards / dashboards an agent keeps current on a cron. Check how a page is doing with `hart stats <you>/sales` — views, last view, freshness, top referrers (server-side, privacy-respecting). Give a monitored dashboard a freshness SLA (`hart fresh <you>/sales 15m`) and `hart stale` flags it if the updates ever stop — hart emits the signal, your cron alerts.\n\n"
    s = s + "## Discover what you published\n\n```sh\nhart list --owner <you>          # your artifacts (JSON: id, title, latest, updated)\nhart get <owner>/<artifact>      # one artifact's metadata + versions\nhart explore [query]             # public discovery feed across the instance\n```\nOperators of an instance they host can set `HART_ADMIN_TOKEN` and use `hart admin owners` / `hart admin list` to discover **every** owner's artifacts (cross-owner) — the fleet-wide view.\n\n"
    s = s + "## Visibility\n\n`--visibility unlisted` (default: public-read, unlisted) · `public` (listed at `/explore`) · `private` (password-gated; agents send `X-Hart-Read-Key` / `HART_READ_KEY`). Set at publish (`--visibility --read-key`) or later via `hart visibility <id> <mode>`.\n\n"
    s = s + "## Teams, SSO & Pro\n\nSome features need a **hart Pro** license — run `hart upgrade` for a checkout link (hand the URL to the human; they're emailed a key; then `hart license <key>`, or set `HART_LICENSE_KEY` on the daemon; `hart license status` shows your tier). Pro unlocks higher storage limits, `hart audit` (who changed what), and **teams**.\n\n**Teams** — share an `--owner` namespace with per-member keys: an admin runs `hart team invite <owner> <email>`; each member holds their own key (send it as `HART_MEMBER_KEY` or `--member-key`), and the audit log records who did what. Revoke with `hart team rm`.\n\n**SSO self-onboarding** — a member runs `hart join <owner>`, opens the returned link to sign in, and their agent receives the member key (no key hand-off). hart is a **generic OpenID Connect client**: to enable it, the operator sets on the daemon `HART_OIDC_ISSUER` (your IdP — Auth0/Okta/Keycloak/Google/machin-idp/…), `HART_OIDC_CLIENT_ID`, `HART_OIDC_CLIENT_SECRET` (optional `HART_OIDC_SCOPES`, default `openid email`), and registers `" + base + "/team/callback` as the redirect URI at that IdP. Unset = SSO off (teams still work via member keys).\n\n"
    s = s + "## Full manual\n\nRun `hart guide` or GET `" + base + "/guide.md` — every command, flag, and the admin API, version-exact. AI-first sitemap: `" + base + "/llms.txt`.\n"
}

// install_sh — a POSIX-sh installer served instance-aware at /install.sh, so
// `curl -fsSL <base>/install.sh | sh` drops the `hart` CLI on PATH already pointed at THIS
// instance (HART_URL baked to `base`). Pulls the binary from the repo's latest GitHub Release.
func install_sh(base) (s) {
    s = "#!/bin/sh\n"
    s = s + "# hart installer — drop the `hart` CLI on your PATH so any agent can publish HTML to a live URL.\n"
    s = s + "# Usage: curl -fsSL " + base + "/install.sh | sh      (override target dir with HART_INSTALL_DIR=)\n"
    s = s + "set -e\n"
    s = s + "REPO=javimosch/machin-hart\n"
    s = s + "HART_URL_DEFAULT=" + base + "\n"
    s = s + "DIR=\"${HART_INSTALL_DIR:-$HOME/.local/bin}\"\n"
    s = s + "os=$(uname -s); arch=$(uname -m)\n"
    s = s + "case \"$os/$arch\" in\n"
    s = s + "  Linux/x86_64) asset=hart-linux-x86_64 ;;\n"
    s = s + "  *) echo \"hart: no prebuilt binary for $os/$arch — build from source: https://github.com/$REPO\" >&2; exit 1 ;;\n"
    s = s + "esac\n"
    s = s + "url=\"https://github.com/$REPO/releases/latest/download/$asset\"\n"
    s = s + "mkdir -p \"$DIR\"\n"
    s = s + "echo \"hart: downloading $asset -> $DIR/hart\" >&2\n"
    s = s + "if command -v curl >/dev/null 2>&1; then curl -fsSL \"$url\" -o \"$DIR/hart\";\n"
    s = s + "elif command -v wget >/dev/null 2>&1; then wget -qO \"$DIR/hart\" \"$url\";\n"
    s = s + "else echo \"hart: need curl or wget\" >&2; exit 1; fi\n"
    s = s + "chmod +x \"$DIR/hart\"\n"
    s = s + "if \"$DIR/hart\" help >/dev/null 2>&1; then echo \"hart: installed -> $DIR/hart\" >&2; else echo \"hart: installed -> $DIR/hart (could not execute it — ensure libssl3 + libsqlite3 are present)\" >&2; fi\n"
    s = s + "case \":$PATH:\" in *\":$DIR:\"*) ;; *) echo \"hart: NOTE $DIR is not on your PATH — add it\" >&2 ;; esac\n"
    s = s + "echo \"\" >&2\n"
    s = s + "echo \"next:\" >&2\n"
    s = s + "echo \"  export HART_URL=$HART_URL_DEFAULT\" >&2\n"
    s = s + "echo \"  hart publish page.html --owner you --artifact my-page   # -> a live URL\" >&2\n"
    s = s + "echo \"  hart skill > ~/.claude/skills/hart/SKILL.md             # make agents publish here by default\" >&2\n"
    s = s + "echo \"  hart upgrade                                            # hart Pro: limits, audit, teams (+SSO: set HART_OIDC_ISSUER/CLIENT_ID/CLIENT_SECRET)\" >&2\n"
}

// llms_txt — the concise /llms.txt (the llms.txt convention): an at-a-glance orientation + links.
func llms_txt(base, authline) (t) {
    t = "# hart\n\n> The agent-first artifact host: publish self-contained HTML or JSX from any terminal agent and get a live, versioned, sandboxed URL. One static binary = CLI + daemon. Open-source, self-hostable.\n\n"
    t = t + "This instance: " + base + " (" + authline + ")\n\n"
    t = t + "## Use it now\n\n"
    t = t + "- Publish (curl, no binary needed): `curl -X POST '" + base + "/v1/publish?owner=you&artifact=name' -H 'content-type: text/html' --data-binary @page.html`\n"
    t = t + "- Or with the CLI: `HART_URL=" + base + " hart publish page.html --owner you --artifact name`\n"
    t = t + "- Result: a URL at `" + base + "/a/you/name` (versioned; re-publish to update).\n\n"
    t = t + "## Rules\n\n"
    t = t + "- Pages must be SELF-CONTAINED: inline all CSS/JS, `data:` URIs for assets. No external refs, no network (fetch/XHR blocked by CSP). External refs are rejected at publish (pass `--force` to override).\n"
    t = t + "- JSX: add `--format jsx` (transpiled in-browser, no build step).\n"
    t = t + "- Update without re-uploading: `hart data you/name '<json>'` -> the page reads `window.HART_DATA` and/or `{{key}}`.\n"
    t = t + "- Visibility: `--visibility unlisted|public|private` (private = read-gated via password / `X-Hart-Read-Key`).\n\n"
    t = t + "## Map (AI-first sitemap)\n\n"
    t = t + "- **" + base + "/guide.md** — the complete, version-exact manual (every command, flags, admin, examples). Start here. Also `hart guide`.\n"
    t = t + "- **" + base + "/byok.md** — BYOK key map (publish token, owner key, admin, Pro license, production hardening env). Also `docs/BYOK.md` in the repo.\n"
    t = t + "- " + base + "/skill.md — a drop-in agent SKILL.md (self-install: `hart skill > ~/.claude/skills/hart/SKILL.md`). Also `hart skill`.\n"
    t = t + "- " + base + "/install.sh — one-line CLI install: `curl -fsSL " + base + "/install.sh | sh` (drops `hart` on PATH, pre-pointed at this instance).\n"
    t = t + "- " + base + "/llms.txt — this file (30-second orientation).\n"
    t = t + "- " + base + "/explore — public discovery feed (HTML); `" + base + "/v1/public?q=` for JSON.\n"
    t = t + "- " + base + "/o/<owner> — an owner's public artifacts.\n"
    t = t + "- " + base + "/a/<owner>/<artifact>[/latest|/v<n>] — a published artifact.\n"
    t = t + "- " + base + "/_health — liveness JSON. " + base + "/_status — instance dashboard.\n"
    t = t + "- Source & self-host: https://github.com/javimosch/machin-hart\n"
}

func auth_line() (s) {
    s = "**free/open** — no token needed to publish"
    if env("HART_TOKEN") != "" { s = "publishing requires a token (operator-configured `HART_TOKEN`)" }
}

func serve_guide(req) (res) {
    r := response("200 OK", "text/markdown; charset=utf-8", guide_md(pubbase(req), auth_line()))
    r = with_header(r, "Content-Security-Policy", "default-src 'none'")
    res = r
}

func serve_llms(req) (res) {
    r := response("200 OK", "text/plain; charset=utf-8", llms_txt(pubbase(req), auth_line()))
    r = with_header(r, "Content-Security-Policy", "default-src 'none'")
    res = r
}

func serve_byok(req) (res) {
    body := read_file("docs/BYOK.md")
    if body == "" { body = "# hart — BYOK setup\n\nBring-your-own-key guide: https://github.com/javimosch/machin-hart/blob/master/docs/BYOK.md\n" }
    r := response("200 OK", "text/markdown; charset=utf-8", body)
    r = with_header(r, "Content-Security-Policy", "default-src 'none'")
    res = r
}

func serve_skill(req) (res) {
    r := response("200 OK", "text/markdown; charset=utf-8", skill_md(pubbase(req), auth_line()))
    r = with_header(r, "Content-Security-Policy", "default-src 'none'")
    res = r
}

func serve_install(req) (res) {
    r := response("200 OK", "text/x-shellscript; charset=utf-8", install_sh(pubbase(req)))
    r = with_header(r, "Content-Security-Policy", "default-src 'none'")
    res = r
}

// the root page — the product landing (OSS, self-hosted). Served from HART_LANDING (default
// ./landing.html); falls back to a one-line notice if the file isn't deployed.
func serve_landing() (res) {
    path := env("HART_LANDING")
    if path == "" { path = "landing.html" }
    body := read_file(path)
    if body == "" { body = "<!doctype html><meta charset=utf-8><title>hart</title><body style=\"font:16px system-ui;max-width:40em;margin:12vh auto;padding:0 6vw\"><h1>hart</h1><p>The agent-first artifact host. Source: github.com/javimosch/machin-hart</p>" }
    r := ok_html(body)
    r = with_header(r, "Content-Security-Policy", "default-src 'none'; style-src 'unsafe-inline'; img-src data:; font-src data:")
    res = r
}

func hart_route(req) (res) {
    p := req.path
    qi := index(p, "?")
    if qi >= 0 { p = substr(p, 0, qi) }
    if p == "/" { if env("HART_HOME") == "dashboard" { return serve_status(req) }  return serve_landing() }
    if p == "/llms.txt" { return serve_llms(req) }
    if p == "/guide.md" || p == "/guide" { return serve_guide(req) }
    if p == "/byok.md" || p == "/byok" { return serve_byok(req) }
    if p == "/skill.md" || p == "/skill" { return serve_skill(req) }
    if p == "/install.sh" { return serve_install(req) }
    if p == "/_health" { return ok_json("{\"ok\":true,\"service\":\"hart\"}") }
    if p == "/_status" || p == "/dashboard" { return serve_status(req) }
    if req.method == "POST" && p == "/_fleet/login" { return h_fleet_login(req) }
    if req.method == "GET" && p == "/_fleet/logout" { return h_fleet_logout(req) }
    if req.method == "GET" && p == "/_fleet" { return serve_fleet(req) }
    if req.method == "GET" && has_prefix(p, "/_hart/runtime/") { return serve_runtime(substr(p, 15, len(p))) }
    if req.method == "POST" && p == "/v1/publish" { return h_publish(req) }
    if req.method == "POST" && p == "/v1/data" { return h_data(req) }
    if req.method == "GET" && p == "/v1/artifacts" { return h_list(req) }
    if req.method == "GET" && p == "/v1/admin/owners" { return h_admin_owners(req) }
    if req.method == "GET" && p == "/v1/admin/list" { return h_admin_list(req) }
    if req.method == "POST" && p == "/v1/admin/mv" { return h_admin_mv(req) }
    if req.method == "GET" && p == "/v1/admin/digest" { return h_admin_digest(req) }
    if has_prefix(p, "/v1/artifacts/") {
        tail := substr(p, 14, len(p))   // the id (may contain "/") + optional /versions|/rollback
        id := tail
        if req.method == "GET" && has_suffix(tail, "/versions") {
            id = substr(tail, 0, len(tail) - 9)
        }
        if req.method == "GET" && has_suffix(tail, "/stats") {
            id = substr(tail, 0, len(tail) - 6)
        }
        if req.method == "POST" && has_suffix(tail, "/rollback") {
            id = substr(tail, 0, len(tail) - 9)
        }
        if valid_id(id) == 0 { return response("400 Bad Request", "application/json", invalid_id_json()) }
        if req.method == "GET" && has_suffix(tail, "/versions") {
            db := opendb(); return h_versions(db, req, id)
        }
        if req.method == "GET" && has_suffix(tail, "/stats") {
            db := opendb(); return h_stats(db, req, id)
        }
        if req.method == "POST" && has_suffix(tail, "/rollback") {
            return h_rollback(req, id, parse_int(query(req, "to")))
        }
        if req.method == "DELETE" { return h_delete(req, tail) }
        if req.method == "GET" { db := opendb(); return h_versions(db, req, tail) }
    }
    if req.method == "POST" && p == "/v1/visibility" { return h_visibility(req) }
    if req.method == "POST" && p == "/v1/feedback" { return h_feedback(req) }
    if req.method == "POST" && p == "/v1/fresh" { return h_fresh(req) }
    if req.method == "POST" && p == "/v1/refresh/run" { return h_refresh_run(req) }
    if req.method == "POST" && p == "/v1/refresh" { return h_refresh_set(req) }
    if req.method == "GET" && p == "/v1/refresh" { return h_refresh_get(req) }
    if req.method == "POST" && p == "/v1/live" { return h_live(req) }
    if req.method == "GET" && p == "/v1/license/status" { return h_license_status(req) }
    if req.method == "POST" && p == "/v1/license" { return h_license_set(req) }
    if req.method == "GET" && p == "/v1/audit" { return h_audit(req) }
    if req.method == "POST" && p == "/v1/team/rm" { return h_team_rm(req) }
    if req.method == "POST" && p == "/v1/team" { return h_team_add(req) }
    if req.method == "GET" && p == "/v1/team" { return h_team_list(req) }
    if req.method == "POST" && p == "/v1/join/start" { return h_join_start(req) }
    if req.method == "GET" && p == "/v1/join/poll" { return h_join_poll(req) }
    if req.method == "GET" && p == "/team/callback" { return h_team_callback(req) }
    if req.method == "GET" && p == "/v1/stale" { return h_stale(req) }
    if req.method == "GET" && p == "/v1/public" { return h_public(req) }
    if req.method == "GET" && p == "/explore" { return serve_explore(req) }
    if req.method == "GET" && has_prefix(p, "/o/") { return serve_owner(req, substr(p, 3, len(p))) }
    if req.method == "POST" && has_prefix(p, "/a/") && has_suffix(p, "/unlock") {
        rest := substr(p, 3, len(p) - 7)   // strip "/a/" and "/unlock"
        return h_unlock(req, rest)
    }
    if req.method == "GET" && has_prefix(p, "/a/") && has_suffix(p, "/data.json") { return h_artifact_data(req, substr(p, 3, len(p) - 10)) }
    if req.method == "GET" && has_prefix(p, "/a/") { return handle_artifact(req, p) }
    res = response("404 Not Found", "text/plain; charset=utf-8", "not found")
}

// POST /v1/refresh?id=&kind=&every=&header=&enabled=  body = the source (a URL, or a shell
// command for kind=cmd). Registers/updates a refresh source. url sources need the owner key;
// cmd sources (arbitrary shell on the server) require the admin token. enabled=0 just disables.
func h_refresh_set(req) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    id := query(req, "id")
    if id == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need ?id=\"}") }
    if valid_id(id) == 0 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_id_json()) }
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"no such artifact — publish the template first\"}") }
    if owner_authorized(db, ars[0].owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + ars[0].owner + "' is claimed — pass the owner key\"}") }
    if query(req, "enabled") == "0" {
        sqlite_exec(db, "UPDATE refresh SET enabled = 0 WHERE artifact_id = ?", []string{id})
        sqlite_close(db)
        return ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"enabled\":false}")
    }
    source := trim(req.body)
    if source == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"empty source (send the URL or command as the request body)\"}") }
    kind := query(req, "kind")
    if kind == "" { kind = "url" }
    if kind != "url" && kind != "cmd" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"kind must be url or cmd\"}") }
    if kind == "cmd" {
        if check_admin(req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"cmd sources run arbitrary shell on the server — admin only (set HART_ADMIN_TOKEN and pass it)\"}") }
    }
    every := parse_int(query(req, "every"))
    if every < 30 { every = 30 }
    header := query(req, "header")
    n := now()
    sqlite_exec(db, "INSERT OR REPLACE INTO refresh(artifact_id, kind, source, header, every, next, last, last_status, enabled) VALUES(?,?,?,?,?,?,0,'',1)", []string{id, kind, source, header, str(every), str(n)})
    sqlite_exec(db, "UPDATE artifacts SET live = 1 WHERE id = ?", []string{id})   // a refreshed page can poll its own data.json
    audit(db, "refresh", ars[0].owner, id, 0, kind, req)
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"kind\":\"" + kind + "\",\"every\":" + str(every) + ",\"live\":true,\"enabled\":true}")
}

// GET /v1/refresh?id=  — the refresh config + last run status for one artifact.
func h_refresh_get(req) (res) {
    db := opendb()
    id := query(req, "id")
    if id == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need ?id=\"}") }
    if valid_id(id) == 0 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_id_json()) }
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"no such artifact\"}") }
    if owner_authorized(db, ars[0].owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + ars[0].owner + "' is claimed — pass the owner key\"}") }
    rows := sqlite_query(db, "SELECT artifact_id, kind, source, header, every, next, last, last_status, enabled FROM refresh WHERE artifact_id = ?", []string{id})
    rl := parse(rows, []RefreshRow{})
    sqlite_close(db)
    if len(rl) == 0 { return ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"configured\":false}") }
    r := rl[0]
    en := "false"
    if r.enabled == 1 { en = "true" }
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"configured\":true,\"kind\":\"" + r.kind + "\",\"source\":\"" + jesc(r.source) + "\",\"every\":" + str(r.every) + ",\"enabled\":" + en + ",\"last\":" + str(r.last) + ",\"next\":" + str(r.next) + ",\"last_status\":\"" + jesc(r.last_status) + "\"}")
}

// POST /v1/refresh/run?id=  — run the source once, now, inline. cmd sources still need admin.
func h_refresh_run(req) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    id := query(req, "id")
    if id == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need ?id=\"}") }
    if valid_id(id) == 0 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_id_json()) }
    rows := sqlite_query(db, "SELECT artifact_id, kind, source, header, every, next, last, last_status, enabled FROM refresh WHERE artifact_id = ?", []string{id})
    rl := parse(rows, []RefreshRow{})
    if len(rl) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"no refresh source configured for this artifact\"}") }
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"no such artifact\"}") }
    if owner_authorized(db, ars[0].owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + ars[0].owner + "' is claimed — pass the owner key\"}") }
    if rl[0].kind == "cmd" {
        if check_admin(req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"running a cmd source is admin only\"}") }
    }
    do_refresh(db, rl[0])
    rows2 := sqlite_query(db, "SELECT artifact_id, kind, source, header, every, next, last, last_status, enabled FROM refresh WHERE artifact_id = ?", []string{id})
    rl2 := parse(rows2, []RefreshRow{})
    sqlite_close(db)
    st := ""
    if len(rl2) > 0 { st = rl2[0].last_status }
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"ran\":true,\"last_status\":\"" + jesc(st) + "\"}")
}

// POST /v1/license  body = the license key. Operator-only (admin token if configured, else the
// publish-token gate). Validates before storing. HART_LICENSE_KEY env is the other way to set it.
func h_license_set(req) (res) {
    db := opendb()
    if env("HART_ADMIN_TOKEN") != "" {
        if check_admin(req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"admin token required to set the license\"}") }
    } else {
        if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    }
    key := trim(req.body)
    if key == "" { key = query(req, "key") }
    if key == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"empty license key\"}") }
    valid, plan, features, exp := parse_license(key)
    sqlite_exec(db, "INSERT OR REPLACE INTO license(id, token, updated) VALUES(1, ?, ?)", []string{key, str(now())})
    audit(db, "license", "", "", 0, plan, req)
    sqlite_close(db)
    v := "false"
    if valid == 1 { v = "true" }
    res = ok_json("{\"ok\":true,\"stored\":true,\"valid\":" + v + ",\"plan\":\"" + jesc(plan) + "\",\"features\":" + features + ",\"exp\":" + str(exp) + "}")
}

// GET /v1/license/status — the active tier/plan/features/expiry (never echoes the raw key). Open read.
func h_license_status(req) (res) {
    tok := current_license()
    valid, plan, features, exp := parse_license(tok)
    src := "none"
    if env("HART_LICENSE_KEY") != "" { src = "env" } else { if tok != "" { src = "stored" } }
    v := "false"
    tier := "free"
    if valid == 1 { v = "true"  tier = plan }
    cap := max_owner_bytes()   // effective per-owner quota (0 = unlimited)
    unl := "false"
    if cap == 0 { unl = "true" }
    limits := "{\"owner_mb\":" + str(cap / 1048576) + ",\"free_ceiling_mb\":" + str(free_owner_mb()) + ",\"unlimited\":" + unl + "}"
    res = ok_json("{\"ok\":true,\"licensed\":" + v + ",\"tier\":\"" + jesc(tier) + "\",\"plan\":\"" + jesc(plan) + "\",\"features\":" + features + ",\"exp\":" + str(exp) + ",\"source\":\"" + src + "\",\"limits\":" + limits + "}")
}

// GET /v1/audit?owner=&action=&since=&limit=  — the pro audit log (who changed what). Operator-gated
// (admin token if configured, else the publish token) AND requires the audit-log license feature.
func h_audit(req) (res) {
    db := opendb()
    if env("HART_ADMIN_TOKEN") != "" {
        if check_admin(req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"admin token required\"}") }
    } else {
        if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    }
    if licensed_db(db, "audit-log") == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"the audit log is a hart Pro feature — hart license\",\"pro\":0}") }
    w := "1=1"
    params := []string{}
    raw_owner := query(req, "owner")
    owner := slugify(raw_owner)
    if reject_bad_slug(raw_owner) == 1 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_owner_json()) }
    if owner != "" { w = w + " AND owner = ?"  params = append(params, owner) }
    action := query(req, "action")
    if action != "" { w = w + " AND action = ?"  params = append(params, action) }
    since := parse_int(query(req, "since"))
    if since > 0 { w = w + " AND ts >= ?"  params = append(params, str(now() - since)) }
    limit := parse_int(query(req, "limit"))
    if limit <= 0 || limit > 1000 { limit = 200 }
    rows := sqlite_query(db, "SELECT id, ts, action, owner, artifact_id, version, actor, detail FROM audit WHERE " + w + " ORDER BY id DESC LIMIT " + str(limit), params)
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"audit\":" + rows + "}")
}

// POST /v1/team?owner=&email=&role=  — add a team member; returns a one-time member key. Managing a
// team needs the owner-key or admin (not a member key), and the teams pro feature.
func h_team_add(req) (res) {
    db := opendb()
    if licensed_db(db, "teams") == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"teams is a hart Pro feature — hart license\",\"pro\":0}") }
    owner := slugify(query(req, "owner"))
    email := query(req, "email")
    if owner == "" || email == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need ?owner= and ?email=\"}") }
    if owner_key_only(db, owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"managing team '" + owner + "' needs its owner-key (or admin); claim the owner first if unclaimed\"}") }
    role := query(req, "role")
    if role == "" { role = "writer" }
    // invite mode: add the member with NO key — they self-claim it via `hart join` (SSO). Lets an
    // admin build the roster without ever handling keys.
    if query(req, "invite") == "1" {
        sqlite_exec(db, "INSERT OR REPLACE INTO members(owner, email, key_hash, role, created) VALUES(?,?,'',?,?)", []string{owner, email, role, str(now())})
        audit(db, "team-invite", owner, "", 0, email, req)
        sqlite_close(db)
        return ok_json("{\"ok\":true,\"owner\":\"" + owner + "\",\"email\":\"" + jesc(email) + "\",\"role\":\"" + jesc(role) + "\",\"invited\":true,\"note\":\"the member claims a key with: hart join " + owner + "\"}")
    }
    mk := "mk_" + to_hex(rand_bytes(18))
    kh := to_hex(sha256_bytes(bytes(mk)))
    sqlite_exec(db, "INSERT OR REPLACE INTO members(owner, email, key_hash, role, created) VALUES(?,?,?,?,?)", []string{owner, email, kh, role, str(now())})
    audit(db, "team-add", owner, "", 0, email, req)
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"owner\":\"" + owner + "\",\"email\":\"" + jesc(email) + "\",\"role\":\"" + jesc(role) + "\",\"member_key\":\"" + mk + "\",\"note\":\"shown once — the member sends it as x-hart-member-key (or HART_MEMBER_KEY)\"}")
}

// GET /v1/team?owner=  — list members (emails + roles, never key hashes).
func h_team_list(req) (res) {
    db := opendb()
    if licensed_db(db, "teams") == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"teams is a hart Pro feature — hart license\",\"pro\":0}") }
    owner := slugify(query(req, "owner"))
    if owner_key_only(db, owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"managing team '" + owner + "' needs its owner-key (or admin)\"}") }
    rows := sqlite_query(db, "SELECT owner, email, role, created FROM members WHERE owner = ? ORDER BY created", []string{owner})
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"owner\":\"" + owner + "\",\"members\":" + rows + "}")
}

// POST /v1/team/rm?owner=&email=  — remove a member (revokes their key immediately).
func h_team_rm(req) (res) {
    db := opendb()
    if licensed_db(db, "teams") == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"teams is a hart Pro feature — hart license\",\"pro\":0}") }
    owner := slugify(query(req, "owner"))
    email := query(req, "email")
    if owner == "" || email == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need ?owner= and ?email=\"}") }
    if owner_key_only(db, owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"managing team '" + owner + "' needs its owner-key (or admin)\"}") }
    sqlite_exec(db, "DELETE FROM members WHERE owner = ? AND email = ?", []string{owner, email})
    audit(db, "team-rm", owner, "", 0, email, req)
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"owner\":\"" + owner + "\",\"removed\":\"" + jesc(email) + "\"}")
}

// ---- teams SSO: agent-first self-onboarding (`hart join`, teams Part 2) --------------------
// A member's agent runs `hart join <owner>`, gets a login_url to hand the human, and polls for the
// minted key. The only browser touch is portier's OAuth callback (the minimal page below). SSO
// authenticates; the members table authorizes (email must already be invited/added).
// Generic OIDC client config — the operator points hart at ANY conformant OpenID Connect issuer
// (their own IdP: Auth0/Okta/Keycloak/Google/machin-idp/…). We provide the wiring; they bring the IdP.
func oidc_issuer() (u) {
    u = env("HART_OIDC_ISSUER")
    if len(u) > 0 && substr(u, len(u) - 1, len(u)) == "/" { u = substr(u, 0, len(u) - 1) }
}
func oidc_scopes() (s) { s = env("HART_OIDC_SCOPES")  if s == "" { s = "openid email" } }
func sso_configured() (ok) {
    ok = 0
    if oidc_issuer() != "" && env("HART_OIDC_CLIENT_ID") != "" && env("HART_OIDC_CLIENT_SECRET") != "" { ok = 1 }
}

// oidc_endpoints — the issuer's authorize/token/userinfo, via OIDC discovery (cached per issuer).
func oidc_endpoints(db) (authz, tokenu, userinfo, ok) {
    ok = 0
    iss := oidc_issuer()
    if iss == "" { return }
    rows := sqlite_query(db, "SELECT authz, token, userinfo FROM oidc_meta WHERE issuer = ?", []string{iss})
    av, e := json_get(rows, "[0].authz")
    if e == "" {
        authz = unq(av)
        tv, _ := json_get(rows, "[0].token")
        tokenu = unq(tv)
        uv, _ := json_get(rows, "[0].userinfo")
        userinfo = unq(uv)
        ok = 1
        return
    }
    st, resp, err := http_request("GET", iss + "/.well-known/openid-configuration", []string{}, "")
    if err != "" || st != 200 { return }
    aev, _ := json_get(resp, ".authorization_endpoint")
    tev, _ := json_get(resp, ".token_endpoint")
    uev, _ := json_get(resp, ".userinfo_endpoint")
    authz = unq(aev)
    tokenu = unq(tev)
    userinfo = unq(uev)
    if authz == "" || tokenu == "" || userinfo == "" { return }
    sqlite_exec(db, "INSERT OR REPLACE INTO oidc_meta(issuer, authz, token, userinfo, fetched) VALUES(?,?,?,?,?)", []string{iss, authz, tokenu, userinfo, str(now())})
    ok = 1
}

func sso_page(msg, okflag) (res) {
    color := "#e0a355"
    if okflag == 1 { color = "#3ad0c4" }
    body := "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>hart teams sign-in</title><style>body{margin:0;background:#0e1216;color:#e8edf2;font:15px system-ui;min-height:100vh;display:grid;place-items:center}.b{max-width:440px;text-align:center;padding:24px}.i{font-size:34px}p{color:" + color + ";line-height:1.5}</style></head><body><div class=\"b\"><div class=\"i\">🔑</div><p>" + jesc(msg) + "</p></div></body></html>"
    res = response("200 OK", "text/html; charset=utf-8", body)
}

// POST /v1/join/start?owner= — begin onboarding; returns login_url (human opens) + token (CLI polls).
func h_join_start(req) (res) {
    db := opendb()
    if licensed_db(db, "teams") == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"teams is a hart Pro feature — hart license\",\"pro\":0}") }
    if sso_configured() == 0 { sqlite_close(db); return response("501 Not Implemented", "application/json", "{\"ok\":false,\"error\":\"SSO not configured on this instance (set HART_OIDC_ISSUER/CLIENT_ID/CLIENT_SECRET)\"}") }
    owner := slugify(query(req, "owner"))
    if owner == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need ?owner=\"}") }
    authz, _, _, dok := oidc_endpoints(db)
    if dok == 0 { sqlite_close(db); return response("502 Bad Gateway", "application/json", "{\"ok\":false,\"error\":\"OIDC discovery failed for " + jesc(oidc_issuer()) + "\"}") }
    token := to_hex(rand_bytes(18))
    sqlite_exec(db, "INSERT INTO joins(token, owner, status, created) VALUES(?,?,'pending',?)", []string{token, owner, str(now())})
    sqlite_close(db)
    login := authz + "?response_type=code&client_id=" + url_encode(env("HART_OIDC_CLIENT_ID")) + "&redirect_uri=" + url_encode(pubbase(req) + "/team/callback") + "&scope=" + url_encode(oidc_scopes()) + "&state=" + token
    res = ok_json("{\"ok\":true,\"owner\":\"" + owner + "\",\"token\":\"" + token + "\",\"login_url\":\"" + jesc(login) + "\"}")
}

// GET /v1/join/poll?token= — CLI polls; returns the minted key ONCE when done (row then deleted).
func h_join_poll(req) (res) {
    db := opendb()
    token := query(req, "token")
    if token == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need ?token=\"}") }
    rows := sqlite_query(db, "SELECT token, owner, status, email, member_key, created FROM joins WHERE token = ?", []string{token})
    js := parse(rows, []JoinRow{})
    if len(js) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"unknown or expired token\"}") }
    if js[0].status != "done" { sqlite_close(db); return ok_json("{\"ok\":true,\"status\":\"" + js[0].status + "\"}") }
    sqlite_exec(db, "DELETE FROM joins WHERE token = ?", []string{token})
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"status\":\"done\",\"email\":\"" + jesc(js[0].email) + "\",\"member_key\":\"" + jesc(js[0].member_key) + "\"}")
}

// GET /team/callback?code=&state= — portier redirect target. Exchange code -> email; the email must
// be a member of the join's owner; mint (rotate) their member key; resolve the join.
func h_team_callback(req) (res) {
    code := query(req, "code")
    state := query(req, "state")
    if code == "" || state == "" { return sso_page("Missing code or state.", 0) }
    db := opendb()
    rows := sqlite_query(db, "SELECT token, owner, status, email, member_key, created FROM joins WHERE token = ?", []string{state})
    js := parse(rows, []JoinRow{})
    if len(js) == 0 { sqlite_close(db); return sso_page("Unknown or expired sign-in.", 0) }
    owner := js[0].owner
    _, tokenu, userinfo, dok := oidc_endpoints(db)
    if dok == 0 { sqlite_close(db); return sso_page("OIDC discovery failed.", 0) }
    // exchange the code for tokens (client_secret_post, over TLS)
    body := "grant_type=authorization_code&code=" + url_encode(code) + "&redirect_uri=" + url_encode(pubbase(req) + "/team/callback") + "&client_id=" + url_encode(env("HART_OIDC_CLIENT_ID")) + "&client_secret=" + url_encode(env("HART_OIDC_CLIENT_SECRET"))
    st, resp, err := http_request("POST", tokenu, []string{"content-type: application/x-www-form-urlencoded"}, body)
    if err != "" || st != 200 { sqlite_close(db); return sso_page("Sign-in failed at the identity provider (token exchange).", 0) }
    atv, _ := json_get(resp, ".access_token")
    access := unq(atv)
    if access == "" { sqlite_close(db); return sso_page("No access token from the identity provider.", 0) }
    // read the identity from userinfo (no id_token signature check needed — trust the TLS'd,
    // client-authenticated code exchange; interoperable with any signing alg, incl. non-RSA)
    ust, uresp, uerr := http_request("GET", userinfo, []string{"authorization: Bearer " + access}, "")
    if uerr != "" || ust != 200 { sqlite_close(db); return sso_page("Could not read your profile from the identity provider.", 0) }
    ev, _ := json_get(uresp, ".email")
    email := unq(ev)
    if email == "" || email == "null" { sqlite_close(db); return sso_page("No email in your identity provider profile (grant the 'email' scope).", 0) }
    mrows := sqlite_query(db, "SELECT email FROM members WHERE owner = ? AND email = ?", []string{owner, email})
    _, merr := json_get(mrows, "[0].email")
    if merr != "" { sqlite_close(db); return sso_page(email + " is not a member of team '" + owner + "'. Ask an admin: hart team invite " + owner + " " + email, 0) }
    mk := "mk_" + to_hex(rand_bytes(18))
    sqlite_exec(db, "UPDATE members SET key_hash = ? WHERE owner = ? AND email = ?", []string{to_hex(sha256_bytes(bytes(mk))), owner, email})
    sqlite_exec(db, "UPDATE joins SET status = 'done', email = ?, member_key = ? WHERE token = ?", []string{email, mk, state})
    audit(db, "team-join", owner, "", 0, email, req)
    sqlite_close(db)
    res = sso_page("Signed in as " + email + " — your hart Pro member key is ready. Return to your terminal.", 1)
}

// POST /v1/live?id=&on=1|0  — toggle live mode (D2 slice 2). Live pages get connect-src 'self'
// and the self-polling repainter; off returns them to the full default-src 'none' lockdown.
func h_live(req) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    id := query(req, "id")
    if id == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need ?id=\"}") }
    if valid_id(id) == 0 { sqlite_close(db); return response("400 Bad Request", "application/json", invalid_id_json()) }
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, visibility, read_key_hash, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"no such artifact\"}") }
    if owner_authorized(db, ars[0].owner, req) == 0 { sqlite_close(db); return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"owner '" + ars[0].owner + "' is claimed — pass the owner key\"}") }
    lv := 0
    if query(req, "on") == "1" { lv = 1 }
    sqlite_exec(db, "UPDATE artifacts SET live = ? WHERE id = ?", []string{str(lv), id})
    audit(db, "live", ars[0].owner, id, lv, "", req)
    sqlite_close(db)
    en := "false"
    if lv == 1 { en = "true" }
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"live\":" + en + "}")
}

// ---- living loop: in-process refresh scheduler (D2) ------------------------
// Runs in its own goroutine next to serve(). Every 5s it runs any refresh sources
// that are due, GETs the URL (or runs the shell command), and pushes the result as
// the artifact's live data — the same write `hart data` does — so a living deliverable
// keeps itself fresh with no external cron. Each tick uses its own db handle.

func refresh_loop() {
    for {
        run_due_refreshes()
        sleep(5000)
    }
}

func run_due_refreshes() {
    db := opendb()
    if db == 0 { return }
    n := now()
    rows := sqlite_query(db, "SELECT artifact_id, kind, source, header, every, next, last, last_status, enabled FROM refresh WHERE enabled = 1 AND source != '' AND every > 0 AND next <= ? ORDER BY next ASC LIMIT 20", []string{str(n)})
    list := parse(rows, []RefreshRow{})
    i := 0
    while i < len(list) {
        do_refresh(db, list[i])
        i = i + 1
    }
    sqlite_close(db)
}

// do_refresh runs one source and, on success, updates the artifact's data + stamps
// data_updated. Records last_status either way; never overwrites data on a failure.
func do_refresh(db, r) {
    n := now()
    data := ""
    stat := "ok"
    if r.kind == "cmd" {
        code, out, cerr := exec(r.source)
        if code != 0 { stat = "error: exit " + str(code) + " " + trim(cerr) } else { data = out }
    } else {
        hdrs := []string{}
        if r.header != "" { hdrs = append(hdrs, r.header) }
        status, resp, herr := http_request("GET", r.source, hdrs, "")
        if herr != "" { stat = "error: " + herr } else {
            if status < 200 || status >= 300 { stat = "error: http " + str(status) } else { data = resp }
        }
    }
    if stat == "ok" {
        data = trim(data)
        if len(data) == 0 { stat = "error: empty response" } else {
            if len(data) > 524288 { stat = "error: response too large (>512KB)" } else {
                if is_jsonish(data) == 0 { stat = "error: not JSON (data must be a JSON object or array)" }
            }
        }
    }
    if stat == "ok" {
        sqlite_exec(db, "UPDATE artifacts SET data = ?, updated = ?, data_updated = ? WHERE id = ?", []string{data, str(n), str(n), r.artifact_id})
    }
    sqlite_exec(db, "UPDATE refresh SET last = ?, next = ?, last_status = ? WHERE artifact_id = ?", []string{str(n), str(n + r.every), stat, r.artifact_id})
}

func is_jsonish(s) (ok) {
    ok = 0
    if len(s) == 0 { return }
    c := substr(s, 0, 1)
    if c == "{" || c == "[" { ok = 1 }
}

// apply_serve_hardening — production defaults via machweb harden(): proxy-aware client IP,
// Secure cookies, access logs, per-request body cap, read timeout. On when HART_PUBLIC or
// HART_HARDEN=1 is set; opt out with HART_HARDEN=0 (local dev). HART_TRUST_PROXY=0 keeps
// direct-socket IP even if harden is on (rate limits can't be spoofed via X-Forwarded-For).
func apply_serve_hardening() {
    if env("HART_HARDEN") == "0" { return }
    on := 0
    if env("HART_HARDEN") == "1" { on = 1 }
    if env("HART_PUBLIC") != "" { on = 1 }
    if env("HART_TRUST_PROXY") == "1" { on = 1 }
    if on == 0 { return }
    mb := parse_int(env("HART_MAX_BODY_BYTES"))
    if mb <= 0 { mb = 10485760 }   // 10 MiB per request
    rt := parse_int(env("HART_READ_TIMEOUT_MS"))
    if rt <= 0 { rt = 30000 }
    harden(mb, rt)
    if env("HART_TRUST_PROXY") == "0" { set_trust_proxy(0) }
    if env("HART_ACCESS_LOG") == "0" { set_access_log(0) }
}

func cmd_serve(a) {
    port := 8799
    if len(a) >= 3 { port = parse_int(a[2]) }
    g_cookie_secret = env("HART_COOKIE_SECRET")
    if g_cookie_secret == "" { g_cookie_secret = to_hex(rand_bytes(24)) }
    apply_serve_hardening()
    if pubbase_over_https() == 1 { set_secure_cookies(1) }
    say("{\"ok\":true,\"serving\":\"hart\",\"port\":" + str(port) + ",\"routes\":[\"POST /v1/publish\",\"GET /a/<id>[/latest|/v<n>]\",\"GET /v1/artifacts\"]}")
    go refresh_loop()
    serve(port, func(req) { return hart_route(req) })
}

// ---- CLI ------------------------------------------------------------------

func flagv(a, name, dflt) (v) {
    v = dflt
    i := 0
    for i < len(a) {
        if a[i] == name { if i + 1 < len(a) { v = a[i+1] } }
        i = i + 1
    }
}

// parse_duration — "30s" / "15m" / "2h" / "1d" (or a bare number = seconds) -> seconds.
// "off" / "none" / "" -> 0 (clears an SLA).
func parse_duration(s) (secs) {
    secs = 0
    if s == "" || s == "off" || s == "none" { return 0 }
    n := len(s)
    u := substr(s, n - 1, n)
    mult := 0
    if u == "s" { mult = 1 }
    if u == "m" { mult = 60 }
    if u == "h" { mult = 3600 }
    if u == "d" { mult = 86400 }
    if mult == 0 { secs = parse_int(s); return secs }
    secs = parse_int(substr(s, 0, n - 1)) * mult
}

// token store: HART_TOKEN env wins; else ~/.hart-token (written by `hart login`)
func client_token() (t) {
    t = env("HART_TOKEN")
    if t == "" { t = trim(read_file(env("HOME") + "/.hart-token")) }
}
func hart_url() (u) {
    u = env("HART_URL")
    if u == "" { u = "http://127.0.0.1:8799" }
}
func has_flag(a, name) (yes) {
    yes = 0
    i := 0
    for i < len(a) { if a[i] == name { yes = 1 } i = i + 1 }
}

func cmd_publish(a) {
    if len(a) < 3 { die(80, "usage: hart publish <file> [--owner <who>] [--artifact <name>] [--title <t>] [--format html|jsx] [--visibility unlisted|public|private] [--read-key <pw>] [--fresh <30s|15m|2h|1d>] [--unguessable] [--dry-run] [--force]") }
    file := a[2]
    html := read_file(file)
    if html == "" { die(90, "file empty or unreadable: " + file) }
    id := flagv(a, "--id", "")
    owner := flagv(a, "--owner", "")
    artifact := flagv(a, "--artifact", "")
    so := ""
    sa := ""
    if owner != "" { so = require_owner_slug(owner, "owner") }
    if artifact != "" { sa = require_owner_slug(artifact, "artifact") }
    if id != "" { require_valid_id(id) } else {
        if so != "" && sa != "" { require_valid_id(so + "/" + sa) }
    }
    title := flagv(a, "--title", "")
    format := flagv(a, "--format", "html")
    vis := flagv(a, "--visibility", "")
    rk := flagv(a, "--read-key", "")
    fresh := flagv(a, "--fresh", "")
    url := hart_url() + "/v1/publish?format=" + url_encode(format)
    if id != "" { url = url + "&id=" + url_encode(id) }
    if owner != "" { url = url + "&owner=" + url_encode(owner) }
    if artifact != "" { url = url + "&artifact=" + url_encode(artifact) }
    if title != "" { url = url + "&title=" + url_encode(title) }
    if vis != "" { url = url + "&visibility=" + url_encode(vis) }
    if rk != "" { url = url + "&read_key=" + url_encode(rk) }
    if fresh != "" { url = url + "&fresh=" + str(parse_duration(fresh)) }
    if has_flag(a, "--unguessable") == 1 { url = url + "&unguessable=1" }
    if has_flag(a, "--live") == 1 { url = url + "&live=1" }
    if has_flag(a, "--dry-run") == 1 { url = url + "&dry=1" }
    if has_flag(a, "--force") == 1 { url = url + "&force=1" }
    headers := []string{"content-type: text/html; charset=utf-8"}
    tok := client_token()
    if tok != "" { headers = append(headers, "authorization: Bearer " + tok) }
    ok := owner_key_of(a)
    if ok != "" { headers = append(headers, "x-hart-owner-key: " + ok) }
    mk := flagv(a, "--member-key", env("HART_MEMBER_KEY"))
    if mk != "" { headers = append(headers, "x-hart-member-key: " + mk) }
    status, resp, err := http_request("POST", url, headers, html)
    if err != "" { die(100, "cannot reach hart daemon at " + hart_url() + " (is `hart serve` running? set HART_URL): " + err) }
    if status != 200 { write(2, resp + "\n"); exit(80) }   // server already returns clean JSON
    say(resp)
}

// hart visibility <id> <unlisted|public|private> [--read-key <pw>] [--clear-read-key]
func cmd_visibility(a) {
    if len(a) < 4 { die(80, "usage: hart visibility <id> <unlisted|public|private> [--read-key <pw>] [--clear-read-key]") }
    require_valid_id(a[2])
    url := hart_url() + "/v1/visibility?id=" + url_encode(a[2]) + "&visibility=" + url_encode(a[3])
    rk := flagv(a, "--read-key", "")
    if rk != "" { url = url + "&read_key=" + url_encode(rk) }
    if has_flag(a, "--clear-read-key") == 1 { url = url + "&clear_read_key=1" }
    status, resp, err := http_request("POST", url, auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { write(2, resp + "\n"); exit(80) }
    say(resp)
}

// hart explore [query]   /   hart owner <who> [query]  — the public discovery feed (JSON)
func cmd_explore(a) {
    q := ""
    if len(a) >= 3 { q = a[2] }
    status, resp, err := http_request("GET", hart_url() + "/v1/public?q=" + url_encode(q), []string{}, "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(100, "explore failed (" + str(status) + ")") }
    say(resp)
}

// hart guide — print the embedded manual (markdown). Uses HART_URL as the example base.
func cmd_guide() {
    al := "set HART_TOKEN on the daemon to require a publish token; unset = free/open"
    say(guide_md(hart_url(), al))
}

// hart skill — print a drop-in agent SKILL.md (self-install: `hart skill > ~/.claude/skills/hart/SKILL.md`).
func cmd_skill() {
    al := "**free/open** — no token needed to publish"
    if env("HART_TOKEN") != "" { al = "publishing requires a token (set via `hart login <token>`)" }
    say(skill_md(hart_url(), al))
}

// hart stats <id> — living-deliverable analytics (views, last view, freshness, top referrers).
// Sends the owner-key (for a claimed owner) and the admin token if present; either grants access.
func cmd_stats(a) {
    if len(a) < 3 { die(80, "usage: hart stats <id>  (views, last view, freshness, referrers)") }
    require_valid_id(a[2])
    h := []string{}
    at := admin_token()
    if at != "" { h = append(h, "authorization: Bearer " + at) }
    ok := owner_key_of(a)
    if ok != "" { h = append(h, "x-hart-owner-key: " + ok) }
    status, resp, err := http_request("GET", hart_url() + "/v1/artifacts/" + a[2] + "/stats", h, "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status == 403 { write(2, resp + "\n"); exit(80) }
    if status != 200 { die(90, "stats failed (" + str(status) + ")") }
    say(resp)
}

// post_feedback — best-effort POST; 1 if it stored (200), else 0. Never blocks the caller.
func post_feedback(url, payload) (ok) {
    status, resp, err := http_request("POST", url, []string{"content-type: application/json"}, payload)
    if err == "" { if status == 200 { ok = 1 } }
}

// hart feedback <message> [--kind bug|idea|praise] [--context <c>]  — send feedback about hart.
// Dual-writes, best-effort: to THIS instance's /v1/feedback AND to the central relay (machin-
// feedback). A shared client id makes it idempotent. Never fails the caller. FEEDBACK_RELAY
// overrides the relay URL ("off" disables it).
func cmd_feedback(a) {
    if len(a) < 3 { die(80, "usage: hart feedback <message> [--kind bug|idea|praise] [--context <what you were doing>]") }
    msg := a[2]
    kind := flagv(a, "--kind", "note")
    ctx := flagv(a, "--context", "")
    rep := env("USER")
    if rep == "" { rep = "agent" }
    id := nid()
    payload := "{\"app\":\"hart\",\"version\":\"" + hart_version() + "\",\"kind\":\"" + jesc(kind) + "\",\"message\":\"" + jesc(msg) + "\",\"context\":\"" + jesc(ctx) + "\",\"reporter\":\"" + jesc(rep) + "\",\"id\":\"" + id + "\"}"
    stored := post_feedback(hart_url() + "/v1/feedback", payload)
    relay := env("FEEDBACK_RELAY")
    if relay == "" { relay = "https://feedback.intrane.fr" }
    relayed := 0
    if relay != "off" { relayed = post_feedback(relay + "/v1/feedback", payload) }
    st := "false"
    if stored == 1 { st = "true" }
    rl := "false"
    if relayed == 1 { rl = "true" }
    say("{\"ok\":true,\"id\":\"" + id + "\",\"stored\":" + st + ",\"relayed\":" + rl + "}")
}

// hart fresh <id> <30s|15m|2h|1d|off> — set (or clear) an artifact's freshness SLA. A monitored
// living deliverable then surfaces in `hart stale` once it hasn't been refreshed within the SLA.
// refresh_headers — bearer + owner-key for a refresh call. want_admin picks the admin god-token
// as the bearer (needed for cmd sources), else the publish token; owner-key comes from --owner-key/env.
func refresh_headers(a, want_admin) (h) {
    h = []string{}
    bt := ""
    if want_admin == 1 { bt = admin_token() }
    if bt == "" { bt = client_token() }
    if bt != "" { h = append(h, "authorization: Bearer " + bt) }
    ok := owner_key_of(a)
    if ok != "" { h = append(h, "x-hart-owner-key: " + ok) }
}

// hart upgrade [--plan pro] — agent-first purchase: mint a checkout link the human opens to pay.
// Flow: human -> agent/operator (runs this) -> hart-cloud checkout -> pay -> emailed a key ->
// `hart license <key>`. hart-cloud URL from HART_CLOUD_URL (default the intrane billing instance).
func cmd_upgrade(a) {
    cloud := env("HART_CLOUD_URL")
    if cloud == "" { cloud = "https://hart-cloud.intrane.fr" }
    plan := flagv(a, "--plan", "pro")
    status, resp, err := http_request("POST", cloud + "/v1/checkout", []string{"content-type: application/json"}, "{\"plan\":\"" + jesc(plan) + "\"}")
    if err != "" { die(100, "cannot reach hart-cloud (" + cloud + "): " + err) }
    if status != 200 { write(2, resp + "\n"); exit(90) }
    uv, gerr := json_get(resp, ".url")
    if gerr != "" { die(90, "no checkout url in response: " + resp) }
    u := unq(uv)
    say("{\"ok\":true,\"plan\":\"" + jesc(plan) + "\",\"checkout_url\":\"" + jesc(u) + "\",\"next\":\"give the human the checkout_url to pay; they'll be emailed a license key; then run: hart license <key>\"}")
}

// hart license <key> | hart license status — set/inspect the hart Pro license (M3 Plan A).
func cmd_license(a) {
    if len(a) >= 3 && a[2] == "status" {
        status, resp, err := http_request("GET", hart_url() + "/v1/license/status", auth_headers(), "")
        if err != "" { die(100, "cannot reach hart daemon: " + err) }
        if status != 200 { write(2, resp + "\n"); exit(80) }
        say(resp); return
    }
    if len(a) < 3 { die(80, "usage: hart license <key>  |  hart license status") }
    h := []string{}
    at := admin_token()
    if at != "" { h = append(h, "authorization: Bearer " + at) } else {
        t := client_token()
        if t != "" { h = append(h, "authorization: Bearer " + t) }
    }
    h = append(h, "content-type: text/plain")
    status, resp, err := http_request("POST", hart_url() + "/v1/license", h, a[2])
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { write(2, resp + "\n"); exit(80) }
    say(resp)
}

// hart join <owner> — SSO self-onboarding: get a login link, sign in once, receive your member key.
func cmd_join(a) {
    if len(a) < 3 { die(80, "usage: hart join <owner>  (sign in via SSO to claim your team member key)") }
    owner := require_owner_slug(a[2], "owner")
    status, resp, err := http_request("POST", hart_url() + "/v1/join/start?owner=" + url_encode(owner), []string{}, "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { write(2, resp + "\n"); exit(80) }
    lv, _ := json_get(resp, ".login_url")
    tv, _ := json_get(resp, ".token")
    login := unq(lv)
    token := unq(tv)
    write(2, "Open this URL in a browser to sign in:\n  " + login + "\n\nWaiting for sign-in… (up to 5 min)\n")
    i := 0
    while i < 150 {
        sleep(2000)
        ps, pr, perr := http_request("GET", hart_url() + "/v1/join/poll?token=" + url_encode(token), []string{}, "")
        if perr == "" && ps == 200 {
            stv, _ := json_get(pr, ".status")
            if unq(stv) == "done" { say(pr); return }
        }
        i = i + 1
    }
    die(90, "sign-in timed out after 5 min — run `hart join " + owner + "` again")
}

// hart team add <owner> <email> [--role writer|admin] | invite … | list <owner> | rm <owner> <email>
// Per-member keys for a shared owner namespace (hart Pro). Managing needs the owner-key/admin.
func cmd_team(a) {
    sub := ""
    if len(a) > 2 { sub = a[2] }
    base := hart_url()
    if sub == "add" {
        if len(a) < 5 { die(80, "usage: hart team add <owner> <email> [--role writer|admin]") }
        role := flagv(a, "--role", "writer")
        owner := require_owner_slug(a[3], "owner")
        url := base + "/v1/team?owner=" + url_encode(owner) + "&email=" + url_encode(a[4]) + "&role=" + url_encode(role)
        status, resp, err := http_request("POST", url, refresh_headers(a, 1), "")
        if err != "" { die(100, "cannot reach hart daemon: " + err) }
        if status != 200 { write(2, resp + "\n"); exit(80) }
        say(resp); return
    }
    if sub == "invite" {
        if len(a) < 5 { die(80, "usage: hart team invite <owner> <email> [--role writer|admin]  (member self-claims a key via `hart join`)") }
        role := flagv(a, "--role", "writer")
        owner := require_owner_slug(a[3], "owner")
        url := base + "/v1/team?owner=" + url_encode(owner) + "&email=" + url_encode(a[4]) + "&role=" + url_encode(role) + "&invite=1"
        status, resp, err := http_request("POST", url, refresh_headers(a, 1), "")
        if err != "" { die(100, "cannot reach hart daemon: " + err) }
        if status != 200 { write(2, resp + "\n"); exit(80) }
        say(resp); return
    }
    if sub == "list" {
        if len(a) < 4 { die(80, "usage: hart team list <owner>") }
        owner := require_owner_slug(a[3], "owner")
        status, resp, err := http_request("GET", base + "/v1/team?owner=" + url_encode(owner), refresh_headers(a, 1), "")
        if err != "" { die(100, "cannot reach hart daemon: " + err) }
        if status != 200 { write(2, resp + "\n"); exit(80) }
        say(resp); return
    }
    if sub == "rm" {
        if len(a) < 5 { die(80, "usage: hart team rm <owner> <email>") }
        owner := require_owner_slug(a[3], "owner")
        url := base + "/v1/team/rm?owner=" + url_encode(owner) + "&email=" + url_encode(a[4])
        status, resp, err := http_request("POST", url, refresh_headers(a, 1), "")
        if err != "" { die(100, "cannot reach hart daemon: " + err) }
        if status != 200 { write(2, resp + "\n"); exit(80) }
        say(resp); return
    }
    die(80, "usage: hart team add <owner> <email> [--role writer|admin] | list <owner> | rm <owner> <email>")
}

// hart audit [--owner <who>] [--action <a>] [--since <dur>] [--limit N] — the pro audit log (who
// changed what). Operator-gated + requires the audit-log license feature.
func cmd_audit(a) {
    url := hart_url() + "/v1/audit?x=1"
    owner := flagv(a, "--owner", "")
    if owner != "" { owner = require_owner_slug(owner, "owner"); url = url + "&owner=" + url_encode(owner) }
    action := flagv(a, "--action", "")
    if action != "" { url = url + "&action=" + url_encode(action) }
    limit := flagv(a, "--limit", "")
    if limit != "" { url = url + "&limit=" + limit }
    since := flagv(a, "--since", "")
    if since != "" { url = url + "&since=" + str(parse_duration(since)) }
    h := []string{}
    at := admin_token()
    if at != "" { h = append(h, "authorization: Bearer " + at) } else {
        t := client_token()
        if t != "" { h = append(h, "authorization: Bearer " + t) }
    }
    status, resp, err := http_request("GET", url, h, "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { write(2, resp + "\n"); exit(80) }
    say(resp)
}

// hart live <id> <on|off> — toggle whether the page may fetch its own data.json and repaint live.
func cmd_live(a) {
    if len(a) < 4 { die(80, "usage: hart live <id> <on|off>") }
    require_valid_id(a[2])
    on := "0"
    if a[3] == "on" { on = "1" }
    status, resp, err := http_request("POST", hart_url() + "/v1/live?id=" + url_encode(a[2]) + "&on=" + on, refresh_headers(a, 0), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { write(2, resp + "\n"); exit(80) }
    say(resp)
}

// hart refresh <id> [--url <URL> | --cmd '<shell>'] --every <dur> [--header 'H: v'] | --off | --now | (bare = status)
// The daemon runs the source on a schedule and pushes its output as the artifact's live data (D2).
func cmd_refresh(a) {
    if len(a) < 3 { die(80, "usage: hart refresh <id> [--url <URL> | --cmd '<shell>'] --every <30s|15m|2h|1d> [--header 'H: v'] | --off | --now") }
    id := a[2]
    require_valid_id(id)
    base := hart_url()
    if has_flag(a, "--off") == 1 {
        status, resp, err := http_request("POST", base + "/v1/refresh?id=" + url_encode(id) + "&enabled=0", refresh_headers(a, 0), "")
        if err != "" { die(100, "cannot reach hart daemon: " + err) }
        if status != 200 { write(2, resp + "\n"); exit(80) }
        say(resp); return
    }
    if has_flag(a, "--now") == 1 {
        status, resp, err := http_request("POST", base + "/v1/refresh/run?id=" + url_encode(id), refresh_headers(a, 1), "")
        if err != "" { die(100, "cannot reach hart daemon: " + err) }
        if status != 200 { write(2, resp + "\n"); exit(80) }
        say(resp); return
    }
    url := flagv(a, "--url", "")
    cmd := flagv(a, "--cmd", "")
    if url == "" && cmd == "" {
        status, resp, err := http_request("GET", base + "/v1/refresh?id=" + url_encode(id), refresh_headers(a, 0), "")
        if err != "" { die(100, "cannot reach hart daemon: " + err) }
        if status != 200 { write(2, resp + "\n"); exit(80) }
        say(resp); return
    }
    every := flagv(a, "--every", "")
    if every == "" { die(80, "need --every <dur> (e.g. 15m); minimum 30s") }
    secs := parse_duration(every)
    kind := "url"
    source := url
    want_admin := 0
    if cmd != "" { kind = "cmd"; source = cmd; want_admin = 1 }
    q := "?id=" + url_encode(id) + "&kind=" + kind + "&every=" + str(secs)
    header := flagv(a, "--header", "")
    if header != "" { q = q + "&header=" + url_encode(header) }
    h := append(refresh_headers(a, want_admin), "content-type: text/plain")
    status, resp, err := http_request("POST", base + "/v1/refresh" + q, h, source)
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { write(2, resp + "\n"); exit(80) }
    say(resp)
}

func cmd_fresh(a) {
    if len(a) < 4 { die(80, "usage: hart fresh <id> <30s|15m|2h|1d|off>  (freshness SLA for `hart stale`)") }
    require_valid_id(a[2])
    ttl := parse_duration(a[3])
    url := hart_url() + "/v1/fresh?id=" + url_encode(a[2]) + "&ttl=" + str(ttl)
    status, resp, err := http_request("POST", url, auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { write(2, resp + "\n"); exit(80) }
    say(resp)
}

// hart stale [--owner <who>] [--older-than <dur>] — living deliverables that went quiet.
// No --older-than: artifacts past their own SLA (see `hart fresh`). Cross-owner needs the admin
// token; --owner scopes it (owner-key for a claimed owner). hart emits the signal; you alert.
func cmd_stale(a) {
    url := hart_url() + "/v1/stale?x=1"
    owner := flagv(a, "--owner", "")
    if owner != "" { owner = require_owner_slug(owner, "owner"); url = url + "&owner=" + url_encode(owner) }
    ot := flagv(a, "--older-than", "")
    if ot != "" { url = url + "&older_than=" + str(parse_duration(ot)) }
    h := []string{}
    at := admin_token()
    if at != "" { h = append(h, "authorization: Bearer " + at) }
    ok := owner_key_of(a)
    if ok != "" { h = append(h, "x-hart-owner-key: " + ok) }
    status, resp, err := http_request("GET", url, h, "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status == 403 { write(2, resp + "\n"); exit(80) }
    if status != 200 { die(90, "stale failed (" + str(status) + ")") }
    say(resp)
}

func cmd_get(a) {
    if len(a) < 3 { die(80, "usage: hart get <id>  (metadata + versions)") }
    require_valid_id(a[2])
    status, resp, err := http_request("GET", hart_url() + "/v1/artifacts/" + a[2] + "/versions", auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "not found (" + str(status) + ")") }
    say(resp)
}

func cmd_rm(a) {
    if len(a) < 3 { die(80, "usage: hart rm <id>") }
    require_valid_id(a[2])
    status, resp, err := http_request("DELETE", hart_url() + "/v1/artifacts/" + a[2], auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "delete failed (" + str(status) + "): " + resp) }
    say(resp)
}

// hart data <id> '<json>'   |   hart data --owner X --artifact Y '<json>'
// updates the artifact's live data (the template re-renders with it).
func cmd_data(a) {
    if len(a) < 3 { die(80, "usage: hart data <id> '<json>'  |  hart data --owner <who> --artifact <name> '<json>'") }
    id := cli_resolve_id(a, 2)
    json := a[len(a) - 1]
    url := hart_url() + "/v1/data?x=1&id=" + url_encode(id)
    headers := []string{"content-type: application/json"}
    tok := client_token()
    if tok != "" { headers = append(headers, "authorization: Bearer " + tok) }
    ok := owner_key_of(a)
    if ok != "" { headers = append(headers, "x-hart-owner-key: " + ok) }
    mk := flagv(a, "--member-key", env("HART_MEMBER_KEY"))
    if mk != "" { headers = append(headers, "x-hart-member-key: " + mk) }
    status, resp, err := http_request("POST", url, headers, json)
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { write(2, resp + "\n"); exit(80) }
    say(resp)
}

func cmd_rollback(a) {
    if len(a) < 4 { die(80, "usage: hart rollback <id> <version>  (re-point latest at an older version)") }
    require_valid_id(a[2])
    status, resp, err := http_request("POST", hart_url() + "/v1/artifacts/" + a[2] + "/rollback?to=" + a[3], auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "rollback failed (" + str(status) + "): " + resp) }
    say(resp)
}

func auth_headers() (h) {
    h = []string{}
    tok := client_token()
    if tok != "" { h = append(h, "authorization: Bearer " + tok) }
    ok := env("HART_OWNER_KEY")
    if ok != "" { h = append(h, "x-hart-owner-key: " + ok) }
    rk := env("HART_READ_KEY")
    if rk != "" { h = append(h, "x-hart-read-key: " + rk) }
    mk := env("HART_MEMBER_KEY")
    if mk != "" { h = append(h, "x-hart-member-key: " + mk) }
}

// owner_key_flag — --owner-key on the command overrides HART_OWNER_KEY for this call.
func owner_key_of(a) (k) {
    k = flagv(a, "--owner-key", "")
    if k == "" { k = env("HART_OWNER_KEY") }
}

func cmd_login(a) {
    if len(a) < 3 { die(80, "usage: hart login <token>") }
    path := env("HOME") + "/.hart-token"
    write_file(path, a[2])
    say("{\"ok\":true,\"saved\":\"~/.hart-token\"}")
}

// admin token store: HART_ADMIN_TOKEN env wins; else ~/.hart-admin-token (written by `hart admin login`)
func admin_token() (t) {
    t = env("HART_ADMIN_TOKEN")
    if t == "" { t = trim(read_file(env("HOME") + "/.hart-admin-token")) }
}
func admin_headers() (h) {
    h = []string{}
    at := admin_token()
    if at != "" { h = append(h, "authorization: Bearer " + at) }
}

// hart admin owners            — every owner on the instance (count, bytes, has_owner_key)
// hart admin list [--owner X]  — every artifact (url, visibility, has_read_key)
// hart admin login <token>     — save HART_ADMIN_TOKEN to ~/.hart-admin-token
// Operator god-mode over an instance YOU host: requires HART_ADMIN_TOKEN, separate from HART_TOKEN.
func cmd_admin(a) {
    if len(a) < 3 { die(80, "usage: hart admin <owners|list [--owner <who>]|digest [--days N]|mv <old-id> <new-owner/new-name>|login <token>>") }
    sub := a[2]
    if sub == "login" {
        if len(a) < 4 { die(80, "usage: hart admin login <token>") }
        write_file(env("HOME") + "/.hart-admin-token", a[3])
        say("{\"ok\":true,\"saved\":\"~/.hart-admin-token\"}")
        return
    }
    if sub == "mv" {
        if len(a) < 5 { die(80, "usage: hart admin mv <old-id> <new-owner/new-name>  (move/rename, keeps version history + read-key)") }
        require_valid_id(a[3])
        require_mv_to(a[4])
        murl := hart_url() + "/v1/admin/mv?from=" + url_encode(a[3]) + "&to=" + url_encode(a[4])
        status, resp, err := http_request("POST", murl, admin_headers(), "")
        if err != "" { die(100, "cannot reach hart daemon: " + err) }
        if status == 403 { die(80, "admin token required — set HART_ADMIN_TOKEN or run `hart admin login <token>` (and the daemon must have HART_ADMIN_TOKEN set)") }
        if status != 200 { write(2, resp + "\n"); exit(80) }   // 400/404/409 carry a clean JSON error
        say(resp)
        return
    }
    url := ""
    if sub == "owners" { url = hart_url() + "/v1/admin/owners" }
    if sub == "list" {
        url = hart_url() + "/v1/admin/list"
        owner := flagv(a, "--owner", "")
        if owner != "" { owner = require_owner_slug(owner, "owner"); url = url + "?owner=" + url_encode(owner) }
    }
    if sub == "digest" {
        url = hart_url() + "/v1/admin/digest"
        days := flagv(a, "--days", "")
        if days != "" { url = url + "?days=" + url_encode(days) }
    }
    if url == "" { die(80, "unknown admin subcommand: " + sub + "  (owners|list|digest|mv|login)") }
    status, resp, err := http_request("GET", url, admin_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status == 403 { die(80, "admin token required — set HART_ADMIN_TOKEN or run `hart admin login <token>` (and the daemon must have HART_ADMIN_TOKEN set)") }
    if status != 200 { die(100, "admin " + sub + " failed (" + str(status) + ")") }
    say(resp)
}

func cmd_list(a) {
    url := hart_url() + "/v1/artifacts"
    owner := flagv(a, "--owner", "")
    if owner != "" { owner = require_owner_slug(owner, "owner"); url = url + "?owner=" + url_encode(owner) }
    status, resp, err := http_request("GET", url, auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status == 401 { die(80, "not authenticated — hart login <token>") }
    if status == 403 { write(2, resp + "\n"); exit(80) }   // e.g. cross-owner list is admin-only
    if status != 200 { die(100, "list failed (" + str(status) + ")") }
    say(resp)
}

func cmd_versions(a) {
    if len(a) < 3 { die(80, "usage: hart versions <id>") }
    require_valid_id(a[2])
    status, resp, err := http_request("GET", hart_url() + "/v1/artifacts/" + a[2] + "/versions", auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "versions failed (" + str(status) + ")") }
    say(resp)
}

// ---- MCP server (`hart mcp`) --------------------------------------------------
// A stdio JSON-RPC 2.0 MCP server so MCP-native agents (Claude Desktop, Cursor, …) get hart as
// native tools. One binary, no Node — configure {"command":"hart","args":["mcp"],"env":{"HART_URL":..}}.
// It wraps hart's own HTTP API, inheriting auth from env (HART_TOKEN/HART_OWNER_KEY/HART_ADMIN_TOKEN).

func mcp_send(s) { say(s); flush() }   // flush is mandatory — stdout is buffered; the client blocks without it.

// json_field — a leaf value from the request JSON, unquoted, or a default.
func json_field(line, path, dflt) (v) {
    v = dflt
    x, e := json_get(line, path)
    if e == "" { v = unq(x) }
}

func mcp_result(id, resultjson) { mcp_send("{\"jsonrpc\":\"2.0\",\"id\":" + id + ",\"result\":" + resultjson + "}") }
func mcp_error(id, code, msg)   { mcp_send("{\"jsonrpc\":\"2.0\",\"id\":" + id + ",\"error\":{\"code\":" + str(code) + ",\"message\":\"" + jesc(msg) + "\"}}") }

// mcp_content — a tools/call result: the tool's text output (isError flags a failed call).
func mcp_content(id, text, iserr) {
    e := "false"
    if iserr == 1 { e = "true" }
    mcp_result(id, "{\"content\":[{\"type\":\"text\",\"text\":\"" + jesc(text) + "\"}],\"isError\":" + e + "}")
}

// mcp_http — run one wrapped API call and answer the tools/call. iserr when status != 200.
func mcp_http(id, method, url, headers, body) {
    status, resp, err := http_request(method, url, headers, body)
    if err != "" { mcp_content(id, "cannot reach hart daemon at " + hart_url() + ": " + err, 1); return }
    ie := 0
    if status != 200 { ie = 1 }
    mcp_content(id, resp, ie)
}

func mcp_tools_json() (t) {
    t = "{\"tools\":["
    t = t + "{\"name\":\"hart_publish\",\"description\":\"Publish a self-contained HTML or JSX page to a live, versioned, sandboxed URL. Inline ALL CSS/JS (no external refs/network — strict CSP). Returns {url,version,...}.\",\"inputSchema\":{\"type\":\"object\",\"properties\":{\"html\":{\"type\":\"string\",\"description\":\"the full self-contained HTML/JSX document\"},\"owner\":{\"type\":\"string\"},\"artifact\":{\"type\":\"string\",\"description\":\"stable name; re-publishing the same owner/artifact appends a version\"},\"title\":{\"type\":\"string\"},\"format\":{\"type\":\"string\",\"enum\":[\"html\",\"jsx\"]},\"visibility\":{\"type\":\"string\",\"enum\":[\"unlisted\",\"public\",\"private\"]},\"read_key\":{\"type\":\"string\",\"description\":\"password for private artifacts\"},\"fresh\":{\"type\":\"string\",\"description\":\"freshness SLA e.g. 15m, 2h, 1d\"}},\"required\":[\"html\"]}},"
    t = t + "{\"name\":\"hart_data\",\"description\":\"Update a published artifact's live data (the page re-renders from window.HART_DATA / {{key}}); same URL. For living dashboards.\",\"inputSchema\":{\"type\":\"object\",\"properties\":{\"id\":{\"type\":\"string\",\"description\":\"owner/artifact\"},\"data\":{\"type\":\"string\",\"description\":\"a JSON string\"}},\"required\":[\"id\",\"data\"]}},"
    t = t + "{\"name\":\"hart_list\",\"description\":\"List artifacts (optionally one owner): id, title, latest version, updated.\",\"inputSchema\":{\"type\":\"object\",\"properties\":{\"owner\":{\"type\":\"string\"}}}},"
    t = t + "{\"name\":\"hart_get\",\"description\":\"One artifact's metadata + version history.\",\"inputSchema\":{\"type\":\"object\",\"properties\":{\"id\":{\"type\":\"string\",\"description\":\"owner/artifact\"}},\"required\":[\"id\"]}},"
    t = t + "{\"name\":\"hart_stats\",\"description\":\"Living-deliverable analytics for an artifact: views, last view, freshness, top referrers.\",\"inputSchema\":{\"type\":\"object\",\"properties\":{\"id\":{\"type\":\"string\"}},\"required\":[\"id\"]}},"
    t = t + "{\"name\":\"hart_stale\",\"description\":\"Living deliverables that went quiet — past their freshness SLA, or (with older_than) any not touched within a window. JSON signal; you decide how to alert.\",\"inputSchema\":{\"type\":\"object\",\"properties\":{\"owner\":{\"type\":\"string\"},\"older_than\":{\"type\":\"string\",\"description\":\"e.g. 2h, 1d\"}}}},"
    t = t + "{\"name\":\"hart_explore\",\"description\":\"Public discovery feed across the instance (recency-ranked), optional text query.\",\"inputSchema\":{\"type\":\"object\",\"properties\":{\"query\":{\"type\":\"string\"}}}}"
    t = t + "]}"
}

// mcp_tools_call — dispatch one tools/call to the wrapped API.
func mcp_tools_call(line, id) {
    name := json_field(line, ".params.name", "")
    tok := client_token()
    okey := env("HART_OWNER_KEY")
    atok := admin_token()
    ap := ".params.arguments."
    if name == "hart_publish" {
        html := json_field(line, ap + "html", "")
        if html == "" { mcp_content(id, "hart_publish: 'html' is required", 1); return }
        ow := json_field(line, ap + "owner", "")
        ar := json_field(line, ap + "artifact", "")
        if ow != "" && slugify(ow) == "" { mcp_content(id, "hart_publish: invalid owner — use letters, digits, or hyphens", 1); return }
        if ar != "" && slugify(ar) == "" { mcp_content(id, "hart_publish: invalid artifact — use letters, digits, or hyphens", 1); return }
        if ow != "" && ar != "" && valid_id(slugify(ow) + "/" + slugify(ar)) == 0 { mcp_content(id, "hart_publish: invalid id — use owner/artifact (lowercase alnum and hyphens, no ..)", 1); return }
        url := hart_url() + "/v1/publish?format=" + url_encode(json_field(line, ap + "format", "html"))
        if ow != "" { url = url + "&owner=" + url_encode(ow) }
        if ar != "" { url = url + "&artifact=" + url_encode(ar) }
        ti := json_field(line, ap + "title", "");      if ti != "" { url = url + "&title=" + url_encode(ti) }
        vi := json_field(line, ap + "visibility", ""); if vi != "" { url = url + "&visibility=" + url_encode(vi) }
        rk := json_field(line, ap + "read_key", "");   if rk != "" { url = url + "&read_key=" + url_encode(rk) }
        fr := json_field(line, ap + "fresh", "");      if fr != "" { url = url + "&fresh=" + str(parse_duration(fr)) }
        h := []string{"content-type: text/html; charset=utf-8"}
        if tok != "" { h = append(h, "authorization: Bearer " + tok) }
        if okey != "" { h = append(h, "x-hart-owner-key: " + okey) }
        mcp_http(id, "POST", url, h, html)
        return
    }
    if name == "hart_data" {
        did := json_field(line, ap + "id", "")
        dat := json_field(line, ap + "data", "")
        if did == "" || dat == "" { mcp_content(id, "hart_data: 'id' and 'data' are required", 1); return }
        if valid_id(did) == 0 { mcp_content(id, "hart_data: invalid id — use owner/artifact (lowercase alnum and hyphens, no ..)", 1); return }
        url := hart_url() + "/v1/data?id=" + url_encode(did)
        h := []string{"content-type: application/json"}
        if tok != "" { h = append(h, "authorization: Bearer " + tok) }
        if okey != "" { h = append(h, "x-hart-owner-key: " + okey) }
        mcp_http(id, "POST", url, h, dat)
        return
    }
    if name == "hart_list" {
        url := hart_url() + "/v1/artifacts"
        ow := json_field(line, ap + "owner", "")
        if ow != "" {
            if slugify(ow) == "" { mcp_content(id, "hart_list: invalid owner — use letters, digits, or hyphens", 1); return }
            url = url + "?owner=" + url_encode(slugify(ow))
        }
        mcp_http(id, "GET", url, auth_headers(), "")
        return
    }
    if name == "hart_get" {
        gid := json_field(line, ap + "id", "")
        if gid == "" { mcp_content(id, "hart_get: 'id' is required", 1); return }
        if valid_id(gid) == 0 { mcp_content(id, "hart_get: invalid id — use owner/artifact (lowercase alnum and hyphens, no ..)", 1); return }
        mcp_http(id, "GET", hart_url() + "/v1/artifacts/" + gid + "/versions", auth_headers(), "")
        return
    }
    if name == "hart_stats" {
        sid := json_field(line, ap + "id", "")
        if sid == "" { mcp_content(id, "hart_stats: 'id' is required", 1); return }
        if valid_id(sid) == 0 { mcp_content(id, "hart_stats: invalid id — use owner/artifact (lowercase alnum and hyphens, no ..)", 1); return }
        h := []string{}
        if atok != "" { h = append(h, "authorization: Bearer " + atok) }
        if okey != "" { h = append(h, "x-hart-owner-key: " + okey) }
        mcp_http(id, "GET", hart_url() + "/v1/artifacts/" + sid + "/stats", h, "")
        return
    }
    if name == "hart_stale" {
        url := hart_url() + "/v1/stale?x=1"
        ow := json_field(line, ap + "owner", "")
        if ow != "" {
            if slugify(ow) == "" { mcp_content(id, "hart_stale: invalid owner — use letters, digits, or hyphens", 1); return }
            url = url + "&owner=" + url_encode(slugify(ow))
        }
        ot := json_field(line, ap + "older_than", ""); if ot != "" { url = url + "&older_than=" + str(parse_duration(ot)) }
        h := []string{}
        if atok != "" { h = append(h, "authorization: Bearer " + atok) }
        if okey != "" { h = append(h, "x-hart-owner-key: " + okey) }
        mcp_http(id, "GET", url, h, "")
        return
    }
    if name == "hart_explore" {
        mcp_http(id, "GET", hart_url() + "/v1/public?q=" + url_encode(json_field(line, ap + "query", "")), []string{}, "")
        return
    }
    mcp_content(id, "unknown tool: " + name, 1)
}

func cmd_mcp(a) {
    for 1 == 1 {
        line := input()
        if line == "" { return }   // EOF (client closed stdin) -> exit
        method, me := json_get(line, ".method")
        if me != "" { continue }   // not a JSON-RPC message we recognize
        m := unq(method)
        _, ie := json_get(line, ".id")
        hasid := 0
        if ie == "" { hasid = 1 }
        id := "null"
        if hasid == 1 { idr, _ := json_get(line, ".id"); id = idr }   // echo id verbatim (number or string)
        if m == "initialize" {
            pv := json_field(line, ".params.protocolVersion", "2024-11-05")
            mcp_result(id, "{\"protocolVersion\":\"" + jesc(pv) + "\",\"capabilities\":{\"tools\":{}},\"serverInfo\":{\"name\":\"hart\",\"version\":\"" + hart_version() + "\"}}")
            continue
        }
        if m == "tools/list" { mcp_result(id, mcp_tools_json()); continue }
        if m == "tools/call" { mcp_tools_call(line, id); continue }
        if m == "ping" { mcp_result(id, "{}"); continue }
        if has_prefix(m, "notifications/") { continue }   // notifications get no response
        if hasid == 1 { mcp_error(id, -32601, "method not found: " + m) }
    }
}

func cmd_help() {
    say("{\"ok\":true,\"name\":\"hart\",\"tagline\":\"agent-first artifact host — publish self-contained HTML or JSX, get a versioned sandboxed URL\",\"commands\":{\"serve\":\"serve [port] (daemon; HART_DB, HART_RUNTIME_DIR, HART_PUBLIC, HART_EXPLORE=0 to disable /explore; HART_TOKEN gates publishing)\",\"login\":\"login <token>\",\"publish\":\"publish <file> [--owner --artifact --title --format html|jsx --visibility unlisted|public|private --read-key <pw> --unguessable --dry-run --force]\",\"data\":\"data <id> '<json>' (update the live data; template re-renders)\",\"visibility\":\"visibility <id> <unlisted|public|private> [--read-key <pw> --clear-read-key]\",\"explore\":\"explore [query] (public discovery feed, JSON)\",\"get\":\"get <id>\",\"list\":\"list [--owner <who>]\",\"versions\":\"versions <id>\",\"rollback\":\"rollback <id> <version>\",\"rm\":\"rm <id>\",\"stats\":\"stats <id> (views, last view, freshness, top referrers; server-side, CSP-safe)\",\"feedback\":\"feedback <message> [--kind bug|idea|praise] [--context <c>] (dual-writes to this instance + the central relay; best-effort)\",\"fresh\":\"fresh <id> <30s|15m|2h|1d|off> (set/clear a freshness SLA)\",\"stale\":\"stale [--owner <who>] [--older-than <dur>] (living deliverables that went quiet; JSON signal, you alert)\",\"refresh\":\"refresh <id> [--url <URL>|--cmd '<sh>'] --every <dur> [--header 'H: v']|--off|--now (daemon self-refreshes the artifact's data on a schedule; cmd sources admin-only)\",\"live\":\"live <id> <on|off> (page polls its own data.json and repaints live; opt-in connect-src 'self')\",\"upgrade\":\"upgrade [--plan pro] (mint a hart Pro checkout link to hand the human; HART_CLOUD_URL)\",\"license\":\"license <key> | license status (set/inspect the hart Pro license)\",\"audit\":\"audit [--owner --action --since --limit] (who changed what; hart Pro)\",\"team\":\"team <add|invite|list|rm> <owner> [<email>] [--role writer|admin] (per-member keys for a shared namespace; hart Pro)\",\"join\":\"join <owner> (SSO self-onboarding via OpenID Connect; receive your member key; hart Pro)\",\"mcp\":\"mcp (run as a stdio MCP server — native tools for MCP-capable agents; wraps the HTTP API)\",\"skill\":\"skill (print a drop-in agent SKILL.md; self-install: hart skill > ~/.claude/skills/hart/SKILL.md)\",\"guide\":\"guide (print the full manual; also GET /guide.md)\",\"admin\":\"admin <owners|list [--owner <who>]|digest [--days N]|mv <old-id> <new-owner/new-name>|login <token>> (operator god-mode over an instance you host; needs HART_ADMIN_TOKEN)\"},\"visibility\":{\"unlisted\":\"default — public read, not listed\",\"public\":\"public read, listed at /explore and /o/<owner>\",\"private\":\"gated read — password (browser: unlock page) or X-Hart-Read-Key header (agents)\"},\"env\":{\"HART_URL\":\"daemon\",\"HART_TOKEN\":\"instance publish token\",\"HART_OWNER_KEY\":\"namespace write key\",\"HART_READ_KEY\":\"read key for a private artifact (sent as X-Hart-Read-Key)\",\"HART_ADMIN_TOKEN\":\"operator god-token for the admin API (cross-owner list); separate from HART_TOKEN, unset = admin API off\",\"HART_LICENSE_KEY\":\"hart Pro license key (or set via hart license <key>)\",\"HART_LICENSE_PUBKEY\":\"override the license signing pubkey (run your own hart-cloud issuer)\",\"HART_MEMBER_KEY\":\"a team member's per-member write key (teams; sent as X-Hart-Member-Key)\",\"HART_OIDC_ISSUER\":\"teams SSO: your OpenID Connect issuer (discovery-based)\",\"HART_OIDC_CLIENT_ID\":\"teams SSO: OIDC client id\",\"HART_OIDC_CLIENT_SECRET\":\"teams SSO: OIDC client secret\",\"HART_OIDC_SCOPES\":\"teams SSO: OIDC scopes (default 'openid email')\",\"HART_MAX_OWNER_MB\":\"per-owner storage cap; raising it above HART_FREE_MAX_OWNER_MB needs hart Pro (0=unlimited)\",\"HART_FREE_MAX_OWNER_MB\":\"free-tier per-owner storage ceiling (default 30)\",\"HART_CLOUD_URL\":\"hart-cloud billing base for hart upgrade (default https://hart-cloud.intrane.fr)\"},\"discovery\":{\"global\":\"/explore\",\"owner\":\"/o/<owner>\"}}")
}

func main() {
    a := args()
    cmd := ""
    if len(a) >= 2 { cmd = a[1] }
    if cmd == "" || cmd == "help" { cmd_help(); return }
    if cmd == "serve" { cmd_serve(a); return }
    if cmd == "login" { cmd_login(a); return }
    if cmd == "publish" { cmd_publish(a); return }
    if cmd == "data" { cmd_data(a); return }
    if cmd == "get" { cmd_get(a); return }
    if cmd == "list" { cmd_list(a); return }
    if cmd == "versions" { cmd_versions(a); return }
    if cmd == "rollback" { cmd_rollback(a); return }
    if cmd == "visibility" { cmd_visibility(a); return }
    if cmd == "explore" { cmd_explore(a); return }
    if cmd == "guide" { cmd_guide(); return }
    if cmd == "skill" { cmd_skill(); return }
    if cmd == "stats" { cmd_stats(a); return }
    if cmd == "fresh" { cmd_fresh(a); return }
    if cmd == "refresh" { cmd_refresh(a); return }
    if cmd == "live" { cmd_live(a); return }
    if cmd == "upgrade" { cmd_upgrade(a); return }
    if cmd == "license" { cmd_license(a); return }
    if cmd == "audit" { cmd_audit(a); return }
    if cmd == "team" { cmd_team(a); return }
    if cmd == "join" { cmd_join(a); return }
    if cmd == "stale" { cmd_stale(a); return }
    if cmd == "mcp" { cmd_mcp(a); return }
    if cmd == "feedback" { cmd_feedback(a); return }
    if cmd == "rm" { cmd_rm(a); return }
    if cmd == "admin" { cmd_admin(a); return }
    write(2, "{\"ok\":false,\"error\":\"unknown command: " + cmd + "\"}\n")
    exit(80)
}
