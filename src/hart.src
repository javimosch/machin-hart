// hart — the agent-first artifact host. One MFL/machin static binary that is BOTH a hosting
// daemon (`hart serve`) and a CLI (`hart publish <file>` → a live, sandboxed URL). M0 spike:
// prove the loop end to end — publish HTML → stored+versioned in SQLite → served at /a/<id>
// wrapped in a doctype skeleton + a strict CSP, with v1/v2/v3/latest versioning.
//
// Agent-first: JSON on stdout, structured errors on stderr, semantic exit codes.
// Env: HART_URL (publish target, default http://127.0.0.1:8799), HART_DB (default ~/.hart.db),
//      HART_PORT (serve port, default 8799), HART_PUBLIC (public base for returned URLs).

type ArtRow struct { id string  account_id string  title string  latest int  created int  updated int }
type VerRow struct { version int  format string  created int }
type HtmlRow struct { html string  format string  title string }

// the strict render sandbox — same envelope idea as Claude artifacts: renders the page while
// neutering it as an exfiltration/attack vector. No external anything; no network.
func csp() (c) {
    c = "default-src 'none'; img-src data: blob:; media-src data: blob:; style-src 'unsafe-inline'; font-src data:; script-src 'unsafe-inline' 'unsafe-eval'; base-uri 'none'; form-action 'none'; frame-ancestors 'self'"
}

// JSX pages additionally load the same-origin runtime (react/babel) — script-src gains 'self'
// for those assets only. Still no external host, still no network.
func csp_jsx() (c) {
    c = "default-src 'none'; img-src data: blob:; media-src data: blob:; style-src 'unsafe-inline'; font-src data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; base-uri 'none'; form-action 'none'; frame-ancestors 'self'"
}

func runtime_dir() (d) {
    d = env("HART_RUNTIME_DIR")
    if d == "" { d = "runtime" }
}

func hdb() (p) {
    p = env("HART_DB")
    if p == "" { p = env("HOME") + "/.hart.db" }
}

func opendb() (db) {
    db = sqlite_open(hdb())
    sqlite_exec(db, "PRAGMA busy_timeout=3000", []string{})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS artifacts(id TEXT PRIMARY KEY, account_id TEXT DEFAULT '', title TEXT, latest INTEGER DEFAULT 0, created INTEGER, updated INTEGER)", []string{})
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN account_id TEXT DEFAULT ''", []string{})   // no-op once it exists
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS versions(artifact_id TEXT, version INTEGER, title TEXT, format TEXT, html TEXT, hash TEXT, created INTEGER, PRIMARY KEY(artifact_id, version))", []string{})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS accounts(id TEXT PRIMARY KEY, email TEXT UNIQUE, created INTEGER)", []string{})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS tokens(token TEXT PRIMARY KEY, account_id TEXT, created INTEGER)", []string{})
}

func nid() (s) { s = to_hex(rand_bytes(6)) }
func longid() (s) { s = to_hex(rand_bytes(16)) }

func unq(s) (o) {
    o = s
    n := len(s)
    if n >= 2 { if substr(s, 0, 1) == "\"" { o = substr(s, 1, n - 1) } }
}

// auth: resolve the bearer token to an account. Open mode (HART_OPEN=1, for single-user
// self-host) returns a fixed "self" account so publish works with no token.
func bearer_account(db, req) (aid, ok) {
    aid = ""
    ok = 0
    if env("HART_OPEN") == "1" { return "self", 1 }
    h := header(req, "authorization")
    if !has_prefix(h, "Bearer ") { return aid, ok }
    tok := trim(substr(h, 7, len(h)))
    if tok == "" { return aid, ok }
    rows := sqlite_query(db, "SELECT account_id FROM tokens WHERE token = ?", []string{tok})
    v, err := json_get(rows, "[0].account_id")
    if err == "" { aid = unq(v) }
    if aid != "" && aid != "null" { ok = 1 } else { aid = "" }
}

func say(s) { write(1, s + "\n") }
func die(code, msg) { write(2, "{\"ok\":false,\"error\":\"" + msg + "\"}\n"); exit(code) }

// public base for the URLs we hand back. HART_PUBLIC pins the real domain (hosted/proxied);
// otherwise reflect the Host the client actually hit, so returned URLs are always dialable.
func pubbase(req) (b) {
    b = env("HART_PUBLIC")
    if b == "" {
        host := header(req, "host")
        if host == "" { host = "127.0.0.1:8799" }
        b = "http://" + host
    }
}

// ---- daemon ---------------------------------------------------------------

// POST /v1/publish?id=&title=&format=  — raw HTML in the body (no JSON escaping of the page).
// New id -> v1; existing id -> next version; `latest` always tracks the newest.
func h_publish(req) (res) {
    db := opendb()
    aid, ok := bearer_account(db, req)
    if ok == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"bad or missing token — hart login <token> (or run the daemon with HART_OPEN=1 for single-user)\"}") }
    id := query(req, "id")
    title := query(req, "title")
    format := query(req, "format")
    if format == "" { format = "html" }
    body := req.body
    if body == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"empty body\"}") }
    // publish-time safety lint (see lint()); hard violations block unless ?force=1
    report := lint(body)
    if query(req, "dry") == "1" {
        sqlite_close(db)
        blk := "false"
        if lint_blocks(report) == 1 { blk = "true" }
        return ok_json("{\"ok\":true,\"dry_run\":true,\"would_block\":" + blk + ",\"bytes\":" + str(len(body)) + ",\"lint\":" + report + "}")
    }
    if lint_blocks(report) == 1 && query(req, "force") != "1" {
        sqlite_close(db)
        return response("422 Unprocessable Entity", "application/json", "{\"ok\":false,\"error\":\"content-security violations — self-contained pages only; inline assets or pass --force\",\"lint\":" + report + "}")
    }
    n := now()
    ver := 1
    arows := sqlite_query(db, "SELECT id, account_id, title, latest, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if id != "" && len(ars) > 0 {
        if ars[0].account_id != aid && env("HART_OPEN") != "1" {
            sqlite_close(db)
            return response("403 Forbidden", "application/json", "{\"ok\":false,\"error\":\"that id belongs to another account\"}")
        }
        // next version = highest ever + 1 (NOT latest+1 — rollback can move latest backward)
        mrows := sqlite_query(db, "SELECT COALESCE(MAX(version),0) AS m FROM versions WHERE artifact_id = ?", []string{id})
        mraw, _ := json_get(mrows, "[0].m")
        ver = parse_int(mraw) + 1
        sqlite_exec(db, "UPDATE artifacts SET latest = ?, title = COALESCE(NULLIF(?,''), title), updated = ? WHERE id = ?", []string{str(ver), title, str(n), id})
    } else {
        if id == "" { id = nid() }
        sqlite_exec(db, "INSERT INTO artifacts(id, account_id, title, latest, created, updated) VALUES(?,?,?,?,?,?)", []string{id, aid, title, str(ver), str(n), str(n)})
    }
    hash := to_hex(sha256_bytes(bytes(body)))
    sqlite_exec(db, "INSERT INTO versions(artifact_id, version, title, format, html, hash, created) VALUES(?,?,?,?,?,?,?)", []string{id, str(ver), title, format, body, hash, str(n)})
    sqlite_close(db)
    base := pubbase(req)
    out := "{\"ok\":true,\"id\":\"" + id + "\",\"version\":" + str(ver) + ",\"format\":\"" + format + "\",\"url\":\"" + base + "/a/" + id + "\",\"latest_url\":\"" + base + "/a/" + id + "/latest\",\"pinned_url\":\"" + base + "/a/" + id + "/v" + str(ver) + "\",\"lint\":" + report + "}"
    res = ok_json(out)
}

func h_list(req) (res) {
    db := opendb()
    aid, ok := bearer_account(db, req)
    if ok == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"bad or missing token\"}") }
    rows := sqlite_query(db, "SELECT id, account_id, title, latest, updated FROM artifacts WHERE account_id = ? ORDER BY updated DESC LIMIT 500", []string{aid})
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"artifacts\":" + rows + "}")
}

func h_versions(db, req, id) (res) {
    aid, ok := bearer_account(db, req)
    if ok == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"bad or missing token\"}") }
    orows := sqlite_query(db, "SELECT id, account_id, title, latest, created, updated FROM artifacts WHERE id = ?", []string{id})
    oa := parse(orows, []ArtRow{})
    if len(oa) == 0 || (oa[0].account_id != aid && env("HART_OPEN") != "1") { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    rows := sqlite_query(db, "SELECT version, format, created FROM versions WHERE artifact_id = ? ORDER BY version DESC", []string{id})
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"versions\":" + rows + "}")
}

// h_delete — remove an artifact + all versions (owner only).
func h_delete(req, id) (res) {
    db := opendb()
    aid, ok := bearer_account(db, req)
    if ok == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"bad or missing token\"}") }
    orows := sqlite_query(db, "SELECT id, account_id, title, latest, created, updated FROM artifacts WHERE id = ?", []string{id})
    oa := parse(orows, []ArtRow{})
    if len(oa) == 0 || (oa[0].account_id != aid && env("HART_OPEN") != "1") { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    sqlite_exec(db, "DELETE FROM versions WHERE artifact_id = ?", []string{id})
    sqlite_exec(db, "DELETE FROM artifacts WHERE id = ?", []string{id})
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"deleted\":\"" + id + "\"}")
}

// h_rollback — re-point `latest` at an existing older version (owner only). Non-destructive:
// versions stay immutable; publishing afterwards still appends MAX+1.
func h_rollback(req, id, target) (res) {
    db := opendb()
    aid, ok := bearer_account(db, req)
    if ok == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"bad or missing token\"}") }
    orows := sqlite_query(db, "SELECT id, account_id, title, latest, created, updated FROM artifacts WHERE id = ?", []string{id})
    oa := parse(orows, []ArtRow{})
    if len(oa) == 0 || (oa[0].account_id != aid && env("HART_OPEN") != "1") { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    vrows := sqlite_query(db, "SELECT version, format, created FROM versions WHERE artifact_id = ? AND version = ?", []string{id, str(target)})
    vs := parse(vrows, []VerRow{})
    if len(vs) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"no such version — see hart versions <id>\"}") }
    sqlite_exec(db, "UPDATE artifacts SET latest = ?, updated = ? WHERE id = ?", []string{str(target), str(now()), id})
    sqlite_close(db)
    base := pubbase(req)
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"latest\":" + str(target) + ",\"url\":\"" + base + "/a/" + id + "\"}")
}

// ---- the publish contract linter ------------------------------------------
// hart hosts SELF-CONTAINED pages. lint() flags anything that reaches off-page: external
// script/style/img/font, @import, and network calls. Hard violations (external <script src>,
// fetch/XHR/WebSocket) block publish unless forced; soft ones (external img/font) warn.
// Returns a JSON array of {level,rule,note}. Cheap substring scan on a lowercased copy.
func lint_find(lc, needle, level, rule, note, acc) (out, blocked) {
    out = acc
    blocked = 0
    if index(lc, needle) >= 0 {
        if acc != "[" { out = acc + "," }
        out = out + "{\"level\":\"" + level + "\",\"rule\":\"" + rule + "\",\"note\":\"" + note + "\"}"
        if level == "error" { blocked = 1 }
    }
}

func lint(html) (report) {
    lc := to_lower(html)
    r := "["
    b := 0
    r2, b2 := lint_find(lc, "<script src=\"http", "error", "external-script", "external <script src> — inline the JS", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "<script src='http", "error", "external-script", "external <script src> — inline the JS", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "fetch(", "error", "network-fetch", "fetch() call — artifacts are offline; connect-src is 'none'", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "xmlhttprequest", "error", "network-xhr", "XMLHttpRequest — no network in the sandbox", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "new websocket", "error", "network-ws", "WebSocket — no network in the sandbox", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "rel=\"stylesheet\" href=\"http", "warn", "external-css", "external stylesheet — inline the CSS", r)
    r = r2
    r2, b2 = lint_find(lc, "@import url(http", "warn", "external-import", "@import from a URL — inline the CSS", r)
    r = r2
    r2, b2 = lint_find(lc, "src=\"http", "warn", "external-asset", "external asset src — embed as a data: URI", r)
    r = r2
    report = r + "]"
}

func lint_blocks(report) (n) {
    n = 0
    if index(report, "\"level\":\"error\"") >= 0 { n = 1 }
}

// wrap stored content in a minimal doctype skeleton (the content itself carries inline
// <title>/<style>/<script>, artifact-style) and serve under the strict CSP.
func render_page(html, title) (page) {
    t := title
    if t == "" { t = "hart artifact" }
    page = "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>" + t + "</title></head><body>" + html + "</body></html>"
}

// JSX: load the same-origin React + Babel runtime, then transform the agent's JSX with the
// CLASSIC runtime (emits React.createElement — no `import` of jsx-runtime, which would fail
// outside a module) and eval it. React/ReactDOM are globals; the agent renders into #root.
func render_page_jsx(jsx, title) (page) {
    t := title
    if t == "" { t = "hart artifact" }
    src := replace(jsx, "</script>", "<\\/script>")   // don't let the source close its host tag
    head := "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>" + t + "</title>"
    rt := "<script src=\"/_hart/runtime/react.js\"></script><script src=\"/_hart/runtime/react-dom.js\"></script><script src=\"/_hart/runtime/babel.js\"></script></head>"
    boot := "<script>(function(){try{var s=document.getElementById('__hart_jsx').textContent;var o=Babel.transform(s,{presets:[['react',{runtime:'classic'}]]}).code;(0,eval)(o);}catch(e){document.getElementById('root').innerHTML='<pre style=\"color:#b00020;padding:24px;font:14px ui-monospace,monospace;white-space:pre-wrap\">hart: JSX error\\n\\n'+((e&&e.message)?e.message:e)+'</pre>';}})();</script>"
    body := "<body><div id=\"root\"></div><script type=\"text/plain\" id=\"__hart_jsx\">\n" + src + "\n</script>" + boot + "</body></html>"
    page = head + rt + body
}

// serve a same-origin runtime asset (react/react-dom/babel) from disk. Path-safe (no traversal).
func serve_runtime(fname) (res) {
    if index(fname, "..") >= 0 || index(fname, "/") >= 0 { return response("400 Bad Request", "text/plain", "bad path") }
    body := read_file(runtime_dir() + "/" + fname)
    if body == "" { return response("404 Not Found", "text/plain; charset=utf-8", "runtime asset not found — deploy the hart runtime dir") }
    r := response("200 OK", "application/javascript; charset=utf-8", body)
    r = with_header(r, "Cache-Control", "public, max-age=31536000, immutable")
    res = r
}

func serve_artifact(db, id, ver) (res) {
    v := ver
    if v == 0 {
        arows := sqlite_query(db, "SELECT id, account_id, title, latest, created, updated FROM artifacts WHERE id = ?", []string{id})
        ars := parse(arows, []ArtRow{})
        if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "text/plain; charset=utf-8", "artifact not found") }
        v = ars[0].latest
    }
    hrows := sqlite_query(db, "SELECT html, format, title FROM versions WHERE artifact_id = ? AND version = ?", []string{id, str(v)})
    sqlite_close(db)
    hs := parse(hrows, []HtmlRow{})
    if len(hs) == 0 { return response("404 Not Found", "text/plain; charset=utf-8", "version not found") }
    page := render_page(hs[0].html, hs[0].title)
    ct := csp()
    if hs[0].format == "jsx" { page = render_page_jsx(hs[0].html, hs[0].title); ct = csp_jsx() }
    r := ok_html(page)
    r = with_header(r, "Content-Security-Policy", ct)
    r = with_header(r, "X-Content-Type-Options", "nosniff")
    r = with_header(r, "X-Frame-Options", "SAMEORIGIN")
    r = with_header(r, "Referrer-Policy", "no-referrer")
    res = r
}

// parse /a/<id>, /a/<id>/latest, /a/<id>/v<n>
func handle_artifact(req, p) (res) {
    rest := substr(p, 3, len(p))   // strip "/a/"
    parts := split(rest, "/")
    id := parts[0]
    if id == "" { return response("404 Not Found", "text/plain", "no id") }
    db := opendb()
    ver := 0
    if len(parts) > 1 {
        seg := parts[1]
        if seg != "latest" && seg != "" {
            if substr(seg, 0, 1) == "v" { ver = parse_int(substr(seg, 1, len(seg))) } else { ver = parse_int(seg) }
        }
    }
    res = serve_artifact(db, id, ver)
}

func hart_route(req) (res) {
    p := req.path
    qi := index(p, "?")
    if qi >= 0 { p = substr(p, 0, qi) }
    if p == "/_health" { return ok_json("{\"ok\":true,\"service\":\"hart\"}") }
    if req.method == "GET" && has_prefix(p, "/_hart/runtime/") { return serve_runtime(substr(p, 15, len(p))) }
    if req.method == "POST" && p == "/v1/publish" { return h_publish(req) }
    if req.method == "GET" && p == "/v1/artifacts" { return h_list(req) }
    if req.method == "GET" && has_prefix(p, "/v1/artifacts/") {
        id := substr(p, 14, len(p))
        si := index(id, "/")
        if si >= 0 { id = substr(id, 0, si) }
        db := opendb()
        return h_versions(db, req, id)
    }
    if req.method == "POST" && has_prefix(p, "/v1/artifacts/") && has_suffix(p, "/rollback") {
        id := substr(p, 14, len(p))
        si := index(id, "/")
        if si >= 0 { id = substr(id, 0, si) }
        return h_rollback(req, id, parse_int(query(req, "to")))
    }
    if req.method == "DELETE" && has_prefix(p, "/v1/artifacts/") {
        id := substr(p, 14, len(p))
        si := index(id, "/")
        if si >= 0 { id = substr(id, 0, si) }
        return h_delete(req, id)
    }
    if req.method == "GET" && has_prefix(p, "/a/") { return handle_artifact(req, p) }
    res = response("404 Not Found", "text/plain; charset=utf-8", "not found")
}

func cmd_serve(a) {
    port := 8799
    if len(a) >= 3 { port = parse_int(a[2]) }
    say("{\"ok\":true,\"serving\":\"hart\",\"port\":" + str(port) + ",\"routes\":[\"POST /v1/publish\",\"GET /a/<id>[/latest|/v<n>]\",\"GET /v1/artifacts\"]}")
    serve(port, func(req) { return hart_route(req) })
}

// ---- CLI ------------------------------------------------------------------

func flagv(a, name, dflt) (v) {
    v = dflt
    i := 0
    for i < len(a) {
        if a[i] == name { if i + 1 < len(a) { v = a[i+1] } }
        i = i + 1
    }
}

// token store: HART_TOKEN env wins; else ~/.hart-token (written by `hart login`)
func client_token() (t) {
    t = env("HART_TOKEN")
    if t == "" { t = trim(read_file(env("HOME") + "/.hart-token")) }
}
func hart_url() (u) {
    u = env("HART_URL")
    if u == "" { u = "http://127.0.0.1:8799" }
}
func has_flag(a, name) (yes) {
    yes = 0
    i := 0
    for i < len(a) { if a[i] == name { yes = 1 } i = i + 1 }
}

func cmd_publish(a) {
    if len(a) < 3 { die(80, "usage: hart publish <file> [--id <id>] [--title <t>] [--format html|jsx] [--dry-run] [--force]") }
    file := a[2]
    html := read_file(file)
    if html == "" { die(90, "file empty or unreadable: " + file) }
    id := flagv(a, "--id", "")
    title := flagv(a, "--title", "")
    format := flagv(a, "--format", "html")
    url := hart_url() + "/v1/publish?format=" + url_encode(format)
    if id != "" { url = url + "&id=" + url_encode(id) }
    if title != "" { url = url + "&title=" + url_encode(title) }
    if has_flag(a, "--dry-run") == 1 { url = url + "&dry=1" }
    if has_flag(a, "--force") == 1 { url = url + "&force=1" }
    headers := []string{"content-type: text/html; charset=utf-8"}
    tok := client_token()
    if tok != "" { headers = append(headers, "authorization: Bearer " + tok) }
    status, resp, err := http_request("POST", url, headers, html)
    if err != "" { die(100, "cannot reach hart daemon at " + hart_url() + " (is `hart serve` running? set HART_URL): " + err) }
    if status == 401 { die(80, "not authenticated — hart login <token> (or run the daemon with HART_OPEN=1)") }
    if status == 422 { write(1, resp + "\n"); exit(80) }
    if status != 200 { die(100, "publish failed (" + str(status) + "): " + resp) }
    say(resp)
}

func cmd_get(a) {
    if len(a) < 3 { die(80, "usage: hart get <id>  (metadata + versions)") }
    status, resp, err := http_request("GET", hart_url() + "/v1/artifacts/" + a[2] + "/versions", auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "not found (" + str(status) + ")") }
    say(resp)
}

func cmd_rm(a) {
    if len(a) < 3 { die(80, "usage: hart rm <id>") }
    status, resp, err := http_request("DELETE", hart_url() + "/v1/artifacts/" + a[2], auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "delete failed (" + str(status) + "): " + resp) }
    say(resp)
}

func cmd_rollback(a) {
    if len(a) < 4 { die(80, "usage: hart rollback <id> <version>  (re-point latest at an older version)") }
    status, resp, err := http_request("POST", hart_url() + "/v1/artifacts/" + a[2] + "/rollback?to=" + a[3], auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "rollback failed (" + str(status) + "): " + resp) }
    say(resp)
}

func auth_headers() (h) {
    h = []string{}
    tok := client_token()
    if tok != "" { h = append(h, "authorization: Bearer " + tok) }
}

func cmd_login(a) {
    if len(a) < 3 { die(80, "usage: hart login <token>") }
    path := env("HOME") + "/.hart-token"
    write_file(path, a[2])
    say("{\"ok\":true,\"saved\":\"~/.hart-token\"}")
}

// admin (operator-only, direct DB): mint an account + token. Run on the daemon host.
func cmd_grant(a) {
    if len(a) < 3 { die(80, "usage: hart grant <email>") }
    email := a[2]
    db := opendb()
    id := longid()
    tok := longid() + longid()
    sqlite_exec(db, "INSERT OR IGNORE INTO accounts(id,email,created) VALUES(?,?,?)", []string{id, email, str(now())})
    arows := sqlite_query(db, "SELECT id FROM accounts WHERE email = ?", []string{email})
    ar := parse(arows, []ArtRow{})
    aid := id
    if len(ar) > 0 { aid = ar[0].id }
    sqlite_exec(db, "INSERT INTO tokens(token,account_id,created) VALUES(?,?,?)", []string{tok, aid, str(now())})
    sqlite_close(db)
    say("{\"ok\":true,\"email\":\"" + email + "\",\"account_id\":\"" + aid + "\",\"token\":\"" + tok + "\"}")
}

func cmd_list() {
    status, resp, err := http_request("GET", hart_url() + "/v1/artifacts", auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status == 401 { die(80, "not authenticated — hart login <token>") }
    if status != 200 { die(100, "list failed (" + str(status) + ")") }
    say(resp)
}

func cmd_versions(a) {
    if len(a) < 3 { die(80, "usage: hart versions <id>") }
    status, resp, err := http_request("GET", hart_url() + "/v1/artifacts/" + a[2] + "/versions", auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "versions failed (" + str(status) + ")") }
    say(resp)
}

func cmd_help() {
    say("{\"ok\":true,\"name\":\"hart\",\"tagline\":\"agent-first artifact host — publish self-contained HTML, get a versioned sandboxed URL\",\"commands\":{\"serve\":\"serve [port] (daemon; HART_DB, HART_PORT, HART_PUBLIC, HART_OPEN=1 for single-user)\",\"grant\":\"grant <email> (admin, on the daemon host: mint an account+token)\",\"login\":\"login <token> (store creds in ~/.hart-token)\",\"publish\":\"publish <file> [--id <id>] [--title <t>] [--format html|jsx] [--dry-run] [--force] -> {url,version}. Re-publish with --id => next version.\",\"get\":\"get <id> (versions)\",\"list\":\"list (your artifacts)\",\"versions\":\"versions <id>\",\"rollback\":\"rollback <id> <version> (re-point latest at an older version; non-destructive)\",\"rm\":\"rm <id>\"},\"env\":{\"HART_URL\":\"daemon (default http://127.0.0.1:8799)\",\"HART_TOKEN\":\"bearer token (or hart login)\"},\"urls\":{\"latest\":\"/a/<id> or /a/<id>/latest\",\"pinned\":\"/a/<id>/v<n>\"},\"contract\":\"self-contained HTML only — inline CSS/JS, data: URIs; external refs + network are linted (errors block, pass --force)\"}")
}

func main() {
    a := args()
    cmd := ""
    if len(a) >= 2 { cmd = a[1] }
    if cmd == "" || cmd == "help" { cmd_help(); return }
    if cmd == "serve" { cmd_serve(a); return }
    if cmd == "grant" { cmd_grant(a); return }
    if cmd == "login" { cmd_login(a); return }
    if cmd == "publish" { cmd_publish(a); return }
    if cmd == "get" { cmd_get(a); return }
    if cmd == "list" { cmd_list(); return }
    if cmd == "versions" { cmd_versions(a); return }
    if cmd == "rollback" { cmd_rollback(a); return }
    if cmd == "rm" { cmd_rm(a); return }
    write(2, "{\"ok\":false,\"error\":\"unknown command: " + cmd + "\"}\n")
    exit(80)
}
