// hart — the agent-first artifact host. One MFL/machin static binary that is BOTH a hosting
// daemon (`hart serve`) and a CLI (`hart publish <file>` → a live, sandboxed URL). M0 spike:
// prove the loop end to end — publish HTML → stored+versioned in SQLite → served at /a/<id>
// wrapped in a doctype skeleton + a strict CSP, with v1/v2/v3/latest versioning.
//
// Agent-first: JSON on stdout, structured errors on stderr, semantic exit codes.
// Env: HART_URL (publish target, default http://127.0.0.1:8799), HART_DB (default ~/.hart.db),
//      HART_PORT (serve port, default 8799), HART_PUBLIC (public base for returned URLs).

type ArtRow struct { id string  owner string  name string  title string  latest int  data string  created int  updated int }
type VerRow struct { version int  format string  created int }
type HtmlRow struct { html string  format string  title string }
type SumRow struct { s int }
type CntRow struct { n int }

// the strict render sandbox — same envelope idea as Claude artifacts: renders the page while
// neutering it as an exfiltration/attack vector. No external anything; no network.
func csp() (c) {
    c = "default-src 'none'; img-src data: blob:; media-src data: blob:; style-src 'unsafe-inline'; font-src data:; script-src 'unsafe-inline' 'unsafe-eval'; base-uri 'none'; form-action 'none'; frame-ancestors 'self'"
}

// JSX pages additionally load the same-origin runtime (react/babel) — script-src gains 'self'
// for those assets only. Still no external host, still no network.
func csp_jsx() (c) {
    c = "default-src 'none'; img-src data: blob:; media-src data: blob:; style-src 'unsafe-inline'; font-src data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; base-uri 'none'; form-action 'none'; frame-ancestors 'self'"
}

func runtime_dir() (d) {
    d = env("HART_RUNTIME_DIR")
    if d == "" { d = "runtime" }
}

func hdb() (p) {
    p = env("HART_DB")
    if p == "" { p = env("HOME") + "/.hart.db" }
}

func opendb() (db) {
    db = sqlite_open(hdb())
    sqlite_exec(db, "PRAGMA busy_timeout=3000", []string{})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS artifacts(id TEXT PRIMARY KEY, owner TEXT DEFAULT '', name TEXT DEFAULT '', title TEXT, latest INTEGER DEFAULT 0, created INTEGER, updated INTEGER)", []string{})
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN owner TEXT DEFAULT ''", []string{})   // no-op once it exists
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN name TEXT DEFAULT ''", []string{})
    sqlite_exec(db, "ALTER TABLE artifacts ADD COLUMN data TEXT DEFAULT ''", []string{})   // the template's live data (window.HART_DATA + {{key}})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS versions(artifact_id TEXT, version INTEGER, title TEXT, format TEXT, html TEXT, hash TEXT, created INTEGER, PRIMARY KEY(artifact_id, version))", []string{})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS hits(ip TEXT, ts INTEGER)", []string{})   // per-IP submit rate window
}

// ---- abuse limits (customizable; the daemon is otherwise open/free) --------
func max_submits_per_min() (n) {
    n = parse_int(env("HART_MAX_SUBMITS_PER_MIN"))
    if n <= 0 { n = 10 }
}
func max_owner_bytes() (n) {
    mb := parse_int(env("HART_MAX_OWNER_MB"))
    if mb <= 0 { mb = 30 }
    n = mb * 1048576
}

func hart_client_ip(req) (ip) {
    ip = header(req, "x-forwarded-for")
    ci := index(ip, ",")
    if ci >= 0 { ip = trim(substr(ip, 0, ci)) }
    if ip == "" { ip = header(req, "x-real-ip") }
    if ip == "" { ip = "unknown" }
}

// rate_ok — sliding 60s window per IP. Prunes old rows, counts recent, records this hit.
func rate_ok(db, ip) (ok) {
    cut := now() - 60
    sqlite_exec(db, "DELETE FROM hits WHERE ts < ?", []string{str(cut)})
    crows := sqlite_query(db, "SELECT COUNT(*) AS n FROM hits WHERE ip = ? AND ts >= ?", []string{ip, str(cut)})
    cs := parse(crows, []CntRow{})
    if len(cs) > 0 && cs[0].n >= max_submits_per_min() { return 0 }
    sqlite_exec(db, "INSERT INTO hits(ip, ts) VALUES(?,?)", []string{ip, str(now())})
    ok = 1
}

// owner_bytes — total stored HTML bytes for an owner (quota accounting).
func owner_bytes(db, owner) (n) {
    srows := sqlite_query(db, "SELECT COALESCE(SUM(LENGTH(v.html)),0) AS s FROM versions v JOIN artifacts a ON v.artifact_id = a.id WHERE a.owner = ?", []string{owner})
    ss := parse(srows, []SumRow{})
    if len(ss) > 0 { n = ss[0].s }
}

func nid() (s) { s = to_hex(rand_bytes(6)) }

func unq(s) (o) {
    o = s
    n := len(s)
    if n >= 2 { if substr(s, 0, 1) == "\"" { o = substr(s, 1, n - 1) } }
}

// auth: a single OPTIONAL static token, set by the self-hoster. If HART_TOKEN is set on the
// daemon, mutating requests must present it (Bearer); if unset, the service is OPEN (free).
// Ownership is a plain label (--owner), not a secured identity — legible, not access-control.
func check_token(req) (ok) {
    st := env("HART_TOKEN")
    if st == "" { return 1 }
    if header(req, "authorization") == "Bearer " + st { return 1 }
    ok = 0
}

// slugify — a URL-safe artifact name: lowercase, non-alnum runs -> single "-", trimmed.
func slugify(s) (out) {
    lc := to_lower(s)
    out = ""
    prevdash := 1
    i := 0
    for i < len(lc) {
        c := substr(lc, i, i + 1)
        keep := 0
        if c >= "a" && c <= "z" { keep = 1 }
        if c >= "0" && c <= "9" { keep = 1 }
        if keep == 1 {
            out = out + c
            prevdash = 0
        } else {
            if prevdash == 0 { out = out + "-"; prevdash = 1 }
        }
        i = i + 1
    }
    if len(out) > 0 { if substr(out, len(out) - 1, len(out)) == "-" { out = substr(out, 0, len(out) - 1) } }
}

func say(s) { write(1, s + "\n") }
func die(code, msg) { write(2, "{\"ok\":false,\"error\":\"" + msg + "\"}\n"); exit(code) }

// public base for the URLs we hand back. HART_PUBLIC pins the real domain (hosted/proxied);
// otherwise reflect the Host the client actually hit, so returned URLs are always dialable.
func pubbase(req) (b) {
    b = env("HART_PUBLIC")
    if b == "" {
        host := header(req, "host")
        if host == "" { host = "127.0.0.1:8799" }
        b = "http://" + host
    }
}

// ---- daemon ---------------------------------------------------------------

// POST /v1/publish?owner=&artifact=&id=&title=&format=  — raw HTML in the body.
// Address by owner/artifact (legible, stable): id = "<owner>/<slug(artifact)>". Re-publishing
// the same owner+artifact appends the next version. Falls back to a random id if neither given.
func h_publish(req) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"this hart requires a token — hart login <token> (the operator set HART_TOKEN)\"}") }
    owner := slugify(query(req, "owner"))
    artifact := slugify(query(req, "artifact"))
    id := query(req, "id")
    if id == "" && owner != "" && artifact != "" { id = owner + "/" + artifact }
    title := query(req, "title")
    format := query(req, "format")
    if format == "" { format = "html" }
    body := req.body
    if body == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"empty body\"}") }
    // abuse limits: per-IP submit rate + per-owner storage quota (both customizable)
    if rate_ok(db, hart_client_ip(req)) == 0 { sqlite_close(db); return response("429 Too Many Requests", "application/json", "{\"ok\":false,\"error\":\"rate limit: max " + str(max_submits_per_min()) + " submits/min — slow down\"}") }
    if owner_bytes(db, owner) + len(body) > max_owner_bytes() { sqlite_close(db); return response("413 Payload Too Large", "application/json", "{\"ok\":false,\"error\":\"storage quota exceeded for owner '" + owner + "': max " + str(max_owner_bytes() / 1048576) + " MB total\"}") }
    // publish-time safety lint (see lint()); hard violations block unless ?force=1
    report := lint(body)
    if query(req, "dry") == "1" {
        sqlite_close(db)
        blk := "false"
        if lint_blocks(report) == 1 { blk = "true" }
        return ok_json("{\"ok\":true,\"dry_run\":true,\"would_block\":" + blk + ",\"bytes\":" + str(len(body)) + ",\"lint\":" + report + "}")
    }
    if lint_blocks(report) == 1 && query(req, "force") != "1" {
        sqlite_close(db)
        return response("422 Unprocessable Entity", "application/json", "{\"ok\":false,\"error\":\"content-security violations — self-contained pages only; inline assets or pass --force\",\"lint\":" + report + "}")
    }
    n := now()
    ver := 1
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if id != "" && len(ars) > 0 {
        // next version = highest ever + 1 (NOT latest+1 — rollback can move latest backward)
        mrows := sqlite_query(db, "SELECT COALESCE(MAX(version),0) AS m FROM versions WHERE artifact_id = ?", []string{id})
        mraw, _ := json_get(mrows, "[0].m")
        ver = parse_int(mraw) + 1
        sqlite_exec(db, "UPDATE artifacts SET latest = ?, title = COALESCE(NULLIF(?,''), title), updated = ? WHERE id = ?", []string{str(ver), title, str(n), id})
    } else {
        if id == "" { id = nid() }
        sqlite_exec(db, "INSERT INTO artifacts(id, owner, name, title, latest, created, updated) VALUES(?,?,?,?,?,?,?)", []string{id, owner, artifact, title, str(ver), str(n), str(n)})
    }
    hash := to_hex(sha256_bytes(bytes(body)))
    sqlite_exec(db, "INSERT INTO versions(artifact_id, version, title, format, html, hash, created) VALUES(?,?,?,?,?,?,?)", []string{id, str(ver), title, format, body, hash, str(n)})
    sqlite_close(db)
    base := pubbase(req)
    out := "{\"ok\":true,\"id\":\"" + id + "\",\"owner\":\"" + owner + "\",\"artifact\":\"" + artifact + "\",\"version\":" + str(ver) + ",\"format\":\"" + format + "\",\"url\":\"" + base + "/a/" + id + "\",\"latest_url\":\"" + base + "/a/" + id + "/latest\",\"pinned_url\":\"" + base + "/a/" + id + "/v" + str(ver) + "\",\"lint\":" + report + "}"
    res = ok_json(out)
}

// POST /v1/data?owner=&artifact=&id=  — JSON body = the artifact's live data. Updates the data
// slot (a mutable pointer, not a version) so an agent can refresh an artifact's content without
// re-pushing the template. The template reads it via window.HART_DATA and/or {{key}}.
func h_data(req) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    if rate_ok(db, hart_client_ip(req)) == 0 { sqlite_close(db); return response("429 Too Many Requests", "application/json", "{\"ok\":false,\"error\":\"rate limit\"}") }
    owner := slugify(query(req, "owner"))
    artifact := slugify(query(req, "artifact"))
    id := query(req, "id")
    if id == "" && owner != "" && artifact != "" { id = owner + "/" + artifact }
    if id == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"need --id or --owner+--artifact\"}") }
    body := req.body
    if body == "" { sqlite_close(db); return response("400 Bad Request", "application/json", "{\"ok\":false,\"error\":\"empty data body\"}") }
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"no such artifact — publish the template first\"}") }
    sqlite_exec(db, "UPDATE artifacts SET data = ?, updated = ? WHERE id = ?", []string{body, str(now()), id})
    sqlite_close(db)
    base := pubbase(req)
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"data_bytes\":" + str(len(body)) + ",\"url\":\"" + base + "/a/" + id + "\"}")
}

func h_list(req) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    owner := slugify(query(req, "owner"))
    rows := ""
    if owner != "" {
        rows = sqlite_query(db, "SELECT id, owner, name, title, latest, updated FROM artifacts WHERE owner = ? ORDER BY updated DESC LIMIT 500", []string{owner})
    } else {
        rows = sqlite_query(db, "SELECT id, owner, name, title, latest, updated FROM artifacts ORDER BY updated DESC LIMIT 500", []string{})
    }
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"artifacts\":" + rows + "}")
}

func h_versions(db, req, id) (res) {
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    orows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, created, updated FROM artifacts WHERE id = ?", []string{id})
    oa := parse(orows, []ArtRow{})
    if len(oa) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    rows := sqlite_query(db, "SELECT version, format, created FROM versions WHERE artifact_id = ? ORDER BY version DESC", []string{id})
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"owner\":\"" + oa[0].owner + "\",\"name\":\"" + oa[0].name + "\",\"versions\":" + rows + "}")
}

// h_delete — remove an artifact + all versions.
func h_delete(req, id) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    orows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, created, updated FROM artifacts WHERE id = ?", []string{id})
    oa := parse(orows, []ArtRow{})
    if len(oa) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    sqlite_exec(db, "DELETE FROM versions WHERE artifact_id = ?", []string{id})
    sqlite_exec(db, "DELETE FROM artifacts WHERE id = ?", []string{id})
    sqlite_close(db)
    res = ok_json("{\"ok\":true,\"deleted\":\"" + id + "\"}")
}

// h_rollback — re-point `latest` at an existing older version. Non-destructive: versions stay
// immutable; publishing afterwards still appends MAX+1.
func h_rollback(req, id, target) (res) {
    db := opendb()
    if check_token(req) == 0 { sqlite_close(db); return response("401 Unauthorized", "application/json", "{\"ok\":false,\"error\":\"token required\"}") }
    orows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, created, updated FROM artifacts WHERE id = ?", []string{id})
    oa := parse(orows, []ArtRow{})
    if len(oa) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"not found\"}") }
    vrows := sqlite_query(db, "SELECT version, format, created FROM versions WHERE artifact_id = ? AND version = ?", []string{id, str(target)})
    vs := parse(vrows, []VerRow{})
    if len(vs) == 0 { sqlite_close(db); return response("404 Not Found", "application/json", "{\"ok\":false,\"error\":\"no such version — see hart versions <id>\"}") }
    sqlite_exec(db, "UPDATE artifacts SET latest = ?, updated = ? WHERE id = ?", []string{str(target), str(now()), id})
    sqlite_close(db)
    base := pubbase(req)
    res = ok_json("{\"ok\":true,\"id\":\"" + id + "\",\"latest\":" + str(target) + ",\"url\":\"" + base + "/a/" + id + "\"}")
}

// ---- the publish contract linter ------------------------------------------
// hart hosts SELF-CONTAINED pages. lint() flags anything that reaches off-page: external
// script/style/img/font, @import, and network calls. Hard violations (external <script src>,
// fetch/XHR/WebSocket) block publish unless forced; soft ones (external img/font) warn.
// Returns a JSON array of {level,rule,note}. Cheap substring scan on a lowercased copy.
func lint_find(lc, needle, level, rule, note, acc) (out, blocked) {
    out = acc
    blocked = 0
    if index(lc, needle) >= 0 {
        if acc != "[" { out = acc + "," }
        out = out + "{\"level\":\"" + level + "\",\"rule\":\"" + rule + "\",\"note\":\"" + note + "\"}"
        if level == "error" { blocked = 1 }
    }
}

func lint(html) (report) {
    lc := to_lower(html)
    r := "["
    b := 0
    r2, b2 := lint_find(lc, "<script src=\"http", "error", "external-script", "external <script src> — inline the JS", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "<script src='http", "error", "external-script", "external <script src> — inline the JS", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "fetch(", "error", "network-fetch", "fetch() call — artifacts are offline; connect-src is 'none'", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "xmlhttprequest", "error", "network-xhr", "XMLHttpRequest — no network in the sandbox", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "new websocket", "error", "network-ws", "WebSocket — no network in the sandbox", r)
    r = r2; if b2 == 1 { b = 1 }
    r2, b2 = lint_find(lc, "rel=\"stylesheet\" href=\"http", "warn", "external-css", "external stylesheet — inline the CSS", r)
    r = r2
    r2, b2 = lint_find(lc, "@import url(http", "warn", "external-import", "@import from a URL — inline the CSS", r)
    r = r2
    r2, b2 = lint_find(lc, "src=\"http", "warn", "external-asset", "external asset src — embed as a data: URI", r)
    r = r2
    report = r + "]"
}

func lint_blocks(report) (n) {
    n = 0
    if index(report, "\"level\":\"error\"") >= 0 { n = 1 }
}

// apply_template — replace {{key}} placeholders in the HTML with top-level values from the
// artifact's data JSON. Bounded loop; unknown keys become empty.
func apply_template(html, data) (out) {
    out = html
    if data == "" { return out }
    guard := 0
    for guard < 500 {
        st := index(out, "{{")
        if st < 0 { return out }
        rel := index(substr(out, st, len(out)), "}}")
        if rel < 0 { return out }
        en := st + rel
        key := trim(substr(out, st + 2, en))
        rep := ""
        val, err := json_get(data, "." + key)
        if err == "" { rep = unq(val) }
        out = substr(out, 0, st) + rep + substr(out, en + 2, len(out))
        guard = guard + 1
    }
}

// data_script — inject the live data as a JS global so templates (charts, JSX, anything) read
// window.HART_DATA. Empty data -> {}.
func data_script(data) (s) {
    d := data
    if d == "" { d = "{}" }
    s = "<script>window.HART_DATA=" + d + ";</script>"
}

// wrap stored content in a minimal doctype skeleton (the content itself carries inline
// <title>/<style>/<script>, artifact-style) and serve under the strict CSP. Data is applied
// two ways: {{key}} substitution in the markup + a window.HART_DATA global for scripts.
func render_page(html, title, data) (page) {
    t := title
    if t == "" { t = "hart artifact" }
    b := apply_template(html, data)
    page = "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>" + t + "</title>" + data_script(data) + "</head><body>" + b + "</body></html>"
}

// JSX: load the same-origin React + Babel runtime, then transform the agent's JSX with the
// CLASSIC runtime (emits React.createElement — no `import` of jsx-runtime, which would fail
// outside a module) and eval it. React/ReactDOM are globals; the agent renders into #root.
func render_page_jsx(jsx, title, data) (page) {
    t := title
    if t == "" { t = "hart artifact" }
    src := replace(jsx, "</script>", "<\\/script>")   // don't let the source close its host tag
    head := "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>" + t + "</title>" + data_script(data)
    rt := "<script src=\"/_hart/runtime/react.js\"></script><script src=\"/_hart/runtime/react-dom.js\"></script><script src=\"/_hart/runtime/babel.js\"></script></head>"
    boot := "<script>(function(){try{var s=document.getElementById('__hart_jsx').textContent;var o=Babel.transform(s,{presets:[['react',{runtime:'classic'}]]}).code;(0,eval)(o);}catch(e){document.getElementById('root').innerHTML='<pre style=\"color:#b00020;padding:24px;font:14px ui-monospace,monospace;white-space:pre-wrap\">hart: JSX error\\n\\n'+((e&&e.message)?e.message:e)+'</pre>';}})();</script>"
    body := "<body><div id=\"root\"></div><script type=\"text/plain\" id=\"__hart_jsx\">\n" + src + "\n</script>" + boot + "</body></html>"
    page = head + rt + body
}

// serve a same-origin runtime asset (react/react-dom/babel) from disk. Path-safe (no traversal).
func serve_runtime(fname) (res) {
    if index(fname, "..") >= 0 || index(fname, "/") >= 0 { return response("400 Bad Request", "text/plain", "bad path") }
    body := read_file(runtime_dir() + "/" + fname)
    if body == "" { return response("404 Not Found", "text/plain; charset=utf-8", "runtime asset not found — deploy the hart runtime dir") }
    r := response("200 OK", "application/javascript; charset=utf-8", body)
    r = with_header(r, "Cache-Control", "public, max-age=31536000, immutable")
    res = r
}

func serve_artifact(db, id, ver) (res) {
    arows := sqlite_query(db, "SELECT id, owner, name, title, latest, data, created, updated FROM artifacts WHERE id = ?", []string{id})
    ars := parse(arows, []ArtRow{})
    if len(ars) == 0 { sqlite_close(db); return response("404 Not Found", "text/plain; charset=utf-8", "artifact not found") }
    v := ver
    if v == 0 { v = ars[0].latest }
    data := ars[0].data
    hrows := sqlite_query(db, "SELECT html, format, title FROM versions WHERE artifact_id = ? AND version = ?", []string{id, str(v)})
    sqlite_close(db)
    hs := parse(hrows, []HtmlRow{})
    if len(hs) == 0 { return response("404 Not Found", "text/plain; charset=utf-8", "version not found") }
    page := render_page(hs[0].html, hs[0].title, data)
    ct := csp()
    if hs[0].format == "jsx" { page = render_page_jsx(hs[0].html, hs[0].title, data); ct = csp_jsx() }
    r := ok_html(page)
    r = with_header(r, "Content-Security-Policy", ct)
    r = with_header(r, "X-Content-Type-Options", "nosniff")
    r = with_header(r, "X-Frame-Options", "SAMEORIGIN")
    r = with_header(r, "Referrer-Policy", "no-referrer")
    res = r
}

// is_version_seg — a trailing path segment that pins a version: "latest" or "v<digits>".
func is_version_seg(seg) (yes) {
    yes = 0
    if seg == "latest" { return 1 }
    if len(seg) >= 2 { if substr(seg, 0, 1) == "v" {
        rest := substr(seg, 1, len(seg))
        alld := 1
        i := 0
        for i < len(rest) { c := substr(rest, i, i + 1); if c < "0" || c > "9" { alld = 0 } i = i + 1 }
        yes = alld
    } }
}

// parse /a/<id>, /a/<owner>/<artifact>, plus an optional trailing /latest or /v<n>.
// The id is everything before a trailing version segment (so owner/artifact ids keep their slash).
func handle_artifact(req, p) (res) {
    rest := substr(p, 3, len(p))   // strip "/a/"
    if rest == "" { return response("404 Not Found", "text/plain", "no id") }
    parts := split(rest, "/")
    ver := 0
    idcount := len(parts)
    last := parts[len(parts) - 1]
    if len(parts) > 1 && is_version_seg(last) == 1 {
        if last != "latest" { ver = parse_int(substr(last, 1, len(last))) }
        idcount = len(parts) - 1
    }
    id := ""
    i := 0
    for i < idcount { if id != "" { id = id + "/" } id = id + parts[i] i = i + 1 }
    if id == "" { return response("404 Not Found", "text/plain", "no id") }
    db := opendb()
    res = serve_artifact(db, id, ver)
}

// the root page — the product landing (OSS, self-hosted). Served from HART_LANDING (default
// ./landing.html); falls back to a one-line notice if the file isn't deployed.
func serve_landing() (res) {
    path := env("HART_LANDING")
    if path == "" { path = "landing.html" }
    body := read_file(path)
    if body == "" { body = "<!doctype html><meta charset=utf-8><title>hart</title><body style=\"font:16px system-ui;max-width:40em;margin:12vh auto;padding:0 6vw\"><h1>hart</h1><p>The agent-first artifact host. Source: github.com/javimosch/machin-hart</p>" }
    r := ok_html(body)
    r = with_header(r, "Content-Security-Policy", "default-src 'none'; style-src 'unsafe-inline'; img-src data:; font-src data:")
    res = r
}

func hart_route(req) (res) {
    p := req.path
    qi := index(p, "?")
    if qi >= 0 { p = substr(p, 0, qi) }
    if p == "/" { return serve_landing() }
    if p == "/_health" { return ok_json("{\"ok\":true,\"service\":\"hart\"}") }
    if req.method == "GET" && has_prefix(p, "/_hart/runtime/") { return serve_runtime(substr(p, 15, len(p))) }
    if req.method == "POST" && p == "/v1/publish" { return h_publish(req) }
    if req.method == "POST" && p == "/v1/data" { return h_data(req) }
    if req.method == "GET" && p == "/v1/artifacts" { return h_list(req) }
    if has_prefix(p, "/v1/artifacts/") {
        tail := substr(p, 14, len(p))   // the id (may contain "/") + optional /versions|/rollback
        if req.method == "GET" && has_suffix(tail, "/versions") {
            db := opendb(); return h_versions(db, req, substr(tail, 0, len(tail) - 9))
        }
        if req.method == "POST" && has_suffix(tail, "/rollback") {
            return h_rollback(req, substr(tail, 0, len(tail) - 9), parse_int(query(req, "to")))
        }
        if req.method == "DELETE" { return h_delete(req, tail) }
        if req.method == "GET" { db := opendb(); return h_versions(db, req, tail) }
    }
    if req.method == "GET" && has_prefix(p, "/a/") { return handle_artifact(req, p) }
    res = response("404 Not Found", "text/plain; charset=utf-8", "not found")
}

func cmd_serve(a) {
    port := 8799
    if len(a) >= 3 { port = parse_int(a[2]) }
    say("{\"ok\":true,\"serving\":\"hart\",\"port\":" + str(port) + ",\"routes\":[\"POST /v1/publish\",\"GET /a/<id>[/latest|/v<n>]\",\"GET /v1/artifacts\"]}")
    serve(port, func(req) { return hart_route(req) })
}

// ---- CLI ------------------------------------------------------------------

func flagv(a, name, dflt) (v) {
    v = dflt
    i := 0
    for i < len(a) {
        if a[i] == name { if i + 1 < len(a) { v = a[i+1] } }
        i = i + 1
    }
}

// token store: HART_TOKEN env wins; else ~/.hart-token (written by `hart login`)
func client_token() (t) {
    t = env("HART_TOKEN")
    if t == "" { t = trim(read_file(env("HOME") + "/.hart-token")) }
}
func hart_url() (u) {
    u = env("HART_URL")
    if u == "" { u = "http://127.0.0.1:8799" }
}
func has_flag(a, name) (yes) {
    yes = 0
    i := 0
    for i < len(a) { if a[i] == name { yes = 1 } i = i + 1 }
}

func cmd_publish(a) {
    if len(a) < 3 { die(80, "usage: hart publish <file> [--owner <who>] [--artifact <name>] [--title <t>] [--format html|jsx] [--id <id>] [--dry-run] [--force]") }
    file := a[2]
    html := read_file(file)
    if html == "" { die(90, "file empty or unreadable: " + file) }
    id := flagv(a, "--id", "")
    owner := flagv(a, "--owner", "")
    artifact := flagv(a, "--artifact", "")
    title := flagv(a, "--title", "")
    format := flagv(a, "--format", "html")
    url := hart_url() + "/v1/publish?format=" + url_encode(format)
    if id != "" { url = url + "&id=" + url_encode(id) }
    if owner != "" { url = url + "&owner=" + url_encode(owner) }
    if artifact != "" { url = url + "&artifact=" + url_encode(artifact) }
    if title != "" { url = url + "&title=" + url_encode(title) }
    if has_flag(a, "--dry-run") == 1 { url = url + "&dry=1" }
    if has_flag(a, "--force") == 1 { url = url + "&force=1" }
    headers := []string{"content-type: text/html; charset=utf-8"}
    tok := client_token()
    if tok != "" { headers = append(headers, "authorization: Bearer " + tok) }
    status, resp, err := http_request("POST", url, headers, html)
    if err != "" { die(100, "cannot reach hart daemon at " + hart_url() + " (is `hart serve` running? set HART_URL): " + err) }
    if status == 401 { die(80, "not authenticated — hart login <token> (or run the daemon with HART_OPEN=1)") }
    if status == 422 { write(1, resp + "\n"); exit(80) }
    if status != 200 { die(100, "publish failed (" + str(status) + "): " + resp) }
    say(resp)
}

func cmd_get(a) {
    if len(a) < 3 { die(80, "usage: hart get <id>  (metadata + versions)") }
    status, resp, err := http_request("GET", hart_url() + "/v1/artifacts/" + a[2] + "/versions", auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "not found (" + str(status) + ")") }
    say(resp)
}

func cmd_rm(a) {
    if len(a) < 3 { die(80, "usage: hart rm <id>") }
    status, resp, err := http_request("DELETE", hart_url() + "/v1/artifacts/" + a[2], auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "delete failed (" + str(status) + "): " + resp) }
    say(resp)
}

// hart data <id> '<json>'   |   hart data --owner X --artifact Y '<json>'
// updates the artifact's live data (the template re-renders with it).
func cmd_data(a) {
    if len(a) < 3 { die(80, "usage: hart data <id> '<json>'  |  hart data --owner <who> --artifact <name> '<json>'") }
    owner := flagv(a, "--owner", "")
    artifact := flagv(a, "--artifact", "")
    id := flagv(a, "--id", "")
    json := a[len(a) - 1]
    url := hart_url() + "/v1/data?x=1"
    if id != "" { url = url + "&id=" + url_encode(id) } else {
        if owner != "" && artifact != "" { url = url + "&owner=" + url_encode(owner) + "&artifact=" + url_encode(artifact) } else { url = url + "&id=" + url_encode(a[2]) }
    }
    headers := []string{"content-type: application/json"}
    tok := client_token()
    if tok != "" { headers = append(headers, "authorization: Bearer " + tok) }
    status, resp, err := http_request("POST", url, headers, json)
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status == 404 { die(90, "no such artifact — publish the template first") }
    if status != 200 { die(100, "data update failed (" + str(status) + "): " + resp) }
    say(resp)
}

func cmd_rollback(a) {
    if len(a) < 4 { die(80, "usage: hart rollback <id> <version>  (re-point latest at an older version)") }
    status, resp, err := http_request("POST", hart_url() + "/v1/artifacts/" + a[2] + "/rollback?to=" + a[3], auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "rollback failed (" + str(status) + "): " + resp) }
    say(resp)
}

func auth_headers() (h) {
    h = []string{}
    tok := client_token()
    if tok != "" { h = append(h, "authorization: Bearer " + tok) }
}

func cmd_login(a) {
    if len(a) < 3 { die(80, "usage: hart login <token>") }
    path := env("HOME") + "/.hart-token"
    write_file(path, a[2])
    say("{\"ok\":true,\"saved\":\"~/.hart-token\"}")
}

func cmd_list(a) {
    url := hart_url() + "/v1/artifacts"
    owner := flagv(a, "--owner", "")
    if owner != "" { url = url + "?owner=" + url_encode(owner) }
    status, resp, err := http_request("GET", url, auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status == 401 { die(80, "not authenticated — hart login <token>") }
    if status != 200 { die(100, "list failed (" + str(status) + ")") }
    say(resp)
}

func cmd_versions(a) {
    if len(a) < 3 { die(80, "usage: hart versions <id>") }
    status, resp, err := http_request("GET", hart_url() + "/v1/artifacts/" + a[2] + "/versions", auth_headers(), "")
    if err != "" { die(100, "cannot reach hart daemon: " + err) }
    if status != 200 { die(90, "versions failed (" + str(status) + ")") }
    say(resp)
}

func cmd_help() {
    say("{\"ok\":true,\"name\":\"hart\",\"tagline\":\"agent-first artifact host — publish self-contained HTML or JSX, get a versioned sandboxed URL\",\"commands\":{\"serve\":\"serve [port] (daemon; HART_DB, HART_RUNTIME_DIR, HART_PUBLIC; HART_TOKEN set => publish requires that token, unset => open/free)\",\"login\":\"login <token> (store creds in ~/.hart-token)\",\"publish\":\"publish <file> [--owner <who>] [--artifact <name>] [--title <t>] [--format html|jsx] [--dry-run] [--force] -> {id,url,version}. owner+artifact => stable id owner/artifact; re-publish => next version.\",\"get\":\"get <id> (versions)\",\"list\":\"list [--owner <who>]\",\"versions\":\"versions <id>\",\"rollback\":\"rollback <id> <version> (re-point latest; non-destructive)\",\"rm\":\"rm <id>\"},\"env\":{\"HART_URL\":\"daemon (default http://127.0.0.1:8799)\",\"HART_TOKEN\":\"static token (client sends it; server requires it if set)\"},\"urls\":{\"latest\":\"/a/<owner>/<artifact> or /a/<id> (+ /latest)\",\"pinned\":\"/a/<owner>/<artifact>/v<n>\"},\"contract\":\"self-contained HTML/JSX only — inline CSS/JS, data: URIs; external refs + network are linted (errors block, pass --force)\"}")
}

func main() {
    a := args()
    cmd := ""
    if len(a) >= 2 { cmd = a[1] }
    if cmd == "" || cmd == "help" { cmd_help(); return }
    if cmd == "serve" { cmd_serve(a); return }
    if cmd == "login" { cmd_login(a); return }
    if cmd == "publish" { cmd_publish(a); return }
    if cmd == "data" { cmd_data(a); return }
    if cmd == "get" { cmd_get(a); return }
    if cmd == "list" { cmd_list(a); return }
    if cmd == "versions" { cmd_versions(a); return }
    if cmd == "rollback" { cmd_rollback(a); return }
    if cmd == "rm" { cmd_rm(a); return }
    write(2, "{\"ok\":false,\"error\":\"unknown command: " + cmd + "\"}\n")
    exit(80)
}
