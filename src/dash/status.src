// status.src — the operational INSTANCE-HOME dashboard for a running hart.
// Served at /_status (and optionally /). Unlike the marketing landing (now on
// GitHub Pages), this answers "you are on a running hart — here is how to use
// THIS instance, and what it hosts." Server-rendered from the daemon's own DB,
// styled with vendored machin-web-ui components (teal theme, dash_css()).

func dash_page(inner) (h) {
    h = "<!doctype html><html lang=en class=dark><head><meta charset=utf-8>"
    h = h + "<meta name=viewport content=\"width=device-width,initial-scale=1\">"
    h = h + "<title>hart - instance status</title><style>" + dash_css() + "</style></head>"
    h = h + "<body class=\"" + ui_page_classes() + "\">"
    h = h + "<main class=\"" + ui_main_classes() + "\">" + inner + "</main></body></html>"
}

func dash_count(db, sql) (n) {
    rows := sqlite_query(db, sql, []string{})
    cs := parse(rows, []CntRow{})
    n = 0
    if len(cs) > 0 { n = cs[0].n }
}

func dash_bytes(db) (b) {
    rows := sqlite_query(db, "SELECT COALESCE(SUM(LENGTH(html)),0) AS s FROM versions", []string{})
    ss := parse(rows, []SumRow{})
    b = 0
    if len(ss) > 0 { b = ss[0].s }
}

func dash_hsize(n) (s) {
    if n < 1024 { s = str(n) + " B"  return }
    if n < 1048576 { s = str(n / 1024) + " KB"  return }
    s = str(n / 1048576) + " MB"
}

func serve_status(req) (res) {
    db := opendb()
    base := pubbase(req)
    nart := dash_count(db, "SELECT COUNT(*) AS n FROM artifacts")
    nver := dash_count(db, "SELECT COUNT(*) AS n FROM versions")
    nown := dash_count(db, "SELECT COUNT(DISTINCT owner) AS n FROM artifacts WHERE owner != ''")
    bytes := dash_bytes(db)
    listrows := sqlite_query(db, "SELECT id, owner, name, title, visibility, updated FROM artifacts WHERE visibility = 'public' ORDER BY updated DESC LIMIT 12", []string{})
    arts := parse(listrows, []ListRow{})
    sqlite_close(db)

    // header
    h := "<header class=\"flex flex-wrap items-center justify-between gap-3\">"
    h = h + "<div class=\"flex items-center gap-3\"><h1 class=\"text-xl font-semibold tracking-tight\">hart</h1>"
    h = h + ui_badge("instance", "info") + "</div>"
    h = h + "<a class=\"text-sm text-muted hover:text-ink underline-offset-4 hover:underline\" href=\"" + base + "/explore\">explore &rarr;</a>"
    h = h + "</header>"
    h = h + "<p class=\"text-sm leading-6 text-muted\">You are on a running hart at <span class=\"text-ink\">" + ui_esc(base) + "</span> &mdash; the agent-first artifact host. Publish a self-contained HTML page and get a live, sandboxed URL back.</p>"

    // stats
    stats := "<div class=\"grid grid-cols-2 gap-3 md:grid-cols-4\">"
    stats = stats + ui_stat("artifacts", str(nart), "hosted here")
    stats = stats + ui_stat("versions", str(nver), "immutable, pinned")
    stats = stats + ui_stat("owners", str(nown), "namespaces")
    stats = stats + ui_stat("stored", dash_hsize(bytes), "rendered HTML")
    stats = stats + "</div>"
    h = h + stats

    // publish-to-this-instance
    pub := ui_code_block("publish to this instance", "export HART_URL=" + base + "\nhart publish page.html --owner you --artifact my-page\n# -> " + base + "/a/you/my-page")
    h = h + ui_card("Publish here", "<div class=\"flex flex-col gap-3\"><p class=\"text-sm text-muted\">One POST; the page is the body. Or drive it with the CLI:</p>" + pub + "<p class=\"text-xs text-muted\">Full contract: <a class=\"text-accent hover:underline\" href=\"" + base + "/guide\">/guide</a> &middot; <a class=\"text-accent hover:underline\" href=\"" + base + "/llms.txt\">/llms.txt</a></p></div>")

    // connect an agent: install one-liner, MCP config, drop-in skill
    setup := "<div class=\"flex flex-col gap-3\">"
    setup = setup + "<p class=\"text-sm text-muted\">Install the CLI, pre-pointed at this instance:</p>"
    setup = setup + ui_code_block("install", "curl -fsSL " + base + "/install.sh | sh")
    setup = setup + "<p class=\"text-sm text-muted\">Or wire hart into an <span class=\"text-ink\">MCP</span>-native agent (Claude Desktop, Cursor, &hellip;) as native tools &mdash; add to your MCP client config:</p>"
    setup = setup + ui_code_block("mcp client config", "{\"mcpServers\":{\"hart\":{\"command\":\"hart\",\"args\":[\"mcp\"],\"env\":{\"HART_URL\":\"" + base + "\"}}}}")
    setup = setup + "<p class=\"text-xs text-muted\">Tools: <code class=\"rounded bg-surface-100 dark:bg-surface-800 px-1 py-0.5 text-ink dark:text-ink-100\">hart_publish · hart_data · hart_list · hart_get · hart_stats · hart_stale · hart_explore</code> &middot; <a class=\"text-accent hover:underline\" href=\"" + base + "/guide.md#mcp\">MCP setup &rarr;</a></p>"
    setup = setup + "<p class=\"text-sm text-muted\">Make any terminal agent publish here by default &mdash; self-install the drop-in skill:</p>"
    setup = setup + ui_code_block("agent skill", "hart skill > ~/.claude/skills/hart/SKILL.md")
    setup = setup + "</div>"
    h = h + ui_card("Connect an agent", setup)

    // public artifacts table
    if len(arts) > 0 {
        rows := []string{}
        for _, a := range arts {
            title := a.title
            if title == "" { title = a.id }
            cells := ui_td("<a class=\"text-accent hover:underline\" href=\"" + base + "/a/" + a.id + "\">" + ui_esc(title) + "</a>")
            cells = cells + ui_td("<span class=\"text-muted\">" + ui_esc(a.owner) + "</span>")
            cells = cells + ui_td("<span class=\"text-muted\">" + time_format(a.updated, "%Y-%m-%d") + "</span>")
            rows = append(rows, ui_tr(cells))
        }
        h = h + ui_card("Public artifacts", ui_table([]string{"artifact", "owner", "updated"}, rows))
    } else {
        h = h + ui_card("Public artifacts", "<p class=\"text-sm text-muted\">Nothing public yet. Published artifacts are unlisted by default; set visibility to <code class=\"rounded bg-surface-100 dark:bg-surface-800 px-1 py-0.5 text-ink dark:text-ink-100\">public</code> to list them here.</p>")
    }

    // limits + safety
    hard := "off (set HART_PUBLIC or HART_HARDEN=1 for production)"
    if hardening_active() == 1 { hard = "on — body cap, access log, read timeout (see /byok.md)" }
    lim := ui_list_group([]string{
        "sandbox", "strict CSP - no external scripts, no network",
        "versions", "immutable, hash-addressed, instant rollback",
        "rate limit", "per-IP submit cap (HART_MAX_SUBMITS_PER_MIN)",
        "namespace size", "per-owner cap (HART_MAX_OWNER_MB)",
        "production hardening", hard})
    h = h + ui_card("Limits and safety", lim)

    h = h + ui_footer("hart - one self-hosted binary. This is the instance status page.",
        []string{"guide", "BYOK", "llms.txt", "GitHub"},
        []string{base + "/guide", base + "/byok.md", base + "/llms.txt", "https://github.com/javimosch/machin-hart"})

    r := ok_html(dash_page(h))
    r = with_header(r, "Content-Security-Policy", "default-src 'none'; style-src 'unsafe-inline'; img-src data:; font-src data:")
    res = r
}

// ---- operator dashboard (/_fleet) -----------------------------------------
// An admin-gated visual fleet cockpit: every owner + artifact (incl. unlisted/
// private), views, freshness, and stale living-deliverables flagged. Auth is a
// signed cookie holding the admin-token hash (rotating HART_ADMIN_TOKEN logs out
// old cookies), set by posting the token to /_fleet/login. Renders the same data
// the admin/stats/stale APIs return, server-side (nothing leaves the box).

func admin_cookie() (n) { n = "hart_admin" }

// set_admin_session — like set_session but SameSite=Strict (the admin cookie must never ride a
// cross-site request — no CSRF logout, no cross-site send). Secure when served over HTTPS.
func set_admin_session(r, value) (out) {
    sec := ""
    if pubbase_over_https() == 1 { sec = "; Secure" }
    r.cookies = append(r.cookies, admin_cookie() + "=" + session_sign(cookie_secret(), value) + "; Path=/; HttpOnly; SameSite=Strict" + sec)
    out = r
}

// no_frame — anti-clickjacking headers for the operator pages: an artifact page (same origin!)
// must not be able to frame the dashboard and clickjack the operator.
func no_frame(r) (out) {
    out = with_header(r, "X-Frame-Options", "DENY")
}

// admin_authed — 1 if the request carries a valid admin session cookie.
func admin_authed(req) (ok) {
    at := env("HART_ADMIN_TOKEN")
    if at == "" { return 0 }
    v, vok := get_session(req, cookie_secret(), admin_cookie())
    if vok == 1 && v == to_hex(sha256_bytes(bytes(at))) { return 1 }
    ok = 0
}

func fleet_login_page(errmsg) (res) {
    em := ""
    if errmsg != "" { em = "<p class=\"mt-3 text-xs text-danger-400\">" + ui_esc(errmsg) + "</p>" }
    inner := "<div class=\"mx-auto max-w-sm\">"
    inner = inner + "<header class=\"mb-4 flex items-center gap-3\"><h1 class=\"text-xl font-semibold tracking-tight\">hart</h1>" + ui_badge("operator", "blue") + "</header>"
    inner = inner + ui_card("Operator sign-in", "<form method=\"POST\" action=\"/_fleet/login\" class=\"flex flex-col gap-3\"><p class=\"text-sm text-muted\">Enter the instance admin token (<code class=\"rounded bg-surface-100 dark:bg-surface-800 px-1 py-0.5 text-ink dark:text-ink-100\">HART_ADMIN_TOKEN</code>) to view the fleet.</p><input type=\"password\" name=\"token\" placeholder=\"admin token\" autofocus autocomplete=\"current-password\" class=\"w-full rounded-lg border border-surface-300 dark:border-surface-700 bg-surface-50 dark:bg-surface-900 px-3 py-2 text-sm text-ink\"><button type=\"submit\" class=\"rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white\">View fleet</button>" + em + "</form>")
    inner = inner + "</div>"
    r := response("401 Unauthorized", "text/html; charset=utf-8", dash_page(inner))
    r = with_header(r, "Content-Security-Policy", "default-src 'none'; style-src 'unsafe-inline'; img-src data:; font-src data:; form-action 'self'; frame-ancestors 'none'")
    r = with_header(r, "Cache-Control", "no-store")
    r = no_frame(r)
    res = r
}

func h_fleet_login(req) (res) {
    at := env("HART_ADMIN_TOKEN")
    if at == "" { return response("404 Not Found", "text/plain; charset=utf-8", "operator dashboard disabled (set HART_ADMIN_TOKEN)") }
    if query_form(req, "token") != at { return fleet_login_page("Wrong admin token.") }
    r := response("303 See Other", "text/html; charset=utf-8", "")
    r = with_header(r, "Location", "/_fleet")
    r = set_admin_session(r, to_hex(sha256_bytes(bytes(at))))
    res = r
}

func h_fleet_logout(req) (res) {
    r := response("303 See Other", "text/html; charset=utf-8", "")
    r = with_header(r, "Location", "/_fleet")
    r = set_admin_session(r, "")   // value can't match the token hash -> deauthed
    res = r
}

// vis_badge — a colored visibility pill.
func vis_badge(v) (h) {
    k := "neutral"
    if v == "public" { k = "green" }
    if v == "private" { k = "blue" }
    h = ui_badge(v, k)
}

func serve_fleet(req) (res) {
    if env("HART_ADMIN_TOKEN") == "" { return response("404 Not Found", "text/plain; charset=utf-8", "operator dashboard disabled (set HART_ADMIN_TOKEN)") }
    if admin_authed(req) == 0 { return fleet_login_page("") }
    db := opendb()
    base := pubbase(req)
    n := now()
    nart := dash_count(db, "SELECT COUNT(*) AS n FROM artifacts")
    nown := dash_count(db, "SELECT COUNT(DISTINCT owner) AS n FROM artifacts WHERE owner != ''")
    nviews := dash_count(db, "SELECT COALESCE(SUM(total),0) AS n FROM views")
    nstale := dash_count(db, "SELECT COUNT(*) AS n FROM artifacts WHERE fresh_ttl > 0 AND (" + str(n) + " - updated) > fresh_ttl")
    // 7-day adoption counts (computed while the db is open — serve_fleet closes it below)
    cut7 := str(n - 604800)
    d_own := dash_count(db, "SELECT COUNT(*) AS n FROM (SELECT owner FROM artifacts WHERE owner != '' GROUP BY owner HAVING MIN(created) > " + cut7 + ")")
    d_art := dash_count(db, "SELECT COUNT(*) AS n FROM artifacts WHERE created > " + cut7)
    d_act := dash_count(db, "SELECT COUNT(*) AS n FROM artifacts WHERE updated > " + cut7)
    bytes := dash_bytes(db)
    ownrows := sqlite_query(db, "SELECT a.owner AS owner, COUNT(DISTINCT a.id) AS cnt, MAX(a.updated) AS updated, COALESCE(SUM(LENGTH(v.html)),0) AS bytes, CASE WHEN o.key_hash IS NOT NULL AND o.key_hash != '' THEN 1 ELSE 0 END AS has_key FROM artifacts a LEFT JOIN versions v ON v.artifact_id = a.id LEFT JOIN owners o ON o.owner = a.owner GROUP BY a.owner ORDER BY bytes DESC", []string{})
    owns := parse(ownrows, []AdmOwn{})
    artrows := sqlite_query(db, "SELECT a.id AS id, a.owner AS owner, a.name AS name, a.title AS title, a.latest AS latest, a.visibility AS visibility, a.read_key_hash AS read_key_hash, a.updated AS updated, COALESCE(vw.total,0) AS views, a.fresh_ttl AS fresh_ttl FROM artifacts a LEFT JOIN views vw ON vw.artifact_id = a.id ORDER BY a.updated DESC LIMIT 500", []string{})
    arts := parse(artrows, []AdmArt{})
    fbrows := sqlite_query(db, "SELECT id, kind, message, context, reporter, version, created FROM feedback ORDER BY created DESC LIMIT 8", []string{})
    fbs := parse(fbrows, []FbRow{})
    sqlite_close(db)

    // header
    h := "<header class=\"flex flex-wrap items-center justify-between gap-3\">"
    h = h + "<div class=\"flex items-center gap-3\"><h1 class=\"text-xl font-semibold tracking-tight\">hart</h1>" + ui_badge("operator", "blue") + "</div>"
    h = h + "<div class=\"flex items-center gap-4 text-sm\"><a class=\"text-muted hover:text-ink hover:underline\" href=\"" + base + "/explore\">explore &rarr;</a><a class=\"text-muted hover:text-ink hover:underline\" href=\"/_fleet/logout\">sign out</a></div>"
    h = h + "</header>"
    h = h + "<p class=\"text-sm leading-6 text-muted\">Every artifact on <span class=\"text-ink\">" + ui_esc(base) + "</span> across all owners &mdash; the operator view (admin-gated). Views are counted server-side; stale = a living deliverable past its freshness SLA.</p>"

    // adoption strip — activity in the last 7 days (values computed above, pre-close)
    h = h + "<div class=\"rounded-lg border border-line dark:border-line-800 bg-surface-100 dark:bg-surface-800 px-4 py-3 text-sm\"><span class=\"text-xs uppercase tracking-wider text-muted\">Last 7 days</span> &nbsp; <span class=\"text-ink dark:text-ink-100 font-semibold\">+" + str(d_own) + "</span> owners &middot; <span class=\"text-ink dark:text-ink-100 font-semibold\">+" + str(d_art) + "</span> artifacts &middot; <span class=\"text-ink dark:text-ink-100 font-semibold\">" + str(d_act) + "</span> updated &middot; <span class=\"text-ink dark:text-ink-100 font-semibold\">" + str(nviews) + "</span> views all-time</div>"

    // stat tiles
    stale_delta := "all fresh"
    if nstale > 0 { stale_delta = "need a refresh" }
    stats := "<div class=\"grid grid-cols-2 gap-3 md:grid-cols-5\">"
    stats = stats + ui_stat("artifacts", str(nart), "all owners")
    stats = stats + ui_stat("owners", str(nown), "namespaces")
    stats = stats + ui_stat("views", str(nviews), "total, server-side")
    stats = stats + ui_stat("stale", str(nstale), stale_delta)
    stats = stats + ui_stat("stored", dash_hsize(bytes), "rendered HTML")
    stats = stats + "</div>"
    h = h + stats

    // stale living deliverables (prominent, only if any)
    if nstale > 0 {
        srows := []string{}
        for _, a := range arts {
            if a.fresh_ttl > 0 && (n - a.updated) > a.fresh_ttl {
                cells := ui_td("<a class=\"text-accent hover:underline\" href=\"" + base + "/a/" + a.id + "\">" + ui_esc(a.id) + "</a>")
                cells = cells + ui_td(ui_badge("stale " + human_dur(n - a.updated), "red"))
                cells = cells + ui_td("<span class=\"text-muted\">SLA " + human_dur(a.fresh_ttl) + "</span>")
                srows = append(srows, ui_tr(cells))
            }
        }
        h = h + ui_card("Stale living deliverables", ui_table([]string{"artifact", "quiet for", "sla"}, srows))
    }

    // owners
    if len(owns) > 0 {
        orows := []string{}
        for _, o := range owns {
            oname := o.owner
            if oname == "" { oname = "(anonymous)" }
            key := ui_badge("open", "neutral")
            if o.has_key == 1 { key = ui_badge("keyed", "green") }
            cells := ui_td("<a class=\"text-accent hover:underline\" href=\"" + base + "/o/" + o.owner + "\">" + ui_esc(oname) + "</a>")
            cells = cells + ui_td("<span class=\"text-ink\">" + str(o.cnt) + "</span>")
            cells = cells + ui_td("<span class=\"text-muted\">" + dash_hsize(o.bytes) + "</span>")
            cells = cells + ui_td(key)
            orows = append(orows, ui_tr(cells))
        }
        h = h + ui_card("Owners", ui_table([]string{"owner", "artifacts", "stored", "namespace"}, orows))
    }

    // all artifacts
    arows := []string{}
    for _, a := range arts {
        title := a.title
        if title == "" { title = a.name }
        stbadge := ""
        if a.fresh_ttl > 0 {
            if (n - a.updated) > a.fresh_ttl { stbadge = " " + ui_badge("stale", "red") } else { stbadge = " " + ui_badge("live", "green") }
        }
        cells := ui_td("<a class=\"text-accent hover:underline\" href=\"" + base + "/a/" + a.id + "\">" + ui_esc(a.id) + "</a>" + stbadge)
        cells = cells + ui_td(vis_badge(a.visibility))
        cells = cells + ui_td("<span class=\"text-ink\">" + str(a.views) + "</span>")
        cells = cells + ui_td("<span class=\"text-muted\">v" + str(a.latest) + " &middot; " + human_dur(n - a.updated) + " ago</span>")
        arows = append(arows, ui_tr(cells))
    }
    h = h + ui_card("All artifacts", ui_table([]string{"artifact", "visibility", "views", "updated"}, arows))

    // recent feedback (hart feedback + the relay dual-write land here)
    if len(fbs) > 0 {
        frows := []string{}
        for _, f := range fbs {
            k := f.kind
            if k == "" { k = "note" }
            rep := f.reporter
            if rep == "" { rep = "anon" }
            cells := ui_td(ui_badge(k, "blue"))
            cells = cells + ui_td("<span class=\"text-ink dark:text-ink-100\">" + ui_esc(f.message) + "</span>")
            cells = cells + ui_td("<span class=\"text-muted\">" + ui_esc(rep) + " · " + time_format(f.created, "%m-%d %H:%M") + "</span>")
            frows = append(frows, ui_tr(cells))
        }
        h = h + ui_card("Recent feedback", ui_table([]string{"kind", "message", "from"}, frows))
    }

    h = h + ui_footer("hart operator dashboard - admin-gated, server-rendered from this instance's DB.",
        []string{"guide", "admin API", "GitHub"},
        []string{base + "/guide", base + "/guide#admin-operator-god-mode", "https://github.com/javimosch/machin-hart"})

    r := ok_html(dash_page(h))
    r = with_header(r, "Content-Security-Policy", "default-src 'none'; style-src 'unsafe-inline'; img-src data:; font-src data:; form-action 'self'; frame-ancestors 'none'")
    r = with_header(r, "Cache-Control", "no-store")
    r = no_frame(r)
    res = r
}
